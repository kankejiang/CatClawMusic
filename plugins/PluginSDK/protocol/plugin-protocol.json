{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CatClawMusic Plugin Protocol",
  "description": "猫爪音乐跨语言插件通信协议规范",
  "version": "1.0.0",

  "definitions": {
    "PluginManifest": {
      "type": "object",
      "required": ["pluginId", "name", "version"],
      "properties": {
        "pluginId": { "type": "string", "description": "插件唯一标识" },
        "name": { "type": "string", "description": "插件显示名称" },
        "version": { "type": "string", "description": "语义化版本号" },
        "author": { "type": "string" },
        "description": { "type": "string" },
        "language": { "type": "string", "description": "运行时语言: csharp/java/python/javascript" },
        "entryPoint": { "type": "string", "description": "入口点标识" },
        "capabilities": { "type": "array", "items": { "type": "string" } }
      }
    },

    "Song": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "album": { "type": "string" },
        "duration": { "type": "integer", "description": "毫秒" },
        "filePath": { "type": "string" },
        "fileSize": { "type": "integer" },
        "bitrate": { "type": "integer" },
        "year": { "type": "integer" },
        "genre": { "type": "string" },
        "coverArtPath": { "type": "string" },
        "lyricsPath": { "type": "string" }
      }
    },

    "LrcLyrics": {
      "type": "object",
      "properties": {
        "metadata": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "artist": { "type": "string" },
            "album": { "type": "string" },
            "author": { "type": "string" },
            "maker": { "type": "string" },
            "version": { "type": "string" }
          }
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string", "description": "hh:mm:ss.fff" },
              "text": { "type": "string" }
            }
          }
        }
      }
    },

    "RemoteFile": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "isDirectory": { "type": "boolean" },
        "size": { "type": "integer" },
        "lastModified": { "type": "integer" }
      }
    },

    "ConnectionProfile": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "protocol": { "type": "string" },
        "host": { "type": "string" },
        "port": { "type": "integer" },
        "userName": { "type": "string" },
        "password": { "type": "string" },
        "basePath": { "type": "string" },
        "isEnabled": { "type": "boolean" }
      }
    },

    "MenuItemEntry": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "title": { "type": "string" }
      }
    },

    "Request": {
      "type": "object",
      "required": ["id", "method"],
      "properties": {
        "id": { "type": "string", "description": "请求唯一ID" },
        "method": { "type": "string", "description": "方法名" },
        "params": { "type": "object", "description": "方法参数" }
      }
    },

    "Response": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "result": { "description": "成功返回值" },
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "integer" },
            "message": { "type": "string" }
          }
        }
      }
    }
  }
}
