<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CatClawMusic.UI.ViewModels"
             x:Class="CatClawMusic.UI.Pages.LibraryPage"
             Title="音乐库"
             BackgroundColor="{StaticResource BackgroundDark}">
    
    <Grid RowDefinitions="Auto,*">
        <!-- 标题栏 -->
        <Frame Grid.Row="0"
               Style="{StaticResource CardStyle}"
               Margin="0,0,0,10"
               Padding="20,15"
               CornerRadius="0">
            <VerticalStackLayout>
                <Label Text="音乐库"
                       Style="{StaticResource LabelHeading}"
                       HorizontalOptions="Center" />
                <!-- 标签切换 -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="{StaticResource SpacingSmall}">
                    <Button Text="本地音乐" 
                            Command="{Binding SwitchTabCommand}"
                            CommandParameter="Local"
                            Style="{StaticResource ButtonSecondary}"
                            CornerRadius="{StaticResource CornerRadiusCircle}"
                            BackgroundColor="{Binding LocalTabColor}"
                            TextColor="{StaticResource TextPrimary}"
                            FontSize="{StaticResource FontSizeSmall}"
                            Padding="20,8" />
                    <Button Text="网络音乐" 
                            Command="{Binding SwitchTabCommand}"
                            CommandParameter="Network"
                            Style="{StaticResource ButtonSecondary}"
                            CornerRadius="{StaticResource CornerRadiusCircle}"
                            BackgroundColor="{Binding NetworkTabColor}"
                            TextColor="{StaticResource TextPrimary}"
                            FontSize="{StaticResource FontSizeSmall}"
                            Padding="20,8" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>
        
        <!-- 歌曲列表 -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Songs}"
                        SelectionMode="Single"
                        SelectionChanged="OnSongSelected"
                        BackgroundColor="Transparent">
            <CollectionView.Header>
                <Label Text="所有歌曲"
                       Style="{StaticResource LabelSubheading}"
                       Margin="0,0,0,10" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Style="{StaticResource CardStyle}"
                           Margin="0,0,0,10"
                           Padding="15">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="{StaticResource SpacingMedium}">
                            <!-- 专辑封面 -->
                            <Frame Grid.Column="0"
                                   CornerRadius="{StaticResource CornerRadiusMedium}"
                                   IsClippedToBounds="True"
                                   Padding="0"
                                   BackgroundColor="{StaticResource SurfaceLight}">
                                <Image Source="{Binding CoverArtPath}"
                                       Aspect="AspectFill"
                                       HeightRequest="60"
                                       WidthRequest="60"
                                       BackgroundColor="{StaticResource SurfaceMedium}" />
                            </Frame>
                            
                            <!-- 歌曲信息 -->
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding Title}"
                                       FontSize="{StaticResource FontSizeLarge}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding Artist}"
                                       FontSize="{StaticResource FontSizeMedium}"
                                       TextColor="{StaticResource TextSecondary}"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding Album}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       TextColor="{StaticResource TextDisabled}"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            
                            <!-- 更多操作按钮（预留） -->
                            <!-- <Button Grid.Column="2"
                                    Text="⋯"
                                    Style="{StaticResource ButtonIcon}"
                                    FontSize="{StaticResource FontSizeXLarge}"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End" /> -->
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
    
</ContentPage>
