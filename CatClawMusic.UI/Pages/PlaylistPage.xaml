<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatClawMusic.UI.Pages.PlaylistPage"
             Title="播放列表"
             BackgroundColor="{StaticResource BackgroundDark}">
    
    <Grid RowDefinitions="Auto,*"
          Padding="{StaticResource SpacingLarge}">
        <!-- 标题栏 -->
        <Frame Grid.Row="0"
               Style="{StaticResource CardStyle}"
               CornerRadius="0"
               Margin="0,0,0,10"
               Padding="20,15">
            <Label Text="播放列表"
                   Style="{StaticResource LabelHeading}"
                   HorizontalOptions="Center" />
        </Frame>
        
        <!-- 播放列表 -->
        <CollectionView Grid.Row="1"
                        x:Name="PlaylistCollection"
                        SelectionMode="Single"
                        SelectionChanged="OnPlaylistSelected"
                        BackgroundColor="Transparent">
            <CollectionView.Header>
                <Label Text="我的播放列表"
                       Style="{StaticResource LabelSubheading}"
                       Margin="0,0,0,10" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Style="{StaticResource CardStyle}"
                           Margin="0,0,0,10"
                           Padding="20,15">
                        <Label Text="{Binding Name}"
                               Style="{StaticResource LabelPrimary}"
                               FontSize="{StaticResource FontSizeLarge}"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               VerticalOptions="Center" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
    
</ContentPage>
