<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatClawMusic.UI.Pages.SettingsPage"
             Title="⚙️ 设置"
             Shell.BackgroundColor="#FF7BAC"
             Shell.ForegroundColor="White"
             Shell.TitleColor="White">
    
    <ScrollView BackgroundColor="#FFF5F7">
        <VerticalStackLayout Spacing="16" Padding="16">
            
            <!-- 网络存储 -->
            <Frame BackgroundColor="White"
                   BorderColor="#F5E6ED"
                   CornerRadius="20" Padding="0" HasShadow="True">
                <Frame.Shadow>
                    <Shadow Brush="#E8C4D0" Offset="0,3" Opacity="0.2" Radius="10"/>
                </Frame.Shadow>
                <VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnWebDavTapped" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,14">
                        <Label Text="☁️" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="14,0">
                            <Label Text="WebDAV 网络存储"
                                   FontSize="15" FontAttributes="Bold"
                                   FontFamily="HappyZcool2016" TextColor="#4A3728" />
                            <Label Text="连接 NAS 或网络硬盘"
                                   FontSize="12" TextColor="#C4B5A5" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="#D4C5C9" VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#F5E6ED" Margin="18,0" />
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavidromeTapped" />
                        </Grid.GestureRecognizers>
                        <Label Text="🎵" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="14,0">
                            <Label Text="Navidrome"
                                   FontSize="15" FontAttributes="Bold"
                                   FontFamily="HappyZcool2016" TextColor="#4A3728" />
                            <Label Text="自托管音乐流媒体服务器"
                                   FontSize="12" TextColor="#C4B5A5" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="#D4C5C9" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- 缓存 -->
            <Frame BackgroundColor="White"
                   BorderColor="#F5E6ED"
                   CornerRadius="20" Padding="18,16" HasShadow="True">
                <Frame.Shadow>
                    <Shadow Brush="#E8C4D0" Offset="0,3" Opacity="0.2" Radius="10"/>
                </Frame.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="💾 缓存设置" FontSize="16" FontAttributes="Bold"
                           FontFamily="HappyZcool2016" TextColor="#FF7BAC" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="缓存大小限制" FontSize="14"
                               TextColor="#4A3728" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding CacheSizeText}"
                               FontSize="16" FontAttributes="Bold"
                               FontFamily="HappyZcool2016" TextColor="#FF7BAC"
                               VerticalOptions="Center" />
                    </Grid>
                    <Slider Value="{Binding CacheSizeGB}" Minimum="1" Maximum="15"
                            ValueChanged="OnCacheSizeChanged" />
                    <Button Text="🗑️ 清除缓存"
                            Command="{Binding ClearCacheCommand}"
                            BackgroundColor="#FFD4E5" TextColor="#E8588E"
                            CornerRadius="14" FontSize="14"
                            FontFamily="HappyZcool2016" Padding="16,10" />
                </VerticalStackLayout>
            </Frame>

            <!-- 播放设置 -->
            <Frame BackgroundColor="White"
                   BorderColor="#F5E6ED"
                   CornerRadius="20" Padding="18,16" HasShadow="True">
                <Frame.Shadow>
                    <Shadow Brush="#E8C4D0" Offset="0,3" Opacity="0.2" Radius="10"/>
                </Frame.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="🎵 播放设置" FontSize="16" FontAttributes="Bold"
                           FontFamily="HappyZcool2016" TextColor="#FF7BAC" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="仅在 WiFi 下缓存" FontSize="14"
                               TextColor="#4A3728" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding OnlyWiFiCache}"
                                OnColor="#FF7BAC" ThumbColor="White"
                                HorizontalOptions="End" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- 关于 -->
            <Frame BackgroundColor="White"
                   BorderColor="#F5E6ED"
                   CornerRadius="20" Padding="18,16" HasShadow="True">
                <Frame.Shadow>
                    <Shadow Brush="#E8C4D0" Offset="0,3" Opacity="0.2" Radius="10"/>
                </Frame.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="🐾 关于猫爪音乐" FontSize="16" FontAttributes="Bold"
                           FontFamily="HappyZcool2016" TextColor="#FF7BAC" />
                    <Label Text="猫爪音乐 v1.0 · .NET MAUI" FontSize="13" TextColor="#8B7355" />
                    <Label Text="作者：kankejiang · MIT 协议" FontSize="13" TextColor="#8B7355" />
                </VerticalStackLayout>
            </Frame>
            
            <BoxView HeightRequest="20" Color="Transparent" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
