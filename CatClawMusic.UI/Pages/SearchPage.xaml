<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatClawMusic.UI.Pages.SearchPage"
             Title="🔍 搜索"
             Shell.BackgroundColor="#FF7BAC"
             Shell.ForegroundColor="White"
             Shell.TitleColor="White">
    
    <Grid RowDefinitions="Auto,*"
          RowSpacing="16"
          Padding="16">
        
        <!-- 搜索框 -->
        <Frame Grid.Row="0"
               BackgroundColor="White"
               BorderColor="#F5E6ED"
               CornerRadius="22"
               Padding="8,4"
               HasShadow="True">
            <Frame.Shadow>
                <Shadow Brush="#E8C4D0" Offset="0,3" Opacity="0.2" Radius="10"/>
            </Frame.Shadow>
            <SearchBar Placeholder="🔍 搜索歌曲、艺术家、专辑..."
                       TextChanged="OnSearchTextChanged"
                       BackgroundColor="Transparent"
                       CancelButtonColor="#FF7BAC"
                       PlaceholderColor="#C4B5A5"
                       TextColor="#4A3728"
                       FontFamily="HappyZcool2016"
                       HorizontalOptions="FillAndExpand" />
        </Frame>
        
        <!-- 搜索结果 -->
        <CollectionView Grid.Row="1"
                         x:Name="SearchResults"
                         SelectionMode="Single"
                         SelectionChanged="OnSongSelected"
                         BackgroundColor="Transparent">
            <CollectionView.Header>
                <Label Text="{Binding ResultCount}"
                       FontSize="13"
                       TextColor="#C4B5A5"
                       FontFamily="HappyZcool2016"
                       Margin="4,0,0,8" />
            </CollectionView.Header>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="12"
                                     Padding="40">
                    <Label Text="🐾"
                           FontSize="48"
                           HorizontalOptions="Center" />
                    <Label Text="输入关键词搜索歌曲"
                           FontSize="16"
                           TextColor="#C4B5A5"
                           FontFamily="HappyZcool2016"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White"
                           BorderColor="#F5E6ED"
                           CornerRadius="18"
                           Margin="2,4"
                           Padding="14"
                           HasShadow="True">
                        <Frame.Shadow>
                            <Shadow Brush="#E8C4D0" Offset="0,2" Opacity="0.15" Radius="8"/>
                        </Frame.Shadow>
                        <Grid ColumnDefinitions="48,*"
                               ColumnSpacing="14">
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#F5E6ED"
                                    StrokeThickness="1"
                                    HeightRequest="48"
                                    WidthRequest="48"
                                    BackgroundColor="#FCF0F4">
                                <Label Text="🎵"
                                       FontSize="20"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="3">
                                <Label Text="{Binding Title}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       FontFamily="HappyZcool2016"
                                       TextColor="#4A3728"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding Artist}"
                                       FontSize="13"
                                       TextColor="#8B7355"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
    
</ContentPage>
