<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CatClawMusic.UI"
             x:Class="CatClawMusic.UI.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 🐾 猫爪音乐 — 少女可爱风配色 -->

            <!-- 背景色 -->
            <Color x:Key="PageBackground">#FFF5F7</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="CardBorder">#F5E6ED</Color>

            <!-- 主色：猫爪粉 -->
            <Color x:Key="PrimaryColor">#FF7BAC</Color>
            <Color x:Key="PrimaryLight">#FFB3D0</Color>
            <Color x:Key="PrimaryDark">#E8588E</Color>
            <Color x:Key="PrimaryGlow">#FFD4E5</Color>

            <!-- 辅助色：薰衣草紫 -->
            <Color x:Key="SecondaryColor">#C4A7E7</Color>
            <Color x:Key="SecondaryLight">#E8D5F5</Color>

            <!-- 点缀色：薄荷绿 -->
            <Color x:Key="AccentColor">#98D8C8</Color>
            <Color x:Key="AccentLight">#C5F0E5</Color>

            <!-- 文字色 -->
            <Color x:Key="TextPrimary">#4A3728</Color>
            <Color x:Key="TextSecondary">#8B7355</Color>
            <Color x:Key="TextHint">#C4B5A5</Color>

            <!-- 状态色 -->
            <Color x:Key="SuccessColor">#90D5AC</Color>
            <Color x:Key="WarningColor">#FFC97A</Color>
            <Color x:Key="ErrorColor">#FF8A8A</Color>

            <!-- 标签/按钮色 -->
            <Color x:Key="TabActive">#FF7BAC</Color>
            <Color x:Key="TabInactive">#D4C5C9</Color>

            <!-- 兼容旧代码的别名 -->
            <Color x:Key="BackgroundDark">#FFF5F7</Color>
            <Color x:Key="SurfaceDark">#FFFFFF</Color>
            <Color x:Key="SurfaceMedium">#FCF0F4</Color>
            <Color x:Key="SurfaceLight">#F5E6ED</Color>
            <Color x:Key="TextDisabled">#C4B5A5</Color>

            <!-- 字体大小 -->
            <x:Double x:Key="FontSizeMicro">10</x:Double>
            <x:Double x:Key="FontSizeSmall">12</x:Double>
            <x:Double x:Key="FontSizeMedium">14</x:Double>
            <x:Double x:Key="FontSizeLarge">16</x:Double>
            <x:Double x:Key="FontSizeXLarge">20</x:Double>
            <x:Double x:Key="FontSizeXXLarge">24</x:Double>
            <x:Double x:Key="FontSizeXXXLarge">32</x:Double>

            <!-- 间距 -->
            <x:Double x:Key="SpacingSmall">8</x:Double>
            <x:Double x:Key="SpacingMedium">16</x:Double>
            <x:Double x:Key="SpacingLarge">24</x:Double>
            <x:Double x:Key="SpacingXLarge">32</x:Double>

            <!-- 圆角 -->
            <x:Double x:Key="CornerRadiusSmall">8</x:Double>
            <x:Double x:Key="CornerRadiusMedium">14</x:Double>
            <x:Double x:Key="CornerRadiusLarge">20</x:Double>
            <x:Double x:Key="CornerRadiusXLarge">28</x:Double>
            <x:Double x:Key="CornerRadiusCircle">100</x:Double>

            <!-- 卡片样式 -->
            <Style x:Key="CardStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="BorderColor" Value="#F5E6ED" />
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Shadow">
                    <Shadow Brush="#E8C4D0"
                            Offset="0,4"
                            Opacity="0.25"
                            Radius="12"/>
                </Setter>
            </Style>

            <!-- 全局页面 -->
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="#FFF5F7" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <!-- 标签 -->
            <Style TargetType="Label" x:Key="LabelPrimary">
                <Setter Property="TextColor" Value="#4A3728" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
            </Style>
            <Style TargetType="Label" x:Key="LabelSecondary">
                <Setter Property="TextColor" Value="#8B7355" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
            </Style>
            <Style TargetType="Label" x:Key="LabelHeading">
                <Setter Property="TextColor" Value="#4A3728" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontFamily" Value="HappyZcool2016" />
            </Style>
            <Style TargetType="Label" x:Key="LabelSubheading">
                <Setter Property="TextColor" Value="#4A3728" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontFamily" Value="HappyZcool2016" />
            </Style>
            <Style TargetType="Label" x:Key="LabelTitle">
                <Setter Property="TextColor" Value="#4A3728" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontFamily" Value="HappyZcool2016" />
            </Style>

            <!-- 按钮 -->
            <Style TargetType="Button" x:Key="ButtonPrimary">
                <Setter Property="BackgroundColor" Value="#FF7BAC" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="20,12" />
                <Setter Property="FontFamily" Value="HappyZcool2016" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#FF7BAC" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#E8588E" />
                                    <Setter Property="Scale" Value="0.96" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Disabled">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#F5E6ED" />
                                    <Setter Property="TextColor" Value="#C4B5A5" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <Style TargetType="Button" x:Key="ButtonSecondary">
                <Setter Property="BackgroundColor" Value="#FCF0F4" />
                <Setter Property="TextColor" Value="#FF7BAC" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="20,12" />
                <Setter Property="FontFamily" Value="HappyZcool2016" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#FCF0F4" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#FFD4E5" />
                                    <Setter Property="Scale" Value="0.96" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Disabled">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#FFF5F7" />
                                    <Setter Property="TextColor" Value="#C4B5A5" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <Style TargetType="Button" x:Key="ButtonIcon">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="#4A3728" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="CornerRadius" Value="50" />
                <Setter Property="WidthRequest" Value="48" />
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#FFD4E5" />
                                    <Setter Property="Scale" Value="0.92" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <!-- 滑块 -->
            <Style TargetType="Slider">
                <Setter Property="MinimumTrackColor" Value="#FF7BAC" />
                <Setter Property="MaximumTrackColor" Value="#F5E6ED" />
                <Setter Property="ThumbColor" Value="#FF7BAC" />
            </Style>

            <!-- 输入框 -->
            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="#4A3728" />
                <Setter Property="BackgroundColor" Value="#FFFBFD" />
                <Setter Property="PlaceholderColor" Value="#C4B5A5" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
            </Style>

            <!-- SearchBar -->
            <Style TargetType="SearchBar">
                <Setter Property="TextColor" Value="#4A3728" />
                <Setter Property="PlaceholderColor" Value="#C4B5A5" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
            </Style>

            <!-- Switch -->
            <Style TargetType="Switch">
                <Setter Property="OnColor" Value="#FF7BAC" />
                <Setter Property="ThumbColor" Value="White" />
            </Style>

            <!-- 默认样式 -->
            <Style TargetType="Label" BasedOn="{StaticResource LabelPrimary}" />
            <Style TargetType="Button" BasedOn="{StaticResource ButtonSecondary}" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
