<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0-android</TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>CatClawMusic.UI</RootNamespace>
    <ApplicationTitle>猫爪音乐</ApplicationTitle>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <SupportedOSPlatformVersion>31</SupportedOSPlatformVersion>
  </PropertyGroup>

  <!-- MauiSplashScreen：启动画面居中显示。360x640 约为手机屏幕 dp 尺寸，保持原图比例 -->
  <ItemGroup>
    <MauiSplashScreen Include="Resources\splash_catclawmusic_main.png" Color="#000000" BaseSize="360,640" />
  </ItemGroup>

  <!-- MauiIcon：应用图标 -->
  <ItemGroup>
    <MauiIcon Include="Resources\app_icon.png" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CatClawMusic.Core\CatClawMusic.Core.csproj" />
    <ProjectReference Include="..\CatClawMusic.Data\CatClawMusic.Data.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
    <PackageReference Include="Microsoft.Maui.Controls" Version="9.0.0" />
    <PackageReference Include="Microsoft.Maui.Controls.Compatibility" Version="9.0.0" />
  </ItemGroup>
</Project>
