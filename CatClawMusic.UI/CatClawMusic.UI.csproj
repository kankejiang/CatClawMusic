<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0-android</TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>CatClawMusic.UI</RootNamespace>
    <ApplicationTitle>猫爪音乐</ApplicationTitle>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <SupportedOSPlatformVersion>31</SupportedOSPlatformVersion>
    <LangVersion>preview</LangVersion>
    <NoWarn>NU1605;NU1608</NoWarn>
    <AndroidUseFastDeployment>False</AndroidUseFastDeployment>
    <EmbedAssembliesIntoApk>True</EmbedAssembliesIntoApk>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\CatClawMusic.Core\CatClawMusic.Core.csproj" />
    <ProjectReference Include="..\CatClawMusic.Data\CatClawMusic.Data.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.0.0" />
    <!-- Material 1.12.0 自带 AppCompat/CardView/RecyclerView，不要重复引用 -->
    <PackageReference Include="Xamarin.AndroidX.Fragment" Version="1.8.4" />
    <PackageReference Include="Xamarin.AndroidX.ConstraintLayout" Version="2.2.0" />
    <PackageReference Include="Xamarin.Google.Android.Material" Version="1.12.0" />
    <PackageReference Include="Xamarin.AndroidX.Lifecycle.LiveData.Core" Version="2.8.7" />
    <PackageReference Include="Xamarin.AndroidX.Lifecycle.Process" Version="2.8.7" />
    <PackageReference Include="Xamarin.AndroidX.Lifecycle.Common" Version="2.8.7" />
  </ItemGroup>
</Project>
