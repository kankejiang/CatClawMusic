<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
      xmlns:pages="clr-namespace:CatClawMusic.UI.Pages"
      x:Class="CatClawMusic.UI.AppShell"
      Shell.FlyoutBehavior="Disabled">
    
    <!-- 底部标签栏 -->
    <TabBar>
        <Tab Title="音乐库" Icon="library.png">
            <ShellContent ContentTemplate="{DataTemplate pages:LibraryPage}" />
        </Tab>
        <Tab Title="播放列表" Icon="playlist.png">
            <ShellContent ContentTemplate="{DataTemplate pages:PlaylistPage}" />
        </Tab>
        <Tab Title="搜索" Icon="search.png">
            <ShellContent ContentTemplate="{DataTemplate pages:SearchPage}" />
        </Tab>
        <Tab Title="设置" Icon="settings.png">
            <ShellContent ContentTemplate="{DataTemplate pages:SettingsPage}" />
        </Tab>
    </TabBar>
    
    <!-- 路由（用于导航到非标签页面） -->
    <ShellContent Route="NowPlayingPage" ContentTemplate="{DataTemplate pages:NowPlayingPage}" />
    <ShellContent Route="WebDavSettingsPage" ContentTemplate="{DataTemplate pages:WebDavSettingsPage}" />
    <ShellContent Route="NavidromeSettingsPage" ContentTemplate="{DataTemplate pages:NavidromeSettingsPage}" />
    
</Shell>
