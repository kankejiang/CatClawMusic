<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notif_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/notif_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/notif_cover"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_home"
            android:layout_marginRight="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notif_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="猫爪音乐"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notif_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未在播放"
                android:textColor="#B0FFFFFF"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginTop="1dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/notif_controls"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_favorite"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:src="@drawable/ic_notif_favorite_border"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:contentDescription="收藏"
            android:padding="6dp" />

        <ImageButton
            android:id="@+id/btn_previous"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:src="@drawable/ic_notif_previous"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:contentDescription="上一曲"
            android:padding="6dp" />

        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/ic_notif_play"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:contentDescription="播放"
            android:padding="4dp" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:src="@drawable/ic_notif_next"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:contentDescription="下一曲"
            android:padding="6dp" />

        <ImageButton
            android:id="@+id/btn_lyric"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:src="@drawable/ic_notif_lyric_off"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:contentDescription="桌面歌词"
            android:padding="6dp" />
    </LinearLayout>
</LinearLayout>
