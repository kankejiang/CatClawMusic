<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- 纯色背景层（代码设置为封面主色调） -->
    <View android:id="@+id/gradient_background" android:layout_width="match_parent"
        android:layout_height="match_parent" android:background="?attr/catClawPageBackground" />

    <!-- 动态光晕：位置由代码根据封面颜色水平分布动态设置 -->
    <View android:id="@+id/glow_1" android:layout_width="220dp"
        android:layout_height="220dp" android:layout_gravity="top"
        android:layout_marginTop="300dp" />
    <View android:id="@+id/glow_2" android:layout_width="280dp"
        android:layout_height="280dp" android:layout_gravity="top"
        android:layout_marginTop="330dp" />
    <View android:id="@+id/glow_3" android:layout_width="180dp"
        android:layout_height="180dp" android:layout_gravity="top"
        android:layout_marginTop="380dp" />
    <View android:id="@+id/glow_4" android:layout_width="320dp"
        android:layout_height="320dp" android:layout_gravity="bottom"
        android:layout_marginBottom="160dp" />
    <View android:id="@+id/glow_5" android:layout_width="200dp"
        android:layout_height="200dp" android:layout_gravity="bottom"
        android:layout_marginBottom="200dp" />
    <View android:id="@+id/glow_6" android:layout_width="260dp"
        android:layout_height="260dp" android:layout_gravity="bottom"
        android:layout_marginBottom="80dp" />

    <!-- 光晕底部遮罩：透明→背景色（底部自然收尾） -->
    <View android:id="@+id/reflection_mask_bottom" android:layout_width="match_parent"
        android:layout_height="100dp" android:layout_gravity="bottom" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:clipChildren="false">

        <!-- 专辑封面：填充上半部分 -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="2.6">
            <ImageView android:id="@+id/album_cover" android:layout_width="match_parent"
                android:layout_height="match_parent" android:scaleType="centerCrop" />

            <!-- 封面底部雾化过渡：从透明渐变到背景色，让封面与下方内容自然衔接 -->
            <View android:id="@+id/cover_fog" android:layout_width="match_parent"
                android:layout_height="60dp" android:layout_gravity="bottom" />
        </FrameLayout>

        <!-- 歌名 / 艺术家 -->
        <TextView android:id="@+id/song_title" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="18sp"
            android:textColor="#333333" android:fontFamily="sans-serif-medium"
            android:gravity="start" android:maxLines="1" android:ellipsize="end"
            android:layout_marginHorizontal="24dp" android:layout_marginTop="12dp"
            android:layout_marginBottom="3dp" />
        <TextView android:id="@+id/song_artist" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#888888"
            android:textSize="14sp" android:gravity="start"
            android:layout_marginHorizontal="24dp" android:layout_marginBottom="8dp" />

        <!-- 歌词区 -->
        <LinearLayout android:id="@+id/lyrics_area" android:layout_width="match_parent"
            android:layout_height="0dp" android:layout_weight="0.95"
            android:orientation="vertical" android:gravity="center"
            android:clipChildren="false" android:paddingHorizontal="24dp"
            android:paddingTop="4dp">

            <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev2" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                android:textColor="#90999999" android:textSize="12sp"
                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                android:lineSpacingMultiplier="1.7" android:alpha="0.55" />

            <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                android:textColor="#B0999999" android:textSize="14sp"
                android:gravity="center" android:maxLines="2" android:ellipsize="end"
                android:lineSpacingMultiplier="1.7" />

            <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_current" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginVertical="12dp"
                android:textColor="#FF444444" android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" android:maxLines="3" android:ellipsize="end"
                android:lineSpacingMultiplier="1.7"
                android:text=" 猫爪音乐" />

            <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="12dp"
                android:textColor="#B0999999" android:textSize="14sp"
                android:gravity="center" android:maxLines="2" android:ellipsize="end"
                android:lineSpacingMultiplier="1.7" />

            <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next2" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="10dp"
                android:textColor="#90999999" android:textSize="12sp"
                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                android:lineSpacingMultiplier="1.7" android:alpha="0.55" />
        </LinearLayout>

        <!-- 控制区 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/controls_card"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp" android:layout_marginBottom="20dp"
            app:cardCornerRadius="28dp" app:cardElevation="0dp"
            app:strokeColor="#15CCCCCC" app:strokeWidth="1dp"
            app:cardBackgroundColor="#26000000">

            <LinearLayout android:id="@+id/controls_area"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:paddingHorizontal="22dp"
                android:paddingTop="14dp" android:paddingBottom="14dp">

                <!-- 进度条 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/time_current" android:layout_width="36dp"
                        android:layout_height="wrap_content" android:text="0:00"
                        android:textColor="#DDFFFFFF" android:textSize="11sp"
                        android:gravity="center" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/progress_slider"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginHorizontal="8dp"
                        android:valueFrom="0" android:valueTo="100" android:value="0"
                        app:thumbRadius="9dp"
                        app:thumbWidth="18dp"
                        app:thumbHeight="18dp"
                        app:thumbColor="#FFFFFF"
                        app:haloColor="#30FFFFFF"
                        app:trackColorActive="#FFFFFF"
                        app:trackColorInactive="#50FFFFFF"
                        app:trackHeight="2dp" />
                    <TextView android:id="@+id/time_total" android:layout_width="36dp"
                        android:layout_height="wrap_content" android:text="0:00"
                        android:textColor="#DDFFFFFF" android:textSize="11sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- 播放列表 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="right" android:layout_marginTop="2dp">
                    <ImageButton android:id="@+id/btn_playlist" android:layout_width="28dp"
                        android:layout_height="28dp" android:src="@drawable/ic_playlist"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="#DDFFFFFF" android:padding="2dp" />
                </LinearLayout>

                <!-- 控制按钮 -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center"
                    android:layout_gravity="center_horizontal" android:layout_marginTop="10dp">

                    <ImageButton android:id="@+id/btn_like" android:layout_width="44dp"
                        android:layout_height="44dp" android:src="@drawable/ic_favorite_border"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp" android:tint="#EEFFFFFF" />

                    <ImageButton android:id="@+id/btn_prev" android:layout_width="48dp"
                        android:layout_height="48dp" android:src="@drawable/ic_skip_previous"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp" android:tint="#EEEEEE" />

                    <ImageButton android:id="@+id/btn_play_pause"
                        android:layout_width="64dp" android:layout_height="64dp"
                        android:src="@drawable/ic_play"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginHorizontal="12dp" android:tint="#FFFFFF" />

                    <ImageButton android:id="@+id/btn_next" android:layout_width="48dp"
                        android:layout_height="48dp" android:src="@drawable/ic_skip_next"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp" android:tint="#EEEEEE" />

                    <ImageButton android:id="@+id/btn_mode_cycle" android:layout_width="44dp"
                        android:layout_height="44dp" android:src="@drawable/ic_repeat"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginStart="4dp" android:tint="#EEFFFFFF" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</FrameLayout>