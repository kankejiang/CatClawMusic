<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/pageBackground">

    <!-- 专辑封面 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1.6" android:gravity="center"
        android:paddingHorizontal="48dp" android:orientation="vertical">

        <FrameLayout android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="240dp" android:layout_height="240dp"
                app:cardCornerRadius="24dp" app:cardElevation="0dp"
                app:strokeColor="@color/cardBorderDark" app:strokeWidth="0.5dp"
                app:cardBackgroundColor="@color/cardBackgroundSolid">
                <ImageView android:id="@+id/album_cover" android:layout_width="match_parent"
                    android:layout_height="match_parent" android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <!-- 歌名/艺术家 -->
        <TextView android:id="@+id/song_title" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="18sp"
            android:textColor="@color/textPrimary" android:fontFamily="sans-serif-medium"
            android:gravity="center" android:maxLines="1" android:ellipsize="end"
            android:layout_marginTop="16dp" />
        <TextView android:id="@+id/song_artist" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/textSecondary"
            android:textSize="13sp" android:gravity="center" android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 歌词区（支持5行歌词显示） -->
    <LinearLayout android:id="@+id/lyrics_area" android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="0.8" android:orientation="vertical"
        android:gravity="center" android:clipChildren="false"
        android:paddingHorizontal="24dp">

        <!-- 上上一行歌词 -->
        <TextView android:id="@+id/lyric_prev2" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="2dp"
            android:textColor="@color/textHint" android:textSize="11sp"
            android:gravity="center" android:maxLines="1" android:ellipsize="end"
            android:lineSpacingMultiplier="1.2" android:alpha="0.6" />

        <!-- 上一行歌词 -->
        <TextView android:id="@+id/lyric_prev" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="4dp"
            android:textColor="@color/textHint" android:textSize="13sp"
            android:gravity="center" android:maxLines="2" android:ellipsize="end"
            android:lineSpacingMultiplier="1.2" />

        <!-- 当前歌词 -->
        <TextView android:id="@+id/lyric_current" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginVertical="4dp"
            android:textColor="@color/primaryColor" android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center" android:maxLines="3" android:ellipsize="end"
            android:lineSpacingMultiplier="1.3"
            android:text=" 猫爪音乐" />

        <!-- 下一行歌词 -->
        <TextView android:id="@+id/lyric_next" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="4dp"
            android:textColor="@color/textHint" android:textSize="13sp"
            android:gravity="center" android:maxLines="2" android:ellipsize="end"
            android:lineSpacingMultiplier="1.2" />

        <!-- 下下一行歌词 -->
        <TextView android:id="@+id/lyric_next2" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="2dp"
            android:textColor="@color/textHint" android:textSize="11sp"
            android:gravity="center" android:maxLines="1" android:ellipsize="end"
            android:lineSpacingMultiplier="1.2" android:alpha="0.6" />
    </LinearLayout>

    <!-- 频谱可视化 -->
    <FrameLayout android:id="@+id/spectrum_container"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp" />

    <!-- 控制区域 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/controls_card"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp" android:layout_marginBottom="16dp"
        android:layout_marginTop="4dp"
        app:cardCornerRadius="20dp" app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder" app:strokeWidth="1dp"
        app:cardBackgroundColor="@color/cardBackground">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="20dp"
            android:paddingTop="16dp" android:paddingBottom="16dp">

            <!-- 进度条行：时间 | 进度条 | 时间 | 播放列表 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/time_current" android:layout_width="36dp"
                    android:layout_height="wrap_content" android:text="0:00"
                    android:textColor="@color/textHint" android:textSize="11sp"
                    android:gravity="center" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/progress_slider"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginHorizontal="8dp"
                    android:valueFrom="0" android:valueTo="100" android:value="0"
                    app:thumbColor="@color/primaryColor"
                    app:trackColorActive="@color/primaryColor"
                    app:trackColorInactive="@color/primaryGlow"
                    app:thumbRadius="8dp" app:trackHeight="2dp" />
                <TextView android:id="@+id/time_total" android:layout_width="36dp"
                    android:layout_height="wrap_content" android:text="0:00"
                    android:textColor="@color/textHint" android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- 播放列表按钮：右对齐，进度条下方 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="right" android:layout_marginTop="0dp" android:layout_marginBottom="0dp">
                <ImageButton android:id="@+id/btn_playlist" android:layout_width="28dp"
                    android:layout_height="28dp" android:src="@drawable/ic_playlist"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/textHint" android:padding="2dp" />
            </LinearLayout>

            <!-- 控制按钮：居中排列 -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:layout_gravity="center_horizontal" android:layout_marginTop="12dp">

                    <ImageButton android:id="@+id/btn_like" android:layout_width="44dp"
                        android:layout_height="44dp" android:src="@drawable/ic_favorite_border"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp" android:tint="@color/textHint" />

                    <ImageButton android:id="@+id/btn_prev" android:layout_width="48dp"
                        android:layout_height="48dp" android:src="@drawable/ic_skip_previous"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp" android:tint="@color/textPrimary" />

                <ImageButton android:id="@+id/btn_play_pause"
                    android:layout_width="64dp" android:layout_height="64dp"
                    android:src="@drawable/ic_play"
                    android:background="@drawable/bg_rounded_glass"
                    android:layout_marginHorizontal="12dp" />

                <ImageButton android:id="@+id/btn_next" android:layout_width="48dp"
                    android:layout_height="48dp" android:src="@drawable/ic_skip_next"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginEnd="4dp" android:tint="@color/textPrimary" />

                <ImageButton android:id="@+id/btn_mode_cycle" android:layout_width="44dp"
                    android:layout_height="44dp" android:src="@drawable/ic_repeat"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="4dp" android:tint="@color/textHint" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
