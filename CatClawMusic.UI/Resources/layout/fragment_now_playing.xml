<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- 动态渐变背景层（代码设置颜色） -->
    <View android:id="@+id/gradient_background" android:layout_width="match_parent"
        android:layout_height="match_parent" android:background="?attr/catClawPageBackground" />

    <!-- 封面发光效果（全屏径向） -->
    <View android:id="@+id/cover_glow" android:layout_width="match_parent"
        android:layout_height="match_parent" android:alpha="0.16" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:clipChildren="false">

        <!-- 专辑封面：撑满上半部分 -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="2.4" android:gravity="center"
            android:paddingHorizontal="28dp" android:paddingTop="20dp"
            android:paddingBottom="6dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:layout_gravity="center"
                app:cardCornerRadius="22dp" app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp">
                <ImageView android:id="@+id/album_cover" android:layout_width="match_parent"
                    android:layout_height="match_parent" android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <!-- 歌名 / 艺术家 -->
        <TextView android:id="@+id/song_title" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="17sp"
            android:textColor="#FFFFFF" android:fontFamily="sans-serif-medium"
            android:gravity="center" android:maxLines="1" android:ellipsize="end"
            android:layout_marginHorizontal="32dp" android:layout_marginBottom="2dp"
            android:shadowColor="#60000000" android:shadowRadius="5" android:shadowDy="1" />
        <TextView android:id="@+id/song_artist" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#BBFFFFFF"
            android:textSize="13sp" android:gravity="center"
            android:layout_marginHorizontal="32dp" android:layout_marginBottom="10dp"
            android:shadowColor="#40000000" android:shadowRadius="3" android:shadowDy="1" />

        <!-- 歌词区 -->
        <LinearLayout android:id="@+id/lyrics_area" android:layout_width="match_parent"
            android:layout_height="0dp" android:layout_weight="0.85"
            android:orientation="vertical" android:gravity="center"
            android:clipChildren="false" android:paddingHorizontal="24dp"
            android:paddingTop="4dp">

            <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev2" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                android:textColor="#70FFFFFF" android:textSize="12sp"
                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                android:lineSpacingMultiplier="1.7" android:alpha="0.55" />

            <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                android:textColor="#A0FFFFFF" android:textSize="14sp"
                android:gravity="center" android:maxLines="2" android:ellipsize="end"
                android:lineSpacingMultiplier="1.7" />

            <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_current" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginVertical="12dp"
                android:textColor="#FFFFFF" android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" android:maxLines="3" android:ellipsize="end"
                android:lineSpacingMultiplier="1.7"
                android:text=" 猫爪音乐" />

            <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="12dp"
                android:textColor="#A0FFFFFF" android:textSize="14sp"
                android:gravity="center" android:maxLines="2" android:ellipsize="end"
                android:lineSpacingMultiplier="1.7" />

            <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next2" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="10dp"
                android:textColor="#70FFFFFF" android:textSize="12sp"
                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                android:lineSpacingMultiplier="1.7" android:alpha="0.55" />
        </LinearLayout>

        <!-- 控制区 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp" android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp" app:cardElevation="0dp"
            app:strokeColor="#10FFFFFF" app:strokeWidth="1dp"
            app:cardBackgroundColor="#33000000">

            <LinearLayout android:id="@+id/controls_area"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:paddingHorizontal="20dp"
                android:paddingTop="16dp" android:paddingBottom="16dp">

                <!-- 进度条 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/time_current" android:layout_width="36dp"
                        android:layout_height="wrap_content" android:text="0:00"
                        android:textColor="#DDFFFFFF" android:textSize="11sp"
                        android:gravity="center" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/progress_slider"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginHorizontal="8dp"
                        android:valueFrom="0" android:valueTo="100" android:value="0"
                        app:thumbIcon="@drawable/slider_thumb"
                        app:haloColor="#309B7ED8"
                        app:trackColorActive="#9B7ED8"
                        app:trackColorInactive="#30FFFFFF"
                        app:trackHeight="3dp" />
                    <TextView android:id="@+id/time_total" android:layout_width="36dp"
                        android:layout_height="wrap_content" android:text="0:00"
                        android:textColor="#DDFFFFFF" android:textSize="11sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- 播放列表 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="right" android:layout_marginTop="2dp">
                    <ImageButton android:id="@+id/btn_playlist" android:layout_width="28dp"
                        android:layout_height="28dp" android:src="@drawable/ic_playlist"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="#D0FFFFFF" android:padding="2dp" />
                </LinearLayout>

                <!-- 控制按钮 -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center"
                    android:layout_gravity="center_horizontal" android:layout_marginTop="10dp">

                    <ImageButton android:id="@+id/btn_like" android:layout_width="44dp"
                        android:layout_height="44dp" android:src="@drawable/ic_favorite_border"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp" android:tint="#EEFFFF" />

                    <ImageButton android:id="@+id/btn_prev" android:layout_width="48dp"
                        android:layout_height="48dp" android:src="@drawable/ic_skip_previous"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp" android:tint="#EEEEEE" />

                    <ImageButton android:id="@+id/btn_play_pause"
                        android:layout_width="64dp" android:layout_height="64dp"
                        android:src="@drawable/ic_play"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginHorizontal="12dp" android:tint="#FFFFFF" />

                    <ImageButton android:id="@+id/btn_next" android:layout_width="48dp"
                        android:layout_height="48dp" android:src="@drawable/ic_skip_next"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp" android:tint="#EEEEEE" />

                    <ImageButton android:id="@+id/btn_mode_cycle" android:layout_width="44dp"
                        android:layout_height="44dp" android:src="@drawable/ic_repeat"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginStart="4dp" android:tint="#EEFFFF" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</FrameLayout>
