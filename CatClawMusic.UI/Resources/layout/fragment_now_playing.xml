<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <!-- 底层：模糊封面背景（与歌词页方案一致） -->
    <ImageView android:id="@+id/bg_cover" android:layout_width="match_parent"
        android:layout_height="match_parent" android:scaleType="centerCrop"
        android:src="@drawable/cover_default" />

    <!-- 背景遮罩层：半透明暗色蒙版，颜色由代码根据设置动态切换 -->
    <View android:id="@+id/bg_dim_overlay" android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#990F0D16" />

    <!-- 流光背景动画层 -->
    <CatClawMusic.UI.Helpers.FlowLightView android:id="@+id/flow_light"
        android:layout_width="match_parent" android:layout_height="match_parent" />

    <!-- 垂直 ViewPager2：page 0 = 正在播放，page 1 = 歌曲详情 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vertical_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical" />

</FrameLayout>
