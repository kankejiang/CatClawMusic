<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/catClawPageBackground">

    <include layout="@layout/include_settings_toolbar" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- 总体状态 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_permission_summary"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:id="@+id/tv_permission_summary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="检测中…"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="以下权限保障猫爪音乐各项功能正常运行"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 通知权限 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_notification"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔔 通知权限"
                            android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_notification_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="检测中…"
                            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 悬浮窗权限 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_overlay"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🖥️ 悬浮窗权限"
                            android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_overlay_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="检测中…"
                            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 麦克风权限 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_record_audio"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🎤 麦克风"
                            android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_record_audio_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="检测中…"
                            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 照片和视频 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_media_images"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📷 照片和视频"
                            android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_media_images_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="检测中…"
                            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 音乐和音频 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_media_audio"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🎵 音乐和音频"
                            android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_media_audio_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="检测中…"
                            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 管理外部存储 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_manage_storage"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📂 管理外部存储"
                            android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_manage_storage_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="检测中…"
                            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
