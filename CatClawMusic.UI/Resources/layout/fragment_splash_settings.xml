<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/catClawPageBackground">

    <include layout="@layout/include_settings_toolbar" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- 预览卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="启动页预览"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp" />
                    <FrameLayout
                        android:layout_width="match_parent" android:layout_height="200dp"
                        android:background="#0A0A0A">
                        <ImageView android:id="@+id/iv_splash_preview"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:scaleType="centerCrop" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:orientation="vertical" android:gravity="center_horizontal"
                            android:paddingBottom="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="猫爪音乐"
                                android:textColor="#FFFFFF" android:textSize="20sp"
                                android:fontFamily="@font/happy_zcool_2016"
                                android:shadowColor="#80000000" android:shadowDy="2" android:shadowRadius="8" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 图片来源模式 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="图片来源"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp" />
                    <RadioGroup android:id="@+id/rg_image_source"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton android:id="@+id/rb_default_image"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="默认（浅色白猫 / 深色黑猫）"
                            android:textSize="14sp" android:checked="true"
                            android:paddingVertical="8dp" />
                        <RadioButton android:id="@+id/rb_custom_api"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="自定义 API"
                            android:textSize="14sp"
                            android:paddingVertical="8dp" />
                        <RadioButton android:id="@+id/rb_custom_image"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="自定义图片"
                            android:textSize="14sp"
                            android:paddingVertical="8dp" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 自定义 API 地址 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_custom_api"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:visibility="gone"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="自定义 API 地址"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="API 需返回图片数据（重定向或直接返回图片二进制）"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginBottom="8dp" />
                    <EditText android:id="@+id/et_custom_api"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="https://example.com/random-image"
                        android:textSize="14sp"
                        android:inputType="textUri"
                        android:background="@android:color/transparent"
                        android:paddingVertical="8dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_api"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="测试并保存"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 自定义图片选择 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_custom_image"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:visibility="gone"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="自定义启动图片"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="选择一张本地图片作为启动页背景"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginBottom="12dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pick_image"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="选择图片"
                        android:textSize="13sp"
                        app:cornerRadius="12dp" />
                    <TextView android:id="@+id/tv_image_info"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 恢复默认 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="清除缓存图片"
                            android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="清除缓存的启动图片，下次启动重新下载"
                            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_cache"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="清除"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:cornerRadius="12dp"
                        app:strokeColor="?attr/catClawCardBorder" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
