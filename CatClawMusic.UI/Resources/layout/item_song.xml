<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp" android:layout_marginVertical="4dp"
    style="@style/CatClawCardSmall"
    android:clickable="true" android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:importantForAutofill="no">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="12dp">

        <FrameLayout
            android:id="@+id/cover_container"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="match_parent"
                app:cardCornerRadius="12dp" app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/catClawCardBackgroundSolid">
                <ImageView android:id="@+id/song_cover" android:layout_width="match_parent"
                    android:layout_height="match_parent" android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>
            <CatClawMusic.UI.Helpers.WaveformView android:id="@+id/playing_pause_icon"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="#99000000"
                android:visibility="gone" />
        </FrameLayout>

        <CheckBox android:id="@+id/checkbox_select" android:layout_width="28dp"
            android:layout_height="28dp" android:visibility="gone"
            android:button="@null" android:background="@drawable/ic_check_box_outline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView android:id="@+id/song_title" android:layout_width="0dp"
            android:layout_height="wrap_content" android:textSize="15sp"
            android:textColor="?attr/catClawTextPrimary" android:maxLines="1"
            android:ellipsize="end" android:fontFamily="sans-serif-medium"
            android:text="歌曲名"
            app:layout_constraintStart_toEndOf="@id/cover_container"
            app:layout_constraintEnd_toStartOf="@id/checkbox_select"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/song_artist" />

        <TextView android:id="@+id/song_artist" android:layout_width="0dp"
            android:layout_height="wrap_content" android:textSize="12sp"
            android:textColor="?attr/catClawTextSecondary" android:fontFamily="sans-serif"
            android:text="艺术家" android:maxLines="1" android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/cover_container"
            app:layout_constraintEnd_toStartOf="@id/checkbox_select"
            app:layout_constraintTop_toBottomOf="@id/song_title"
            app:layout_constraintBottom_toTopOf="@id/song_album" />

        <TextView android:id="@+id/song_album" android:layout_width="0dp"
            android:layout_height="wrap_content" android:textSize="11sp"
            android:textColor="?attr/catClawTextHint" android:fontFamily="sans-serif"
            android:text="专辑" android:maxLines="1" android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/cover_container"
            app:layout_constraintEnd_toStartOf="@id/checkbox_select"
            app:layout_constraintTop_toBottomOf="@id/song_artist"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
