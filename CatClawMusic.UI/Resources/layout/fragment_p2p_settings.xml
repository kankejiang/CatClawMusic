<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/catClawPageBackground"
    android:importantForAutofill="noExcludeDescendants">

    <include layout="@layout/include_settings_toolbar" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- P2P 开关 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardElevation="2dp"
                style="@style/Widget.Material3.CardView.Filled">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="P2P 网络"
                            android:textSize="16sp" android:textColor="?attr/catClawTextPrimary"
                            android:textStyle="bold" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/p2p_switch"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView android:id="@+id/p2p_status_text"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="?attr/catClawTextSecondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 限速设置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardElevation="2dp"
                style="@style/Widget.Material3.CardView.Filled">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="下载限速" android:textSize="14sp"
                        android:textColor="?attr/catClawTextPrimary" android:textStyle="bold" />

                    <TextView android:id="@+id/rate_limit_label"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="24sp" android:textColor="?attr/catClawAccentColor"
                        android:textStyle="bold" android:layout_marginTop="8dp" />

                    <SeekBar android:id="@+id/rate_limit_seekbar"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:max="1280" android:progress="16" android:layout_marginTop="8dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="128 KB/s"
                            android:textSize="11sp" android:textColor="?attr/catClawTextSecondary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="10240 KB/s" android:textSize="11sp"
                            android:textColor="?attr/catClawTextSecondary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bootstrap 节点 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardElevation="2dp"
                style="@style/Widget.Material3.CardView.Filled">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="网络配置" android:textSize="14sp"
                        android:textColor="?attr/catClawTextPrimary" android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Bootstrap 节点" android:layout_marginBottom="12dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/bootstrap_input"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="music.08102516.xyz:6881" android:singleLine="true" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="设备名称" android:layout_marginBottom="8dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/device_name_input"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="CatClawApp" android:singleLine="true" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 设备发现 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardElevation="2dp"
                style="@style/Widget.Material3.CardView.Filled">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="发现设备" android:textSize="14sp"
                        android:textColor="?attr/catClawTextPrimary" android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <Button android:id="@+id/discover_button"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="搜索在线设备"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_marginBottom="12dp" />

                    <TextView android:id="@+id/devices_list"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="?attr/catClawTextSecondary"
                        android:fontFamily="monospace" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
