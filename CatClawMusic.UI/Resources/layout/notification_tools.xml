<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tools_root"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="8dp"
    android:paddingRight="8dp">

    <ImageButton
        android:id="@+id/tool_favorite"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_weight="1"
        android:src="@drawable/ic_notif_favorite_border"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:padding="4dp"
        android:contentDescription="收藏" />

    <ImageButton
        android:id="@+id/tool_lyric"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_weight="1"
        android:src="@drawable/ic_notif_lyric_off"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:padding="4dp"
        android:contentDescription="桌面歌词" />

    <ImageButton
        android:id="@+id/tool_lock"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_weight="1"
        android:src="@drawable/ic_lock"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:padding="4dp"
        android:contentDescription="锁定" />

    <ImageButton
        android:id="@+id/tool_mode"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_weight="1"
        android:src="@drawable/ic_mode_single"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:padding="4dp"
        android:contentDescription="模式" />
</LinearLayout>
