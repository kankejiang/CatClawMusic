<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/catClawPageBackground">

    <!-- 顶部搜索区 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingHorizontal="16dp"
        android:paddingTop="16dp" android:paddingBottom="4dp"
        android:gravity="center_vertical">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:layout_marginEnd="8dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <EditText android:id="@+id/search_box" android:layout_width="match_parent"
                android:layout_height="match_parent" android:hint="搜索歌曲..."
                android:textColor="?attr/catClawTextPrimary" android:textColorHint="?attr/catClawTextHint"
                android:background="@null" android:paddingHorizontal="14dp"
                android:fontFamily="sans-serif" android:textSize="14sp"
                android:singleLine="true" android:imeOptions="actionSearch" />
        </com.google.android.material.card.MaterialCardView>
        <ImageButton android:id="@+id/btn_refresh" android:layout_width="36dp"
            android:layout_height="36dp" android:src="@drawable/ic_refresh"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/catClawTextHint" android:padding="6dp" />
    </LinearLayout>

    <!-- Tab 切换：毛玻璃胶囊 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp" android:layout_marginBottom="12dp"
        app:cardCornerRadius="16dp" app:cardElevation="0dp"
        app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
        app:cardBackgroundColor="?attr/catClawCardBackground">
        <LinearLayout android:id="@+id/tab_row" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:padding="4dp">
            <Button android:id="@+id/btn_local" android:layout_width="0dp"
                android:layout_height="36dp" android:layout_weight="1" android:text="@string/local_music"
                style="@style/CatClawButtonPrimary" android:layout_marginEnd="4dp" />
            <Button android:id="@+id/btn_network" android:layout_width="0dp"
                android:layout_height="36dp" android:layout_weight="1" android:text="@string/network_music"
                style="@style/CatClawButtonSecondary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 网络协议选择下拉框 -->
    <LinearLayout android:id="@+id/network_protocol_row" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:paddingHorizontal="16dp" android:paddingBottom="8dp"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="网络协议：" android:textColor="?attr/catClawTextSecondary"
            android:textSize="14sp" android:layout_gravity="center_vertical"
            android:paddingEnd="8dp" />
        <Spinner android:id="@+id/spinner_protocol" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:padding="8dp" android:minHeight="40dp" />
    </LinearLayout>

    <!-- 歌曲列表 -->
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/song_list"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:clipToPadding="false"
        android:paddingTop="4dp" android:paddingBottom="8dp" />

    <!-- 状态文本 -->
    <TextView android:id="@+id/status_text" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textSize="12sp"
        android:textColor="?attr/catClawTextHint" android:gravity="center"
        android:padding="8dp" android:text="@string/scanning" />
</LinearLayout>
