<?xml version="1.0" encoding="utf-8"?>
<!-- 文件夹浏览器页面 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/catClawPageBackground">

    <include layout="@layout/include_settings_toolbar" />

    <!-- 当前路径面包屑 -->
    <TextView android:id="@+id/tv_current_path"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
        android:paddingHorizontal="16dp" android:paddingVertical="8dp"
        android:ellipsize="middle" android:singleLine="true"
        android:fontFamily="sans-serif" />

    <!-- 文件夹列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_folders"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingBottom="80dp" />

    <!-- 底部操作栏 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="12dp"
        android:gravity="center_vertical" android:background="?attr/catClawPageBackground">

        <Button android:id="@+id/btn_select_folder"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1"
            android:text="选择此文件夹"
            style="@style/CatClawButtonPrimary"
            android:layout_marginEnd="8dp" />

        <ImageButton android:id="@+id/btn_go_up"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="返回上级"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/catClawTextSecondary"
            android:rotation="90" />
    </LinearLayout>

</LinearLayout>
