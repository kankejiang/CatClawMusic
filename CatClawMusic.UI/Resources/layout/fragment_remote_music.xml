<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/catClawPageBackground">

    <include layout="@layout/include_settings_toolbar" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="连接你的远程音乐服务"
                android:textSize="13sp" android:textColor="?attr/catClawTextHint"
                android:layout_marginBottom="12dp" />

            <!-- ✅ Navidrome 服务器 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_navidrome"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" android:gravity="center_vertical">

                    <!-- 状态指示点 -->
                    <View android:id="@+id/dot_navidrome"
                        android:layout_width="8dp" android:layout_height="8dp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Navidrome 服务器"
                            android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_navidrome_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="未连接"
                            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- 快捷开关 -->
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_navidrome"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ⚪ WebDAV 连接 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_webdav"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" android:gravity="center_vertical">

                    <!-- 状态指示点 -->
                    <View android:id="@+id/dot_webdav"
                        android:layout_width="8dp" android:layout_height="8dp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="WebDAV 连接"
                            android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_webdav_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="未连接"
                            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- 快捷开关 -->
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_webdav"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- � SMB 共享 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_smb"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" android:gravity="center_vertical">

                    <View android:id="@+id/dot_smb"
                        android:layout_width="8dp" android:layout_height="8dp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SMB 共享"
                            android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_smb_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="未连接"
                            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_smb"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
