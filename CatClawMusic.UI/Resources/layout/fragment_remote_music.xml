<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/pageBackground">

    <include layout="@layout/include_settings_toolbar" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="连接你的远程音乐服务"
                android:textSize="13sp" android:textColor="@color/textHint"
                android:layout_marginBottom="12dp" />

            <!-- ✅ Navidrome 服务器 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_navidrome"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="@color/cardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/cardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" android:gravity="center_vertical">

                    <!-- 状态指示点 -->
                    <View android:id="@+id/dot_navidrome"
                        android:layout_width="8dp" android:layout_height="8dp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Navidrome 服务器"
                            android:textSize="15sp" android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_navidrome_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="未连接"
                            android:textSize="12sp" android:textColor="@color/textHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- 快捷开关 -->
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_navidrome"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ⚪ WebDAV 连接 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_webdav"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="@color/cardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/cardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" android:gravity="center_vertical">

                    <!-- 状态指示点 -->
                    <View android:id="@+id/dot_webdav"
                        android:layout_width="8dp" android:layout_height="8dp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="WebDAV 连接"
                            android:textSize="15sp" android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tv_webdav_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="未连接"
                            android:textSize="12sp" android:textColor="@color/textHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- 快捷开关 -->
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_webdav"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🔌 更多协议（禁用占位） -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_more_protocols"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:clickable="false" android:focusable="false"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="@color/cardBorder" app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/cardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" android:gravity="center_vertical">

                    <View android:layout_width="8dp" android:layout_height="8dp"
                        android:layout_marginEnd="12dp"
                        android:alpha="0.3" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="更多协议"
                            android:textSize="15sp" android:textColor="@color/textHint"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SMB / FTP / DLNA 即将支持"
                            android:textSize="12sp" android:textColor="@color/textHint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="敬请期待" android:textSize="12sp" android:textColor="@color/textHint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
