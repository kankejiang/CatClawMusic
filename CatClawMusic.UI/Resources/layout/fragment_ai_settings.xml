<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="?attr/catClawPageBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <ImageButton android:id="@+id/btn_back"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:tint="?attr/catClawTextPrimary"
                android:contentDescription="返回" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AI 助手设置" android:textSize="20sp"
                android:textColor="?attr/catClawTextPrimary"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />
            <View android:layout_width="40dp" android:layout_height="0dp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="启用 AI 助手"
                    android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="开启后可在探索页面使用 AI 对话功能"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint" />
                    <Switch android:id="@+id/switch_ai_enabled"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="已保存配置"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_config_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint" />
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_config_entries"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
                <TextView android:id="@+id/tv_no_configs"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="暂无已保存的配置，填写下方信息后点击保存"
                    android:textSize="13sp" android:textColor="?attr/catClawTextHint"
                    android:gravity="center" android:paddingVertical="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="配置名称"
                    android:textSize="13sp" android:textColor="?attr/catClawTextHint"
                    android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/et_config_name"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:hint="如：我的 DeepSeek"
                    android:textColor="?attr/catClawTextPrimary" android:textColorHint="?attr/catClawTextHint"
                    android:background="@null" android:paddingHorizontal="12dp"
                    android:textSize="14sp" android:inputType="text"
                    android:importantForAutofill="no"
                    android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="模型服务商"
                    android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />
                <Spinner android:id="@+id/spinner_provider"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:minHeight="48dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="API 地址"
                    android:textSize="13sp" android:textColor="?attr/catClawTextHint"
                    android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/et_api_url"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:hint="https://api.deepseek.com/v1"
                    android:textColor="?attr/catClawTextPrimary" android:textColorHint="?attr/catClawTextHint"
                    android:background="@null" android:paddingHorizontal="12dp"
                    android:textSize="14sp" android:inputType="textUri"
                    android:importantForAutofill="no"
                    android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="API Key"
                    android:textSize="13sp" android:textColor="?attr/catClawTextHint"
                    android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/et_api_key"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:hint="输入你的 API Key"
                    android:textColor="?attr/catClawTextPrimary" android:textColorHint="?attr/catClawTextHint"
                    android:background="@null" android:paddingHorizontal="12dp"
                    android:textSize="14sp" android:inputType="textPassword"
                    android:importantForAutofill="no"
                    android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="模型名称"
                        android:textSize="13sp" android:textColor="?attr/catClawTextHint" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_fetch_models"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="获取可用模型"
                        android:textSize="11sp"
                        app:cornerRadius="8dp"
                        app:backgroundTint="?attr/catClawCardBackground"
                        android:textColor="?attr/catClawPrimaryColor"
                        app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
                        android:minWidth="0dp" android:paddingHorizontal="12dp" />
                </LinearLayout>
                <Spinner android:id="@+id/spinner_model"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:paddingHorizontal="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:minHeight="44dp"
                    android:visibility="gone" />
                <EditText android:id="@+id/et_model"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:hint="deepseek-chat"
                    android:textColor="?attr/catClawTextPrimary" android:textColorHint="?attr/catClawTextHint"
                    android:background="@null" android:paddingHorizontal="12dp"
                    android:textSize="14sp" android:inputType="text"
                    android:importantForAutofill="no" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="高级参数"
                    android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Temperature（创造性）"
                    android:textSize="13sp" android:textColor="?attr/catClawTextHint"
                    android:layout_marginBottom="4dp" />
                <SeekBar android:id="@+id/seekbar_temperature"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="70"
                    android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/tv_temperature_value"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0.7"
                    android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                    android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="最大 Token 数"
                    android:textSize="13sp" android:textColor="?attr/catClawTextHint"
                    android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/et_max_tokens"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:hint="2048"
                    android:textColor="?attr/catClawTextPrimary" android:textColorHint="?attr/catClawTextHint"
                    android:background="@null" android:paddingHorizontal="12dp"
                    android:textSize="14sp" android:inputType="number"
                    android:importantForAutofill="no" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginBottom="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test_connection"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:layout_marginEnd="8dp"
                android:text="测试连接"
                app:cornerRadius="12dp"
                app:backgroundTint="?attr/catClawCardBackground"
                android:textColor="?attr/catClawTextPrimary"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_config"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1"
                android:text="保存配置"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <TextView android:id="@+id/tv_status"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center" android:padding="8dp"
            android:textColor="?attr/catClawTextHint" android:textSize="12sp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
