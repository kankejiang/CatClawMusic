<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/catClawPageBackground"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="12dp" android:paddingVertical="8dp">
        <ImageButton android:id="@+id/btn_back"
            android:layout_width="36dp" android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="?attr/catClawTextPrimary"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:contentDescription="返回" />
        <TextView android:id="@+id/tv_title"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="艺术家"
            android:textSize="18sp"
            android:textColor="?attr/catClawTextPrimary"
            android:fontFamily="@font/happy_zcool_2016"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="?attr/catClawCardBorder" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:fillViewport="true">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Artist header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="96dp" android:layout_height="96dp"
                    app:cardCornerRadius="48dp" app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/catClawCardBackgroundSolid">
                    <ImageView android:id="@+id/iv_artist_photo"
                        android:layout_width="match_parent" android:layout_height="match_parent"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="20dp">
                    <TextView android:id="@+id/tv_artist_name"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="22sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="@font/happy_zcool_2016"
                        android:maxLines="2" android:ellipsize="end" />
                    <TextView android:id="@+id/tv_artist_alias"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="?attr/catClawTextSecondary"
                        android:layout_marginTop="2dp"
                        android:maxLines="1" android:ellipsize="end"
                        android:visibility="gone" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="2dp">
                        <TextView android:id="@+id/tv_artist_gender"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="13sp" android:textColor="?attr/catClawTextSecondary"
                            android:visibility="gone" />
                        <TextView android:id="@+id/tv_artist_birthday"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="13sp" android:textColor="?attr/catClawTextSecondary"
                            android:visibility="gone" />
                        <TextView android:id="@+id/tv_artist_country"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="13sp" android:textColor="?attr/catClawTextSecondary"
                            android:visibility="gone" />
                    </LinearLayout>
                    <TextView android:id="@+id/tv_song_count"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="?attr/catClawTextSecondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Artist description -->
            <TextView android:id="@+id/tv_artist_desc"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp" android:layout_marginBottom="12dp"
                android:textSize="13sp" android:textColor="?attr/catClawTextSecondary"
                android:maxLines="3" android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:visibility="gone" />

            <!-- Play all button -->
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_play_all"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:layout_marginStart="20dp" android:layout_marginBottom="12dp"
                android:text="全部播放"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:backgroundTint="?attr/catClawPrimaryColor"
                android:textColor="?attr/catClawTextOnPrimary"
                app:icon="@drawable/ic_play"
                app:iconGravity="textStart"
                app:iconSize="16dp"
                app:iconTint="?attr/catClawTextOnPrimary" />

            <!-- Song list -->
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_songs"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp"
                android:paddingBottom="16dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
