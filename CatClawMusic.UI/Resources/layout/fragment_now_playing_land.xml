<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:clipChildren="false">

    <!-- 底层：模糊封面背景（与歌词页方案一致） -->
    <ImageView android:id="@+id/bg_cover" android:layout_width="match_parent"
        android:layout_height="match_parent" android:scaleType="centerCrop"
        android:src="@drawable/cover_default" />

    <!-- 背景遮罩层：半透明暗色蒙版 -->
    <View android:id="@+id/bg_dim_overlay" android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#990F0D16" />

    <!-- 流光背景动画层 -->
    <CatClawMusic.UI.Helpers.FlowLightView android:id="@+id/flow_light"
        android:layout_width="match_parent" android:layout_height="match_parent" />

    <LinearLayout android:id="@+id/content_area" android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="horizontal" android:clipChildren="false"
        android:paddingHorizontal="24dp" android:paddingVertical="16dp">

        <CatClawMusic.UI.Helpers.SquareFrameLayout android:id="@+id/cover_panel" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="16dp"
            android:layout_gravity="center_vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cover_card"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <FrameLayout android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView android:id="@+id/album_cover" android:layout_width="match_parent"
                        android:layout_height="match_parent" android:scaleType="centerCrop" />

                    <View android:id="@+id/cover_glow" android:layout_width="match_parent"
                        android:layout_height="120dp" android:layout_gravity="bottom" />

                    <View android:id="@+id/cover_fog" android:layout_width="match_parent"
                        android:layout_height="90dp" android:layout_gravity="bottom" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_gravity="bottom" android:orientation="vertical"
                        android:layout_marginHorizontal="20dp" android:layout_marginBottom="10dp">
                        <TextView android:id="@+id/song_title" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textSize="16sp"
                            android:textColor="#FFFFFF" android:fontFamily="sans-serif-medium"
                            android:gravity="start" android:maxLines="1" android:ellipsize="end"
                            android:layout_marginBottom="2dp"
                            android:shadowColor="#80000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
                        <TextView android:id="@+id/song_artist" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="#CCFFFFFF"
                            android:textSize="12sp" android:gravity="start"
                            android:shadowColor="#80000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="2" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </CatClawMusic.UI.Helpers.SquareFrameLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical" android:clipChildren="false">

            <LinearLayout android:id="@+id/lyrics_area" android:layout_width="match_parent"
                android:layout_height="0dp" android:layout_weight="1"
                android:orientation="vertical" android:gravity="bottom|center_horizontal"
                android:clipChildren="false" android:paddingHorizontal="16dp"
                android:paddingBottom="0dp">

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev8" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="1dp"
                    android:textColor="#66000000" android:textSize="7sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev7" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="1dp"
                    android:textColor="#7F000000" android:textSize="7sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev6" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="1dp"
                    android:textColor="#99000000" android:textSize="8sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev5" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="1dp"
                    android:textColor="#99000000" android:textSize="9sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev4" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="1dp"
                    android:textColor="#CC000000" android:textSize="9sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev3" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="1dp"
                    android:textColor="#CC000000" android:textSize="10sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev2" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="2dp"
                    android:textColor="#CC000000" android:textSize="10sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_prev" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="3dp"
                    android:textColor="#CC000000" android:textSize="12sp"
                    android:gravity="center" android:maxLines="3" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_current" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginVertical="3dp"
                    android:textColor="#FFFFFFFF" android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center" android:maxLines="4" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:text=" 猫爪音乐" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="3dp"
                    android:textColor="#CC000000" android:textSize="12sp"
                    android:gravity="center" android:maxLines="3" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next2" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="2dp"
                    android:textColor="#CC000000" android:textSize="10sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next3" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="1dp"
                    android:textColor="#CC000000" android:textSize="10sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next4" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="1dp"
                    android:textColor="#CC000000" android:textSize="9sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next5" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="1dp"
                    android:textColor="#99000000" android:textSize="9sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next6" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="1dp"
                    android:textColor="#99000000" android:textSize="8sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next7" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="1dp"
                    android:textColor="#7F000000" android:textSize="7sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />

                <CatClawMusic.UI.Helpers.StrokeTextView android:id="@+id/lyric_next8" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="1dp"
                    android:textColor="#66000000" android:textSize="7sp"
                    android:gravity="center" android:maxLines="2" android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />
            </LinearLayout>

            <CatClawMusic.UI.Helpers.AudioVisualizerView android:id="@+id/audio_visualizer"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:layout_marginHorizontal="16dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/controls_card"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginHorizontal="0dp" android:layout_marginTop="0dp" android:layout_marginBottom="0dp"
                app:cardCornerRadius="24dp" app:cardElevation="0dp"
                app:strokeColor="#15CCCCCC" app:strokeWidth="1dp"
                app:cardBackgroundColor="#26000000">

                <LinearLayout android:id="@+id/controls_area"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:paddingHorizontal="18dp"
                    android:paddingTop="10dp" android:paddingBottom="10dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/time_current" android:layout_width="36dp"
                            android:layout_height="wrap_content" android:text="0:00"
                            android:textColor="#DDFFFFFF" android:textSize="11sp"
                            android:gravity="center" />
                        <com.google.android.material.slider.Slider
                            android:id="@+id/progress_slider"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginHorizontal="8dp"
                            android:valueFrom="0" android:valueTo="100" android:value="0"
                            app:thumbRadius="8dp"
                            app:thumbColor="#FFFFFF"
                            app:haloColor="@android:color/transparent"
                            app:trackColorActive="#FFFFFF"
                            app:trackColorInactive="#50FFFFFF"
                            app:trackHeight="2dp" />
                        <TextView android:id="@+id/time_total" android:layout_width="36dp"
                            android:layout_height="wrap_content" android:text="0:00"
                            android:textColor="#DDFFFFFF" android:textSize="11sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginTop="2dp">
                        <ImageButton android:id="@+id/btn_landscape" android:layout_width="28dp"
                            android:layout_height="28dp" android:src="@drawable/ic_landscape"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="2dp" />
                        <ImageButton android:id="@+id/btn_visualizer_toggle" android:layout_width="28dp"
                            android:layout_height="28dp" android:src="@drawable/ic_equalizer"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="2dp" android:layout_marginStart="4dp" />
                        <ImageButton android:id="@+id/btn_eq" android:layout_width="28dp"
                            android:layout_height="28dp" android:src="@drawable/ic_eq"
                            android:contentDescription="音效"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="2dp" android:layout_marginStart="4dp" />
                        <ImageButton android:id="@+id/btn_sleep_timer" android:layout_width="28dp"
                            android:layout_height="28dp" android:src="@drawable/ic_sleep"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="2dp" android:layout_marginStart="4dp" />
                        <TextView android:id="@+id/sleep_timer_text" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="#DDFFFFFF"
                            android:textSize="10sp" android:visibility="gone"
                            android:layout_marginStart="2dp" />
                        <View android:layout_width="0dp" android:layout_height="0dp"
                            android:layout_weight="1" />
                        <ImageButton android:id="@+id/btn_playlist" android:layout_width="28dp"
                            android:layout_height="28dp" android:src="@drawable/ic_playlist"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:tint="#DDFFFFFF" android:padding="2dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center"
                        android:layout_gravity="center_horizontal" android:layout_marginTop="6dp">

                        <ImageButton android:id="@+id/btn_like" android:layout_width="40dp"
                            android:layout_height="40dp" android:src="@drawable/ic_favorite_border"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:layout_marginEnd="4dp" android:tint="#FFFFFF" />

                        <ImageButton android:id="@+id/btn_prev" android:layout_width="44dp"
                            android:layout_height="44dp" android:src="@drawable/ic_skip_previous"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:layout_marginEnd="4dp" android:tint="#FFFFFF" />

                        <ImageButton android:id="@+id/btn_play_pause"
                            android:layout_width="56dp" android:layout_height="56dp"
                            android:src="@drawable/ic_play"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:layout_marginHorizontal="10dp" android:tint="#FFFFFF" />

                        <ImageButton android:id="@+id/btn_next" android:layout_width="44dp"
                            android:layout_height="44dp" android:src="@drawable/ic_skip_next"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:layout_marginEnd="4dp" android:tint="#FFFFFF" />

                        <ImageButton android:id="@+id/btn_mode_cycle" android:layout_width="40dp"
                            android:layout_height="40dp" android:src="@drawable/ic_repeat"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:layout_marginStart="4dp" android:tint="#FFFFFF" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
