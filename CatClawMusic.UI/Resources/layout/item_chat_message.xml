<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:paddingVertical="4dp">

    <LinearLayout android:id="@+id/layout_user"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="end"
        android:visibility="gone">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            app:cardCornerRadius="18dp" app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/catClawPrimaryColor">
            <TextView android:id="@+id/tv_user_message"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="14dp" android:paddingVertical="10dp"
                android:textColor="#FFFFFF" android:textSize="14sp"
                android:maxWidth="280dp" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout android:id="@+id/layout_assistant"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="start"
        android:visibility="gone">
        <ImageView android:id="@+id/iv_agent_avatar"
            android:layout_width="32dp" android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginEnd="48dp"
            app:cardCornerRadius="18dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="0.5dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:paddingHorizontal="14dp" android:paddingVertical="10dp">
                <TextView android:id="@+id/tv_assistant_message"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/catClawTextPrimary" android:textSize="14sp"
                    android:maxWidth="280dp" />
                <LinearLayout android:id="@+id/layout_tool_calls"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout android:id="@+id/layout_tool"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="start"
        android:visibility="gone">
        <ImageView android:id="@+id/iv_agent_avatar_tool"
            android:layout_width="32dp" android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginEnd="48dp"
            app:cardCornerRadius="12dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawPageBackground">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingHorizontal="12dp" android:paddingVertical="8dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔧" android:textSize="12sp"
                    android:layout_marginEnd="6dp" />
                <TextView android:id="@+id/tv_tool_info"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/catClawTextHint" android:textSize="12sp"
                    android:maxWidth="260dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout android:id="@+id/layout_search_results"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="start"
        android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="start">
            <ImageView android:id="@+id/iv_agent_avatar_search"
                android:layout_width="32dp" android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="0.5dp"
                app:cardBackgroundColor="?attr/catClawCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:id="@+id/tv_search_summary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="?attr/catClawTextHint" android:textSize="12sp"
                        android:layout_marginBottom="8dp" />
                    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_song_cards"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/layout_wizard"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="start"
        android:visibility="gone">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="0.5dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:id="@+id/tv_wizard_title"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/catClawTextPrimary" android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <RadioGroup android:id="@+id/rg_providers"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:visibility="gone" />

                <LinearLayout android:id="@+id/layout_apikey_input"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <EditText android:id="@+id/et_wizard_apikey"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:hint="输入 API Key"
                        android:textColor="?attr/catClawTextPrimary" android:textColorHint="?attr/catClawTextHint"
                        android:background="?attr/catClawPageBackground"
                        android:paddingHorizontal="12dp"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:importantForAutofill="no" />
                </LinearLayout>

                <LinearLayout android:id="@+id/layout_model_select"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <Spinner android:id="@+id/spinner_wizard_models"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:paddingHorizontal="12dp"
                        android:background="?attr/catClawPageBackground" />
                    <TextView android:id="@+id/tv_wizard_model_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="11sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="4dp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="end"
                    android:layout_marginTop="12dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_wizard_cancel"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="取消"
                        android:textSize="13sp"
                        app:cornerRadius="8dp"
                        android:paddingHorizontal="20dp"
                        app:backgroundTint="?attr/catClawCardBorder"
                        app:strokeColor="?attr/catClawCardBorder"
                        app:strokeWidth="1dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_wizard_next"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="下一步"
                        android:textSize="13sp"
                        app:cornerRadius="8dp"
                        android:paddingHorizontal="20dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</LinearLayout>
