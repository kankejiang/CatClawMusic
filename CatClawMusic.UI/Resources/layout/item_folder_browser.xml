<?xml version="1.0" encoding="utf-8"?>
<!-- 文件夹浏览器列表项 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="12dp" android:paddingVertical="10dp"
    android:background="?attr/selectableItemBackground">

    <ImageView android:id="@+id/iv_icon"
        android:layout_width="36dp" android:layout_height="36dp"
        android:src="@drawable/ic_folder"
        android:contentDescription="文件夹"
        android:tint="?attr/catClawPrimaryColor" />

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView android:id="@+id/tv_folder_name"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="?attr/catClawTextPrimary"
            android:fontFamily="sans-serif-medium" android:maxLines="1"
            android:ellipsize="end" />

        <TextView android:id="@+id/tv_folder_path"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="?attr/catClawTextHint"
            android:fontFamily="sans-serif" android:maxLines="1"
            android:ellipsize="start" android:layout_marginTop="1dp" />

    </LinearLayout>

</LinearLayout>
