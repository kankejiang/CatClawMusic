<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/pageBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <com.google.android.material.card.MaterialCardView style="@style/CatClawCard"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="WebDAV 设置" style="@style/CatClawTitle" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="配置 WebDAV 服务器连接" android:textColor="@color/textSecondary"
                    android:textSize="@dimen/font_small" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/CatClawCard"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Navidrome 设置" style="@style/CatClawTitle" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="配置 Navidrome 音乐服务器" android:textColor="@color/textSecondary"
                    android:textSize="@dimen/font_small" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
