<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/pageBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="设置" android:textSize="22sp"
            android:fontFamily="@font/happy_zcool_2016"
            android:textColor="@color/textPrimary" android:layout_marginBottom="16dp" />

        <!-- 📁 本地音乐 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_music_folders"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="@color/cardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/cardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📁 本地音乐"
                        android:textSize="15sp" android:textColor="@color/textPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_local_music_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="加载中…"
                        android:textSize="12sp" android:textColor="@color/textHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="@color/textHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ☁️ 远程音乐服务 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_remote_music"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="@color/cardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/cardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☁️ 远程音乐服务"
                        android:textSize="15sp" android:textColor="@color/textPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_remote_music_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="加载中…"
                        android:textSize="12sp" android:textColor="@color/textHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="@color/textHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🔋 省电策略 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_battery_optimization"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="@color/cardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/cardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔋 省电策略设置"
                        android:textSize="15sp" android:textColor="@color/textPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_battery_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="检测中…"
                        android:textSize="12sp" android:textColor="@color/textHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="@color/textHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🔔 通知权限 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_notification_permission"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="@color/cardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/cardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔔 通知权限设置"
                        android:textSize="15sp" android:textColor="@color/textPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_notification_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="检测中…"
                        android:textSize="12sp" android:textColor="@color/textHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="@color/textHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
