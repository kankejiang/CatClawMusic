<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="?attr/catClawPageBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- 标题栏 + 深浅色切换 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="设置" android:textSize="22sp"
                android:fontFamily="@font/happy_zcool_2016"
                android:textColor="?attr/catClawTextPrimary" />
            <ImageButton android:id="@+id/btn_dark_mode_toggle"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_system_mode"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:contentDescription="深浅色模式切换" />
        </LinearLayout>

        <!-- 🎨 主题选择 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🎨 主题选择"
                    android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />
                <Spinner android:id="@+id/spinner_theme"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:minHeight="48dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 📁 本地音乐 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_music_folders"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📁 本地音乐"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_local_music_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="加载中…"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ☁️ 远程音乐服务 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_remote_music"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☁️ 远程音乐服务"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_remote_music_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="加载中…"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🧩 插件管理 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_plugin_management"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🧩 插件管理"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_plugin_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="加载中…"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🤖 AI 助手 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_ai_settings"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔍 探索设置"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_ai_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="加载中…"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 通用设置分组卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_general_settings"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <!-- 分组标题 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="通用设置"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_arrow_general"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 💾 备份与恢复 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_backup_restore"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💾 备份与恢复"
                    android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />
                <TextView android:id="@+id/tv_backup_status"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="备份歌单、播放记录、艺术家元数据、AI配置"
                    android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                    android:layout_marginBottom="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_backup"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="备份"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp"
                        app:cornerRadius="12dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_restore"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="恢复"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:cornerRadius="12dp"
                        app:strokeColor="?attr/catClawCardBorder" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 关于 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_about"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="关于"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="版本信息、开源协议、交流群"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
