<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/pageBackground"
    android:paddingHorizontal="16dp" android:paddingTop="16dp">

    <TextView android:id="@+id/title_text" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="20sp"
        android:textColor="@color/textPrimary" android:fontFamily="@font/happy_zcool_2016"
        android:text="@string/playlist_detail" android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/song_list"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:clipToPadding="false" android:paddingBottom="8dp" />

    <TextView android:id="@+id/status_text" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textColor="@color/textHint"
        android:gravity="center" android:padding="8dp" android:textSize="12sp" />
</LinearLayout>
