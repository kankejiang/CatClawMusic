<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/catClawPageBackground"
    android:paddingHorizontal="16dp" android:paddingTop="48dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageButton android:id="@+id/btn_back" android:layout_width="40dp"
            android:layout_height="40dp" android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/catClawTextPrimary"
            android:contentDescription="返回"
            android:layout_marginEnd="8dp" />

        <TextView android:id="@+id/title_text" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textSize="20sp" android:textColor="?attr/catClawTextPrimary"
            android:fontFamily="@font/happy_zcool_2016"
            android:text="@string/playlist_detail" android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageButton android:id="@+id/btn_shuffle" android:layout_width="36dp"
            android:layout_height="36dp" android:src="@drawable/ic_shuffle"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/catClawTextHint"
            android:contentDescription="随机播放"
            android:layout_marginEnd="8dp" />

        <View android:layout_width="0dp" android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton android:id="@+id/btn_sort" android:layout_width="36dp"
            android:layout_height="36dp" android:src="@drawable/ic_sort"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/catClawTextHint"
            android:contentDescription="排序"
            android:layout_marginEnd="8dp" />

        <ImageButton android:id="@+id/btn_multi_select" android:layout_width="36dp"
            android:layout_height="36dp" android:src="@drawable/ic_check_box_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/catClawTextHint"
            android:contentDescription="多选" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/song_list"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:clipToPadding="false" android:paddingBottom="8dp" />

    <TextView android:id="@+id/status_text" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textColor="?attr/catClawTextHint"
        android:gravity="center" android:padding="8dp" android:textSize="12sp" />
</LinearLayout>
