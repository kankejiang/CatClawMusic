<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="?attr/catClawPageBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- 标题栏 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <ImageButton android:id="@+id/btn_back"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:tint="?attr/catClawTextPrimary"
                android:contentDescription="返回" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="通用设置" android:textSize="20sp"
                android:textColor="?attr/catClawTextPrimary"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />
            <View android:layout_width="40dp" android:layout_height="0dp" />
        </LinearLayout>

        <!-- 🎨 播放页面背景动画 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_bg_animation"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎨 流光背景动画"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="开启后背景将显示缓慢漂移的流光效果"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <android.widget.Switch android:id="@+id/switch_bg_animation"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🔋 省电策略 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_battery_optimization"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔋 省电策略设置"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:id="@+id/tv_battery_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="检测中…"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🎵 桌面与歌词 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_desktop_lyric"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎵 桌面与歌词"
                        android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="桌面歌词、歌词显示设置"
                        android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="?attr/catClawTextHint" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 💾 缓存管理 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
            app:cardBackgroundColor="?attr/catClawCardBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💾 缓存管理"
                    android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                    android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="网络音乐缓存大小上限，超出后自动清理旧数据"
                    android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                    android:layout_marginTop="2dp" />
                <TextView android:id="@+id/tv_cache_size"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="当前缓存：计算中…"
                    android:textSize="13sp" android:textColor="?attr/catClawTextSecondary"
                    android:layout_marginTop="8dp" />
                <SeekBar android:id="@+id/seekbar_cache_size"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="14" android:progress="0"
                    android:layout_marginTop="8dp" />
                <TextView android:id="@+id/tv_cache_value"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="上限：1 GB"
                    android:textSize="13sp" android:textColor="?attr/catClawTextSecondary"
                    android:gravity="center" android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
