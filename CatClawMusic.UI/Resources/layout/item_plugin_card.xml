<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp" app:cardElevation="0dp"
    app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
    app:cardBackgroundColor="?attr/catClawCardBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp"
        android:gravity="center_vertical">

        <!-- 插件图标 emoji -->
        <TextView android:id="@+id/tv_plugin_icon"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="24sp"
            android:text="🧩" />

        <!-- 插件信息 -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView android:id="@+id/tv_plugin_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="15sp" android:textColor="?attr/catClawTextPrimary"
                android:fontFamily="sans-serif-medium" />
            <TextView android:id="@+id/tv_plugin_desc"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                android:layout_marginTop="2dp"
                android:maxLines="2" android:ellipsize="end" />
        </LinearLayout>

        <!-- 版本号 -->
        <TextView android:id="@+id/tv_plugin_version"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
            android:layout_marginEnd="8dp" />

        <!-- 启用开关 -->
        <Switch android:id="@+id/switch_plugin_enabled"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
