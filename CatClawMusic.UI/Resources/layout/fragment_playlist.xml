<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/catClawPageBackground">

    <TextView android:id="@+id/title_text" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="歌单"
        android:textSize="32sp" android:fontFamily="sans-serif"
        android:textStyle="bold"
        android:textColor="?attr/catClawTextPrimary"
        android:paddingHorizontal="20dp" android:paddingTop="8dp"
        android:paddingBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/playlist_list"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <TextView android:id="@+id/status_text" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:gravity="center"
        android:textColor="?attr/catClawTextHint" android:textSize="12sp"
        android:padding="8dp" android:visibility="gone" />
</LinearLayout>
