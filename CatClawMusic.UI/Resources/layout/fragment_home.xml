<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/pageBackground"
    android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🐾 猫爪音乐" android:textSize="24sp"
        android:fontFamily="@font/happy_zcool_2016"
        android:textColor="@color/textPrimary" android:layout_marginBottom="16dp" />

    <!-- 状态卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="16dp" app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder" app:strokeWidth="1dp"
        app:cardBackgroundColor="@color/cardBackground">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="16dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🎵 本地音乐"
                android:textSize="14sp" android:textColor="@color/textPrimary" />
            <TextView android:id="@+id/home_song_count" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0 首"
                android:textSize="20sp" android:textColor="@color/primaryColor"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 快捷操作 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btn_goto_library"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" android:clickable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardCornerRadius="16dp" app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder" app:strokeWidth="1dp"
        app:cardBackgroundColor="@color/cardBackground">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="16dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="📀 浏览音乐库"
                android:textSize="14sp" android:textColor="@color/textPrimary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textSize="20sp" android:textColor="@color/textHint" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
