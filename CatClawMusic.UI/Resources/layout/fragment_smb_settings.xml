<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/catClawPageBackground"
    android:importantForAutofill="noExcludeDescendants">

    <include layout="@layout/include_settings_toolbar" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 服务名称 -->
            <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="服务名称"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_name"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="我的 SMB" android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 用户名 -->
            <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="用户名"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_username"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:singleLine="true" android:inputType="textNoSuggestions" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 密码 -->
            <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="密码"
                android:layout_marginBottom="12dp" app:passwordToggleEnabled="true"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_password"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:singleLine="true" android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 主机地址 -->
            <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="主机地址"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_host"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="192.168.1.1" android:singleLine="true"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 端口 -->
            <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="端口"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_port"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="number" android:text="445" android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 浏览按钮 — 突出显示 -->
            <Button android:id="@+id/btn_browse" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="📂 浏览选择共享"
                android:textSize="16sp" android:layout_marginBottom="12dp"
                style="@style/CatClawButtonPrimary" />

            <!-- 已选共享 & 路径摘要 -->
            <LinearLayout android:id="@+id/layout_selected" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:layout_marginBottom="16dp" android:visibility="gone"
                android:background="?attr/catClawCardBackground" android:padding="12dp"
                android:minHeight="48dp">

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="✅ 已选择:"
                        android:textColor="?attr/catClawAccentColor" android:textSize="13sp"
                        android:layout_marginEnd="8dp" />
                    <TextView android:id="@+id/tv_selected_path"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="?attr/catClawTextPrimary"
                        android:textSize="14sp" android:maxLines="2"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <!-- 高级设置 — 折叠面板 -->
            <LinearLayout android:id="@+id/layout_advanced_header"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="4dp" android:paddingEnd="12dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">

                <TextView android:id="@+id/tv_advanced_arrow"
                    android:layout_width="24dp" android:layout_height="24dp"
                    android:text="▶" android:gravity="center"
                    android:textColor="?attr/catClawTextHint" android:textSize="14sp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="高级设置"
                    android:textColor="?attr/catClawTextHint" android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/layout_advanced_content"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone"
                android:paddingStart="28dp">

                <!-- 域名 -->
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="域名（可选）"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_domain_name"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 共享名（浏览后自动填写，也可手动输入） -->
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="共享名（浏览后自动填写）"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_share_name"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 路径（浏览后自动填写） -->
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="路径（浏览后自动填写）"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_base_path"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="\" android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- 状态信息 -->
            <TextView android:id="@+id/status_text" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="?attr/catClawTextHint"
                android:textSize="13sp" android:padding="8dp" android:gravity="center"
                android:visibility="gone" />

            <!-- 操作按钮 -->
            <Button android:id="@+id/btn_save" android:layout_width="match_parent"
                android:layout_height="48dp" android:text="保存连接"
                style="@style/CatClawButtonSecondary" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
