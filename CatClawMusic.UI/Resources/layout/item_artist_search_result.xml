<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true" android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="12dp" app:cardElevation="0dp"
    app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
    app:cardBackgroundColor="?attr/catClawCardBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="12dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp" android:layout_height="48dp"
            app:cardCornerRadius="24dp" app:cardElevation="0dp">
            <ImageView android:id="@+id/iv_cover"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_person" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView android:id="@+id/tv_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="14sp" android:textColor="?attr/catClawTextPrimary"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/tv_alias"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="?attr/catClawTextHint"
                android:maxLines="1" android:ellipsize="end"
                android:layout_marginTop="1dp" />
            <TextView android:id="@+id/tv_info"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="?attr/catClawTextHint"
                android:maxLines="1" android:ellipsize="end"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <TextView android:id="@+id/tv_source"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="网易云"
            android:textSize="10sp" android:textColor="?attr/catClawAccentColor"
            android:background="?attr/catClawCardBorder"
            android:paddingStart="6dp" android:paddingEnd="6dp"
            android:paddingTop="2dp" android:paddingBottom="2dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
