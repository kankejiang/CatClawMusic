<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp" app:cardElevation="0dp"
    app:strokeColor="?attr/catClawCardBorder" app:strokeWidth="1dp"
    app:cardBackgroundColor="?attr/catClawCardBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- 第一行：拖拽手柄 + 名称 + 启用状态 + 菜单 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView android:id="@+id/iv_drag_handle"
                android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/drag_indicator_line"
                android:tint="?attr/catClawTextHint"
                android:scaleType="centerInside"
                android:layout_marginEnd="4dp"
                android:contentDescription="拖拽排序" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tv_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="16sp" android:textColor="?attr/catClawTextPrimary"
                    android:fontFamily="sans-serif-medium" />
                <TextView android:id="@+id/tv_provider_model"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="12sp" android:textColor="?attr/catClawTextHint" />
            </LinearLayout>
            <Switch android:id="@+id/switch_enabled"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="8dp" />
            <ImageButton android:id="@+id/btn_menu"
                android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_menu"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/catClawTextHint"
                android:scaleType="centerInside" android:padding="6dp"
                android:contentDescription="菜单" />
        </LinearLayout>

        <!-- 第二行：API URL 预览 -->
        <TextView android:id="@+id/tv_api_url"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp" android:textColor="?attr/catClawTextHint"
            android:ellipsize="end" android:maxLines="1" />

        <!-- 第三行：退回对话模型 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <CheckBox android:id="@+id/cb_fallback"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="退回对话模型"
                android:textSize="12sp"
                android:textColor="?attr/catClawTextSecondary" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="当前模型失败时按顺序尝试下一个"
                android:textSize="10sp"
                android:textColor="?attr/catClawTextHint"
                android:layout_marginStart="4dp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
