<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
    <TextView android:id="@+id/upcoming_title" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:textSize="@dimen/font_medium" android:textColor="@color/textPrimary"
        android:maxLines="1" android:ellipsize="end" android:text="歌曲" />
    <TextView android:id="@+id/upcoming_artist" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="@dimen/font_small"
        android:textColor="@color/textHint" android:text="艺术家" />
</LinearLayout>
