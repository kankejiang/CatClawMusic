<resources>
    <!-- 猫爪主题（Material 3） -->
    <style name="CatClawTheme" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">@color/primaryGlow</item>
        <item name="colorOnPrimaryContainer">@color/primaryDark</item>
        <item name="android:windowBackground">@color/pageBackground</item>
        <item name="android:statusBarColor">@color/primaryDark</item>
        <item name="android:navigationBarColor">@color/pageBackground</item>
        <item name="bottomNavigationStyle">@style/CatClawBottomNav</item>
    </style>

    <!-- 启动画面主题 -->
    <style name="CatClaw.Splash" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <!-- 底部导航 -->
    <style name="CatClawBottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/PinkActiveIndicator</item>
        <item name="itemIconTint">@color/tabActive</item>
        <item name="itemTextColor">@color/tabActive</item>
    </style>

    <style name="PinkActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primaryGlow</item>
    </style>

    <!-- 粉色卡片 -->
    <style name="CatClawCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/cardBorder</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/cardBackground</item>
    </style>

    <!-- 主按钮 -->
    <style name="CatClawButtonPrimary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primaryColor</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- 次按钮 -->
    <style name="CatClawButtonSecondary" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/primaryGlow</item>
        <item name="android:textColor">@color/primaryDark</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- 标题文字 -->
    <style name="CatClawHeading" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/happy_zcool_2016</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>

    <!-- 正文 -->
    <style name="CatClawBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textColor">@color/textSecondary</item>
    </style>

    <!-- 大标题 -->
    <style name="CatClawTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/happy_zcool_2016</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>
</resources>
