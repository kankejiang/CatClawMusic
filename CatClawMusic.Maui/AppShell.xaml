<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:CatClawMusic.Maui.Pages"
       x:Class="CatClawMusic.Maui.AppShell"
       FlyoutBehavior="Disabled"
       Shell.TabBarBackgroundColor="{DynamicResource TabBarBackgroundColor}"
       Shell.TabBarForegroundColor="{DynamicResource TabActiveColor}"
       Shell.TabBarUnselectedColor="{DynamicResource TabInactiveColor}"
       Shell.TabBarTitleColor="{DynamicResource TabActiveColor}">

    <Shell.Resources>
        <ResourceDictionary>
            <!-- 全局隐藏顶部导航栏，所有页面内容将延伸至状态栏下方 -->
            <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
                <Setter Property="Shell.NavBarIsVisible" Value="False"/>
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <TabBar>
        <Tab Title="播放" Icon="ic_play" Route="nowplaying">
            <ShellContent ContentTemplate="{DataTemplate pages:NowPlayingPage}" />
        </Tab>

        <Tab Title="发现" Icon="ic_home" Route="discover">
            <ShellContent ContentTemplate="{DataTemplate pages:SearchPage}" />
        </Tab>

        <Tab Title="歌单" Icon="ic_library" Route="playlists">
            <ShellContent ContentTemplate="{DataTemplate pages:PlaylistPage}" />
        </Tab>

        <Tab Title="音乐库" Icon="ic_library" Route="library">
            <ShellContent ContentTemplate="{DataTemplate pages:LibraryPage}" />
        </Tab>

        <Tab Title="设置" Icon="ic_settings" Route="settings">
            <ShellContent ContentTemplate="{DataTemplate pages:SettingsPage}" />
        </Tab>
    </TabBar>

</Shell>
