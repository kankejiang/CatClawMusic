<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    
    <!-- Colors -->
    <Color x:Key="PrimaryColor">#9B7ED8</Color>
    <Color x:Key="PrimaryDarkColor">#7B5DB8</Color>
    <Color x:Key="AccentColor">#FF6B9D</Color>
    
    <!-- Page-level dynamic resources (referenced by Pages) -->
    <Color x:Key="PageBackgroundColor">#FFFFFF</Color>
    <Color x:Key="CardBackgroundColor">#F5F5F5</Color>
    <Color x:Key="CardBorderColor">#E0E0E0</Color>
    <Color x:Key="TextPrimaryColor">#000000</Color>
    <Color x:Key="TextSecondaryColor">#666666</Color>
    <Color x:Key="TextHintColor">#999999</Color>
    
    <!-- Styles with Theme Support -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
    </Style>
    
    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20,10" />
    </Style>
    
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light=#999999, Dark=#666666}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>
    
    <Style TargetType="CollectionView">
        <Setter Property="SelectionMode" Value="Single" />
    </Style>
    
    <!-- Custom Styles -->
    <Style x:Key="CardStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2C}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="15" />
        <Setter Property="HasShadow" Value="False" />
    </Style>
    
    <Style x:Key="SectionHeaderStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#666666, Dark=#B0B0B0}" />
        <Setter Property="Margin" Value="20,15,20,5" />
    </Style>
    
    <Style x:Key="SongItemStyle" TargetType="Grid">
        <Setter Property="Padding" Value="20,12" />
    </Style>
    
</ResourceDictionary>
