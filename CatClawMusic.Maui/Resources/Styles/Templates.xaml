<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════ -->
    <!-- 歌曲列表项模板                          -->
    <!-- ═══════════════════════════════════════ -->
    <DataTemplate x:Key="SongItemTemplate">
        <Grid Padding="16,10" ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto"
              ColumnSpacing="12">
            <!-- 封面缩略图 -->
            <Border Grid.RowSpan="2" WidthRequest="48" HeightRequest="48"
                    StrokeShape="RoundRectangle 6" StrokeThickness="0"
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    VerticalOptions="Center">
                <Image Source="{Binding CoverArtPath, FallbackValue='ic_music_note'}"
                       Aspect="AspectFill" WidthRequest="48" HeightRequest="48"/>
            </Border>
            <!-- 标题 -->
            <Label Grid.Column="1" Grid.Row="0"
                   Text="{Binding Title}" FontSize="15" FontAttributes="Bold"
                   TextColor="{DynamicResource TextPrimaryColor}"
                   LineBreakMode="TailTruncation" MaxLines="1"/>
            <!-- 艺术家 · 专辑 -->
            <Label Grid.Column="1" Grid.Row="1"
                   TextColor="{DynamicResource TextSecondaryColor}" FontSize="12"
                   LineBreakMode="TailTruncation" MaxLines="1">
                <Label.Text>
                    <MultiBinding StringFormat="{}{0} · {1}">
                        <Binding Path="Artist" FallbackValue="未知艺术家"/>
                        <Binding Path="Album" FallbackValue="未知专辑"/>
                    </MultiBinding>
                </Label.Text>
            </Label>
            <!-- 时长 -->
            <Label Grid.Column="2" Grid.RowSpan="2"
                   Text="{Binding Duration, Converter={StaticResource DurationConverter}}"
                   TextColor="{DynamicResource TextSecondaryColor}"
                   FontSize="12" VerticalOptions="Center"/>
        </Grid>
    </DataTemplate>

    <!-- ═══════════════════════════════════════ -->
    <!-- 专辑卡片模板                            -->
    <!-- ═══════════════════════════════════════ -->
    <DataTemplate x:Key="AlbumCardTemplate">
        <Border Padding="0" StrokeShape="RoundRectangle 10" StrokeThickness="0"
                BackgroundColor="{DynamicResource CardBackgroundColor}"
                WidthRequest="140">
            <VerticalStackLayout Spacing="6" Padding="0,0,0,10">
                <Border WidthRequest="140" HeightRequest="140"
                        StrokeShape="RoundRectangle 10 10 0 0" StrokeThickness="0"
                        BackgroundColor="{DynamicResource SurfaceColor}">
                    <Image Source="{Binding CoverArtPath, FallbackValue='ic_album'}"
                           Aspect="AspectFill" WidthRequest="140" HeightRequest="140"/>
                </Border>
                <Label Text="{Binding Title}" FontSize="13" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimaryColor}"
                       LineBreakMode="TailTruncation" MaxLines="1"
                       Padding="8,0"/>
                <Label Text="{Binding Artist, FallbackValue='未知艺术家'}" FontSize="11"
                       TextColor="{DynamicResource TextSecondaryColor}"
                       LineBreakMode="TailTruncation" MaxLines="1"
                       Padding="8,0"/>
            </VerticalStackLayout>
        </Border>
    </DataTemplate>

    <!-- ═══════════════════════════════════════ -->
    <!-- 艺术家卡片模板                          -->
    <!-- ═══════════════════════════════════════ -->
    <DataTemplate x:Key="ArtistCardTemplate">
        <VerticalStackLayout Spacing="6" WidthRequest="90" Padding="4">
            <Border WidthRequest="80" HeightRequest="80"
                    StrokeShape="RoundRectangle 40" StrokeThickness="0"
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    HorizontalOptions="Center">
                <Image Source="{Binding PhotoPath, FallbackValue='ic_artist'}"
                       Aspect="AspectFill" WidthRequest="80" HeightRequest="80"/>
            </Border>
            <Label Text="{Binding Name}" FontSize="12"
                   TextColor="{DynamicResource TextPrimaryColor}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="TailTruncation" MaxLines="1"/>
        </VerticalStackLayout>
    </DataTemplate>

</ResourceDictionary>
