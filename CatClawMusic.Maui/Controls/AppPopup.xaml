<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatClawMusic.Maui.Controls.AppPopup"
             InputTransparent="False"
             HorizontalOptions="Fill"
             VerticalOptions="Fill"
             IsVisible="False"
             Opacity="0">
    <Grid x:Name="RootGrid"
          InputTransparent="False"
          BackgroundColor="Transparent">
        <BoxView x:Name="MaskLayer"
                 Color="#99000000"
                 InputTransparent="False"
                 Opacity="0">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnMaskTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>
        <Border x:Name="PopupCard"
                BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                Stroke="{DynamicResource GlassStrokeStrongColor}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 26"
                Padding="20"
                WidthRequest="360"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                TranslationY="20"
                Opacity="0"
                Scale="0.9"
                InputTransparent="False">
            <Border.Shadow>
                <Shadow Brush="Black"
                        Radius="30"
                        Offset="0,12"
                        Opacity="0.5" />
            </Border.Shadow>
            <VerticalStackLayout x:Name="PopupContent" Spacing="0"
                                 x:FieldModifier="public" />
        </Border>
    </Grid>
</ContentView>
