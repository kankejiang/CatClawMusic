<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.AlbumDetailPage"
             Title="专辑详情"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12"
                      Padding="44,0,0,0">
                    <Border Grid.Column="0"
                            WidthRequest="72"
                            HeightRequest="72"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="0"
                            BackgroundColor="{DynamicResource SurfaceColor}">
                        <Image Source="{Binding AlbumCoverPath, TargetNullValue='ic_album'}"
                               Aspect="AspectFill"
                               WidthRequest="72"
                               HeightRequest="72" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1"
                                         VerticalOptions="Center"
                                         Spacing="2">
                        <Label Text="{Binding Album.Title}"
                               FontSize="20"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}"
                               MaxLines="2" />
                        <Label Text="{Binding Album.Artist}"
                               FontSize="14"
                               TextColor="{DynamicResource TextSecondaryColor}" />
                        <Label Text="{Binding Album.Year}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}" />
                        <Grid ColumnDefinitions="Auto,Auto"
                              ColumnSpacing="8"
                              Margin="0,2,0,0">
                            <Button Text="▶ 播放"
                                    Command="{Binding PlayAllCommand}"
                                    BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                    TextColor="White"
                                    CornerRadius="18"
                                    HeightRequest="32"
                                    FontSize="11" />
                            <Button Grid.Column="1"
                                    Text="＋ 添加到"
                                    Command="{Binding AddToPlaylistCommand}"
                                    BackgroundColor="{DynamicResource ChipInactiveColor}"
                                    TextColor="{DynamicResource ChipInactiveTextColor}"
                                    CornerRadius="18"
                                    HeightRequest="32"
                                    FontSize="11" />
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <Label Grid.Row="1"
               Text="{Binding Songs.Count, StringFormat='共 {0} 首歌曲'}"
               FontSize="12"
               TextColor="{DynamicResource TextHintColor}"
               Margin="20,6,20,10" />

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Songs}"
                        SelectionMode="Single"
                        SelectionChanged="OnSongSelected"
                        ItemsUpdatingScrollMode="KeepItemsInView"
                        ItemTemplate="{StaticResource SongItemTemplate}">
            <CollectionView.Behaviors>
                <controls:ScrollPerformanceBehavior />
            </CollectionView.Behaviors>
        </CollectionView>
</Grid>
</ContentPage>
