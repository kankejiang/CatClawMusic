<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:converters="clr-namespace:CatClawMusic.Maui.Converters"
             xmlns:vm="clr-namespace:CatClawMusic.Maui.ViewModels"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.PluginManagementPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Plugins]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid Background="{DynamicResource PageBackgroundBrush}">

        <ScrollView>
            <VerticalStackLayout Padding="16,18,16,22" Spacing="14">

                <!-- Hero Header -->
                <Border Style="{StaticResource GlassCardStrongStyle}"
                        Background="{DynamicResource HeroBrush}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Plugins]}"
                                   Style="{StaticResource PageTitleStyle}"
                                   TextColor="White" />
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PluginsSubtitle]}"
                                   Style="{StaticResource PageSubtitleStyle}"
                                   TextColor="#F3F5FF" />
                            <Label Text="{Binding Summary}"
                                   FontSize="12"
                                   TextColor="#B8C7FF" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                Style="{StaticResource GlassIconContainerStyle}"
                                BackgroundColor="#24FFFFFF"
                                Stroke="{DynamicResource GlassStrokeColor}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RefreshCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="🔄" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- 插件列表 -->
                <VerticalStackLayout Spacing="10"
                                     BindableLayout.ItemsSource="{Binding Plugins}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:PluginItemView">
                            <Border Style="{StaticResource GlassCardStyle}">
                                <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <Label Text="{Binding IconEmoji}"
                                           FontSize="26"
                                           VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="6">
                                            <Label Text="{Binding DisplayName}"
                                                   FontSize="15"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="{DynamicResource TextPrimaryColor}" />
                                            <Border Grid.Column="1"
                                                    Padding="6,2"
                                                    Stroke="{DynamicResource GlassStrokeColor}"
                                                    StrokeShape="RoundRectangle 8"
                                                    BackgroundColor="#1AFFFFFF"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding CategoryText}"
                                                       FontSize="9"
                                                       TextColor="#B8C7FF" />
                                            </Border>
                                            <Border Grid.Column="2"
                                                    Padding="6,2"
                                                    Stroke="{DynamicResource GlassStrokeColor}"
                                                    StrokeShape="RoundRectangle 8"
                                                    BackgroundColor="#1AFFFFFF"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding SourceText}"
                                                       FontSize="9"
                                                       TextColor="#B8C7FF" />
                                            </Border>
                                        </Grid>
                                        <Label Text="{Binding Description}"
                                               FontSize="11"
                                               TextColor="{DynamicResource TextHintColor}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding Version, StringFormat='v{0}'}"
                                                   FontSize="10"
                                                   TextColor="{DynamicResource TextHintColor}" />
                                            <Label Text="{Binding Author, StringFormat='by {0}'}"
                                                   FontSize="10"
                                                   TextColor="{DynamicResource TextHintColor}"
                                                   IsVisible="{Binding Author, Converter={StaticResource StringToBoolConverter}}" />
                                            <BoxView WidthRequest="6" HeightRequest="6"
                                                     CornerRadius="3"
                                                     Color="{Binding StatusColor}"
                                                     VerticalOptions="Center" />
                                            <Label Text="{Binding StatusText}"
                                                   FontSize="10"
                                                   TextColor="{Binding StatusColor}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    <Switch Grid.Column="2"
                                            IsToggled="{Binding IsEnabled}"
                                            OnColor="{DynamicResource PrimaryColor}"
                                            ThumbColor="White"
                                            VerticalOptions="Center"
                                            IsEnabled="False" />
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleEnabledCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- 空状态 -->
                <Border Style="{StaticResource GlassCardStyle}"
                        IsVisible="{Binding Plugins.Count, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="🧩"
                               FontSize="34"
                               HorizontalOptions="Center" />
                        <Label Text="当前没有可用插件"
                               Style="{StaticResource PageSubtitleStyle}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="插件系统已就绪，未来可通过安装包扩展功能"
                               FontSize="11"
                               TextColor="{DynamicResource TextHintColor}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- 提示 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="💡 关于插件"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Label Text="点击插件卡片可快速切换启用状态。插件按类型分为歌词、协议、封面、音效等。"
                               FontSize="11"
                               TextColor="{DynamicResource TextHintColor}" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
            <controls:BackButton Margin="16,16,0,0"
                             VerticalOptions="Start"
                             HorizontalOptions="Start"
                             ZIndex="100" />
</Grid>
</ContentPage>
