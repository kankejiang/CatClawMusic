<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:converters="clr-namespace:CatClawMusic.Maui.Converters"
             x:Class="CatClawMusic.Maui.Pages.AiSettingsPage"
             Title="AI 设置"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <Grid.Behaviors>
            <controls:SafeAreaPaddingBehavior />
        </Grid.Behaviors>

        <!-- 顶部栏：BackButton + 标题 -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="10"
              Padding="16,8,16,10">
            <controls:BackButton VerticalOptions="Center" />
            <Label Grid.Column="1"
                   Text="AI 设置"
                   FontSize="20"
                   FontFamily="OpenSansSemibold"
                   TextColor="{DynamicResource TextPrimaryColor}"
                   VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,4,16,22" Spacing="14">

                <!-- 卡片1：AI 助手开关 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="AI 助手"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="关闭后探索页 AI 入口将不响应"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsEnabled}"
                                OnColor="{DynamicResource PrimaryColor}"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- 卡片2：主对话模型 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Text="主对话模型"
                                   FontSize="16"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="管理"
                                    Command="{Binding ManageModelsCommand}"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    TextColor="White"
                                    CornerRadius="14"
                                    HeightRequest="32"
                                    Padding="14,0"
                                    FontSize="12"
                                    VerticalOptions="Center" />
                        </Grid>

                        <!-- 已配置：显示概览 -->
                        <VerticalStackLayout Spacing="6"
                                             IsVisible="{Binding HasCurrentConfig}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Label Text="配置"
                                       FontSize="12"
                                       TextColor="{DynamicResource TextHintColor}" />
                                <Label Grid.Column="1"
                                       Text="{Binding CurrentConfigName}"
                                       FontSize="13"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Label Text="提供商"
                                       FontSize="12"
                                       TextColor="{DynamicResource TextHintColor}" />
                                <Label Grid.Column="1"
                                       Text="{Binding CurrentProviderName}"
                                       FontSize="13"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Label Text="模型"
                                       FontSize="12"
                                       TextColor="{DynamicResource TextHintColor}" />
                                <Label Grid.Column="1"
                                       Text="{Binding CurrentModel}"
                                       FontSize="13"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Label Text="API URL"
                                       FontSize="12"
                                       TextColor="{DynamicResource TextHintColor}" />
                                <Label Grid.Column="1"
                                       Text="{Binding CurrentApiUrl}"
                                       FontSize="13"
                                       TextColor="{DynamicResource TextSecondaryColor}"
                                       MaxLines="1"
                                       LineBreakMode="MiddleTruncation" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- 未配置提示 -->
                        <Label Text="未配置，点击管理添加"
                               FontSize="13"
                               TextColor="{DynamicResource TextHintColor}"
                               IsVisible="{Binding HasCurrentConfig, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>
                </Border>

                <!-- 卡片3：回退模型 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="回退模型"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />

                        <!-- 回退模型列表 -->
                        <VerticalStackLayout Spacing="6"
                                             IsVisible="{Binding HasFallbackConfigs}">
                            <BindableLayout.ItemsSource>
                                <Binding Path="FallbackConfigs" />
                            </BindableLayout.ItemsSource>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="2,3">
                                        <Label Text="{Binding Name}"
                                               FontSize="13"
                                               TextColor="{DynamicResource TextPrimaryColor}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Model}"
                                               FontSize="12"
                                               TextColor="{DynamicResource TextSecondaryColor}" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- 空状态提示 -->
                        <Label Text="未设置回退模型，主模型失败时将无法自动切换"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}"
                               IsVisible="{Binding HasFallbackConfigs, Converter={StaticResource InvertedBoolConverter}}" />

                        <Label Text="主模型请求失败时，将按顺序切换到这些回退模型"
                               FontSize="11"
                               TextColor="{DynamicResource TextHintColor}"
                               Margin="0,4,0,0" />
                    </VerticalStackLayout>
                </Border>

                <!-- 卡片4：长期记忆 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="长期记忆"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />

                        <Editor Text="{Binding MemoryContent}"
                                IsReadOnly="True"
                                HeightRequest="200"
                                BackgroundColor="#22FFFFFF"
                                TextColor="{DynamicResource TextPrimaryColor}"
                                FontSize="13"
                                Placeholder="暂无长期记忆"
                                PlaceholderColor="{DynamicResource TextHintColor}" />

                        <HorizontalStackLayout Spacing="8">
                            <Button Text="添加记忆"
                                    Command="{Binding AddMemoryCommand}"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    TextColor="White"
                                    CornerRadius="16"
                                    HeightRequest="38"
                                    Padding="16,0"
                                    FontSize="13" />
                            <Button Text="清空记忆"
                                    Command="{Binding ClearMemoryCommand}"
                                    BackgroundColor="#33FFFFFF"
                                    TextColor="{DynamicResource TextSecondaryColor}"
                                    CornerRadius="16"
                                    HeightRequest="38"
                                    Padding="16,0"
                                    FontSize="13" />
                        </HorizontalStackLayout>

                        <Label Text="长期记忆会作为系统提示的一部分注入到每次对话中，帮助 AI 记住重要信息"
                               FontSize="11"
                               TextColor="{DynamicResource TextHintColor}"
                               Margin="0,2,0,0" />
                    </VerticalStackLayout>
                </Border>

                <!-- 卡片5：当前助手 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="2">
                        <Border Grid.Column="0"
                                WidthRequest="56"
                                HeightRequest="56"
                                StrokeShape="RoundRectangle 28"
                                StrokeThickness="0"
                                Padding="0">
                            <Image Source="avatar_yuki.png"
                                   Aspect="AspectFill"
                                   WidthRequest="56"
                                   HeightRequest="56" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Yuki"
                                   FontSize="16"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="猫爪音乐内置小助手"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
