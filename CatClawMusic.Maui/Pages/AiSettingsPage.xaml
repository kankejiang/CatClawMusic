<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:converters="clr-namespace:CatClawMusic.Maui.Converters"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.AiSettingsPage"
             Title="AI 设置"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Padding="44,0,0,0" Spacing="6">
                    <Label Text="🤖 AI 设置"
                           Style="{StaticResource PageTitleStyle}"
                           TextColor="White" />
                    <Label Text="配置 OpenAI 兼容的大语言模型，让 Yuki 帮你管理音乐库。"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextColor="#F3F5FF" />
                    <Label Text="{Binding ConfiguredStatus}"
                           FontSize="12"
                           TextColor="#B8C7FF" />
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,22" Spacing="14">

                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="启用 AI 助手"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="关闭后探索页 AI 入口将不响应"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsEnabled}"
                                OnColor="{DynamicResource PrimaryColor}"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="提供商"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Picker Title="选择 LLM 提供商"
                                ItemsSource="{Binding Providers}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedProvider}"
                                BackgroundColor="#22FFFFFF"
                                TextColor="{DynamicResource TextPrimaryColor}"
                                TitleColor="{DynamicResource TextSecondaryColor}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="API 配置"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Base URL"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextSecondaryColor}" />
                            <Entry Text="{Binding ApiUrl}"
                                   Placeholder="https://api.deepseek.com/v1"
                                   Keyboard="Url"
                                   BackgroundColor="#22FFFFFF"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   PlaceholderColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="API Key"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextSecondaryColor}" />
                            <Entry Text="{Binding ApiKey}"
                                   Placeholder="sk-..."
                                   IsPassword="True"
                                   BackgroundColor="#22FFFFFF"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   PlaceholderColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label Text="模型名"
                                       FontSize="12"
                                       TextColor="{DynamicResource TextSecondaryColor}" />
                                <Button Grid.Column="1"
                                        Text="获取模型"
                                        Command="{Binding FetchModelsCommand}"
                                        FontSize="11"
                                        HeightRequest="28"
                                        CornerRadius="14"
                                        Padding="10,0"
                                        BackgroundColor="#33FFFFFF"
                                        TextColor="{DynamicResource TextSecondaryColor}"
                                        IsEnabled="{Binding IsFetchingModels, Converter={StaticResource InvertedBoolConverter}}" />
                            </Grid>
                            <Entry Text="{Binding Model}"
                                   Placeholder="deepseek-chat"
                                   BackgroundColor="#22FFFFFF"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   PlaceholderColor="{DynamicResource TextHintColor}" />
                            <Label Text="{Binding FetchModelsResult}"
                                   FontSize="11"
                                   TextColor="{DynamicResource TextHintColor}"
                                   IsVisible="{Binding FetchModelsResult, Converter={StaticResource StringToBoolConverter}}" />
                            <Label Text="可选预设模型（点击填入）"
                                   FontSize="11"
                                   TextColor="{DynamicResource TextHintColor}"
                                   IsVisible="{Binding PresetModels.Count, Converter={StaticResource IntToBoolConverter}}" />
                            <FlexLayout Direction="Row" Wrap="Wrap" AlignItems="Start" JustifyContent="Start">
                                <BindableLayout.ItemsSource>
                                    <Binding Path="PresetModels" />
                                </BindableLayout.ItemsSource>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,6,6"
                                                Padding="10,4"
                                                Stroke="{DynamicResource GlassStrokeColor}"
                                                StrokeShape="RoundRectangle 12"
                                                BackgroundColor="#1AFFFFFF">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UsePresetModelCommand}"
                                                                      CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="{Binding .}"
                                                   FontSize="11"
                                                   TextColor="{DynamicResource TextSecondaryColor}" />
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                            <Label Text="从 API 获取的模型（点击填入）"
                                   FontSize="11"
                                   TextColor="{DynamicResource PrimaryColor}"
                                   IsVisible="{Binding IsModelPickerVisible}"
                                   Margin="0,6,0,2" />
                            <FlexLayout Direction="Row" Wrap="Wrap" AlignItems="Start" JustifyContent="Start"
                                        IsVisible="{Binding IsModelPickerVisible}">
                                <BindableLayout.ItemsSource>
                                    <Binding Path="FetchedModels" />
                                </BindableLayout.ItemsSource>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,6,6"
                                                Padding="10,4"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12"
                                                BackgroundColor="{DynamicResource PrimaryColor}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectFetchedModelCommand}"
                                                                      CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="{Binding .}"
                                                   FontSize="11"
                                                   TextColor="White" />
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="高级参数"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="温度 (Temperature)"
                                       FontSize="13"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                                <Label Text="{Binding Temperature, StringFormat='{0:F2}'}"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="2"
                                    Value="{Binding Temperature}"
                                    WidthRequest="180"
                                    ThumbColor="{DynamicResource PrimaryColor}"
                                    MinimumTrackColor="{DynamicResource PrimaryColor}"
                                    VerticalOptions="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="最大 Tokens"
                                       FontSize="13"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                            </VerticalStackLayout>
                            <Entry Grid.Column="1"
                                   Text="{Binding MaxTokens}"
                                   Keyboard="Numeric"
                                   WidthRequest="120"
                                   BackgroundColor="#22FFFFFF"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}"
                        IsVisible="{Binding TestResult, Converter={StaticResource StringToBoolConverter}}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="连接测试"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Label Text="{Binding TestResult}"
                               FontSize="13"
                               TextColor="{Binding TestResultColor}" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="{Binding IsTesting, StringFormat='测试连接'}"
                            Command="{Binding TestConnectionCommand}"
                            BackgroundColor="#33FFFFFF"
                            TextColor="White"
                            CornerRadius="18"
                            HeightRequest="46"
                            FontSize="14"
                            IsEnabled="{Binding IsTesting, Converter={StaticResource InvertedBoolConverter}}" />
                    <Button Grid.Column="1"
                            Text="{Binding IsSaving, StringFormat='保存配置'}"
                            Command="{Binding SaveCommand}"
                            BackgroundColor="{DynamicResource PrimaryColor}"
                            TextColor="White"
                            CornerRadius="18"
                            HeightRequest="46"
                            FontSize="14"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}" />
                </Grid>

                <Button Text="重置为默认值"
                        Command="{Binding ResetToDefaultCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{DynamicResource TextHintColor}"
                        CornerRadius="16"
                        HeightRequest="38"
                        FontSize="12" />

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="当前助手"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="🐾" FontSize="22" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding CurrentAgentName}"
                                       FontSize="14"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                                <Label Text="猫爪音乐内置小助手"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
</Grid>
</ContentPage>
