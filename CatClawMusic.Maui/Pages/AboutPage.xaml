<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.AboutPage"
             Title="关于"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Padding="44,0,0,0"
                                     Spacing="14"
                                     HorizontalOptions="Center">
                    <Image Source="cover_default"
                           WidthRequest="100"
                           HeightRequest="100"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AppName]}"
                           Style="{StaticResource PageTitleStyle}"
                           HorizontalOptions="Center"
                           TextColor="White" />
                    <Label Text="{Binding Version}"
                           FontSize="13"
                           TextColor="#F3F5FF"
                           HorizontalOptions="Center" />
                    <Label Text="一个简洁优雅的音乐播放器"
                           FontSize="14"
                           TextColor="#F3F5FF"
                           HorizontalOptions="Center" />
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#24FFFFFF"
                            Padding="14,5"
                            HorizontalOptions="Center">
                        <Label Text=".NET MAUI Edition"
                               FontSize="11"
                               FontFamily="OpenSansSemibold"
                               TextColor="White"
                               HorizontalOptions="Center" />
                    </Border>
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,22"
                                 Spacing="16">

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Button Text="📄 开源协议"
                                Command="{Binding ViewLicenseCommand}"
                                BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                                TextColor="{DynamicResource TextPrimaryColor}"
                                CornerRadius="16"
                                HeightRequest="48"
                                FontSize="14" />
                        <Button Text="💬 交流群"
                                Command="{Binding JoinGroupCommand}"
                                BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                                TextColor="{DynamicResource TextPrimaryColor}"
                                CornerRadius="16"
                                HeightRequest="48"
                                FontSize="14" />
                        <Button Text="⭐ GitHub"
                                Command="{Binding OpenGitHubCommand}"
                                BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                                TextColor="{DynamicResource TextPrimaryColor}"
                                CornerRadius="16"
                                HeightRequest="48"
                                FontSize="14" />
                        <Button Text="检查更新"
                                Command="{Binding CheckUpdateCommand}"
                                BackgroundColor="{DynamicResource PrimaryColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="48"
                                FontSize="14"
                                FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding Copyright}"
                       FontSize="12"
                       TextColor="{DynamicResource TextHintColor}"
                       HorizontalOptions="Center"
                       Margin="0,8,0,0" />
            </VerticalStackLayout>
        </ScrollView>
</Grid>
</ContentPage>
