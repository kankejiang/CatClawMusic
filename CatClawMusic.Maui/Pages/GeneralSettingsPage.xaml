<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.GeneralSettingsPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[GeneralSettingsTitle]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <!-- Frosted glass background: blurred theme image, semi-transparent -->
        <controls:FrostedBackground Grid.RowSpan="2"
            Source="{DynamicResource ThemeBackgroundImage}"
            IsActive="{DynamicResource ThemeBackgroundEnabled}"
            IsVisible="{DynamicResource ThemeBackgroundEnabled}"
            TintColor="{DynamicResource TabBarGlassTint}"
            TintOpacity="0.45"
            DimAmount="0.25"
            Opacity="0.8"
            Aspect="AspectFill"
            UseNativeBlur="True"
            InputTransparent="True" />

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Padding="44,0,0,0" Spacing="8">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[GeneralSettingsTitle]}"
                           Style="{StaticResource PageTitleStyle}"
                           TextColor="White" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[GeneralSettingsSubtitle]}"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextColor="#F3F5FF" />
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,22"
                                 Spacing="14">

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Language]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Border Style="{StaticResource GlassInputStyle}"
                                Padding="0">
                            <Picker ItemsSource="{Binding LanguageOptions}"
                                    SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"
                                    BackgroundColor="Transparent"
                                    TextColor="{DynamicResource TextPrimaryColor}" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0"
                                            Spacing="4"
                                            VerticalOptions="Center">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[CacheSize]}"
                                   FontSize="16"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="{Binding CacheSize}"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClearCache]}"
                                Command="{Binding ClearCacheCommand}"
                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="38"
                                FontSize="12" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ResetSettings]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ResetSettingsHint]}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}" />
                        <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Reset]}"
                                Command="{Binding ResetSettingsCommand}"
                                BackgroundColor="{DynamicResource ErrorColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="40"
                                FontSize="13" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
