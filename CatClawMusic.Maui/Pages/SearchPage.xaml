<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.SearchPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabDiscover]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid Background="{DynamicResource PageBackgroundBrush}">

        <CollectionView x:Name="DiscoverCollection"
                        IsVisible="{Binding IsChatMode, Converter={StaticResource InvertedBoolConverter}}"
                        ItemsSource="{Binding DiscoverPageItems}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" />
            </CollectionView.ItemsLayout>
            <CollectionView.Header>
                <VerticalStackLayout Padding="0,0,0,24" Spacing="0">

                    <!-- Header: Hamburger + Search + Avatar -->
                    <Grid Margin="16,16,16,10"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="10">
                        <!-- 汉堡菜单按钮（左上角） -->
                        <Border Grid.Column="0"
                                Padding="8"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Background="{DynamicResource BadgeBackgroundColor}"
                                VerticalOptions="Center">
                            <ImageButton Source="ic_menu"
                                         WidthRequest="28" HeightRequest="28"
                                         BackgroundColor="Transparent"
                                         Clicked="OnHamburgerClicked" />
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource GlassInputStyle}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Image Source="ic_search"
                                       WidthRequest="18" HeightRequest="18"
                                       Opacity="0.9" VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       x:Name="SearchBox"
                                       Text="{Binding SearchQuery, Mode=TwoWay}"
                                       Placeholder="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[SearchPlaceholder]}"
                                       ReturnType="Search"
                                       TextChanged="OnSearchTextChanged"
                                       Completed="OnSearchCompleted" />
                                <ImageButton Grid.Column="2"
                                             Source="ic_close"
                                             WidthRequest="24" HeightRequest="24"
                                             BackgroundColor="Transparent"
                                             IsVisible="{Binding ShowSearchResults}"
                                             Clicked="OnClearSearchClicked" />
                            </Grid>
                        </Border>
                        <Border Grid.Column="2"
                                Padding="4"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Background="{DynamicResource BadgeBackgroundColor}"
                                VerticalOptions="Center">
                            <ImageButton Source="avatar_yuki.png"
                                         WidthRequest="44" HeightRequest="44"
                                         BackgroundColor="Transparent"
                                         Clicked="OnYukiAvatarClicked" />
                        </Border>
                    </Grid>

                    <!-- Search Results Dropdown -->
                    <Border Margin="16,0,16,10"
                            Padding="0"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="1"
                            Stroke="{DynamicResource GlassStrokeColor}"
                            BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                            IsVisible="{Binding ShowSearchResults}">
                        <ScrollView MaximumHeightRequest="380">
                            <VerticalStackLayout Spacing="0">

                                <!-- Songs Section -->
                                <VerticalStackLayout IsVisible="{Binding SearchResults.Count, Converter={StaticResource CountToBoolConverter}}">
                                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabSongs]}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource TextHintColor}"
                                           CharacterSpacing="2"
                                           Padding="16,12,16,4" />
                                    <CollectionView ItemsSource="{Binding SearchResults}"
                                                    SelectionMode="Single"
                                                    SelectionChanged="OnSearchResultSelected"
                                                    HeightRequest="{Binding SearchResults.Count, Converter={StaticResource SearchSectionHeightConverter}}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="14,8"
                                                      ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="12">
                                                    <Border WidthRequest="36" HeightRequest="36"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{DynamicResource SurfaceColor}">
                                                        <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}"
                                                               Aspect="AspectFill"
                                                               WidthRequest="36" HeightRequest="36" />
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1"
                                                                         VerticalOptions="Center" Spacing="1">
                                                        <Label Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontFamily="OpenSansSemibold"
                                                               TextColor="{DynamicResource TextPrimaryColor}"
                                                               MaxLines="1" />
                                                        <Label FontSize="11"
                                                               TextColor="{DynamicResource TextSecondaryColor}"
                                                               MaxLines="1">
                                                            <Label.Text>
                                                                <MultiBinding StringFormat="{}{0} · {1}">
                                                                    <Binding Path="Artist" TargetNullValue="未知艺术家" />
                                                                    <Binding Path="Album" TargetNullValue="未知专辑" />
                                                                </MultiBinding>
                                                            </Label.Text>
                                                        </Label>
                                                    </VerticalStackLayout>
                                                    <Label Grid.Column="2"
                                                           Text="{Binding Duration, Converter={StaticResource DurationConverter}}"
                                                           FontSize="11"
                                                           TextColor="{DynamicResource TextHintColor}"
                                                           VerticalOptions="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>

                                <!-- Artists Section -->
                                <VerticalStackLayout IsVisible="{Binding SearchArtistResults.Count, Converter={StaticResource CountToBoolConverter}}">
                                    <BoxView HeightRequest="1"
                                             BackgroundColor="{DynamicResource DividerColor}"
                                             Margin="16,4" />
                                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabArtists]}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource TextHintColor}"
                                           CharacterSpacing="2"
                                           Padding="16,8,16,4" />
                                    <CollectionView ItemsSource="{Binding SearchArtistResults}"
                                                    SelectionMode="Single"
                                                    SelectionChanged="OnSearchArtistSelected"
                                                    HeightRequest="{Binding SearchArtistResults.Count, Converter={StaticResource SearchSectionHeightConverter}}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="14,8"
                                                      ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="12">
                                                    <Border WidthRequest="36" HeightRequest="36"
                                                            StrokeShape="RoundRectangle 18"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{DynamicResource SurfaceColor}">
                                                        <Image Source="{Binding CoverSource}"
                                                               Aspect="AspectFill"
                                                               WidthRequest="36" HeightRequest="36" />
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1"
                                                                         VerticalOptions="Center" Spacing="1">
                                                        <Label Text="{Binding Name}"
                                                               FontSize="14"
                                                               FontFamily="OpenSansSemibold"
                                                               TextColor="{DynamicResource TextPrimaryColor}"
                                                               MaxLines="1" />
                                                        <Label Text="{Binding Subtitle}"
                                                               FontSize="11"
                                                               TextColor="{DynamicResource TextSecondaryColor}"
                                                               MaxLines="1" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>

                                <!-- Albums Section -->
                                <VerticalStackLayout IsVisible="{Binding SearchAlbumResults.Count, Converter={StaticResource CountToBoolConverter}}">
                                    <BoxView HeightRequest="1"
                                             BackgroundColor="{DynamicResource DividerColor}"
                                             Margin="16,4" />
                                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabAlbums]}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource TextHintColor}"
                                           CharacterSpacing="2"
                                           Padding="16,8,16,4" />
                                    <CollectionView ItemsSource="{Binding SearchAlbumResults}"
                                                    SelectionMode="Single"
                                                    SelectionChanged="OnSearchAlbumSelected"
                                                    HeightRequest="{Binding SearchAlbumResults.Count, Converter={StaticResource SearchSectionHeightConverter}}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="14,8"
                                                      ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="12">
                                                    <Border WidthRequest="36" HeightRequest="36"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{DynamicResource SurfaceColor}">
                                                        <Image Source="{Binding CoverSource}"
                                                               Aspect="AspectFill"
                                                               WidthRequest="36" HeightRequest="36" />
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1"
                                                                         VerticalOptions="Center" Spacing="1">
                                                        <Label Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontFamily="OpenSansSemibold"
                                                               TextColor="{DynamicResource TextPrimaryColor}"
                                                               MaxLines="1" />
                                                        <Label FontSize="11"
                                                               TextColor="{DynamicResource TextSecondaryColor}"
                                                               MaxLines="1">
                                                            <Label.Text>
                                                                <MultiBinding StringFormat="{}{0} · {1}">
                                                                    <Binding Path="ArtistName" TargetNullValue="未知艺术家" />
                                                                    <Binding Path="Subtitle" />
                                                                </MultiBinding>
                                                            </Label.Text>
                                                        </Label>
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </ScrollView>
                    </Border>

                    <!-- Featured Hero Card -->
                    <Border x:Name="HeroCard"
                            Margin="16,0,16,18"
                            Style="{StaticResource GlassCardStrongStyle}"
                            Background="{DynamicResource HeroBrush}"
                            IsVisible="{Binding HasFeaturedSong}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHeroCardTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                            <Border WidthRequest="110" HeightRequest="110"
                                    StrokeShape="RoundRectangle 18"
                                    StrokeThickness="0"
                                    BackgroundColor="Transparent">
                                <Image Source="{Binding FeaturedSongCover}"
                                       Aspect="AspectFill"
                                       WidthRequest="110" HeightRequest="110" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center" Spacing="6">
                                <Label Text="TODAY'S PICK"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#A0FFFFFF"
                                       CharacterSpacing="3" />
                                <Label Text="{Binding FeaturedSongTitle}"
                                       FontSize="20"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="White"
                                       MaxLines="2"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding FeaturedSongArtist}"
                                       FontSize="13"
                                       TextColor="#CCFFFFFF"
                                       MaxLines="1" />
                                <Border Margin="0,6,0,0"
                                        Padding="14,5"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 999"
                                        BackgroundColor="#30FFFFFF"
                                        HorizontalOptions="Start">
                                    <Label Text="&#x25b6;  播放推荐"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Quick Access Grid (2x2) -->
                    <Grid Margin="16,0,16,18"
                          ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10" RowSpacing="10">
                        <Border Grid.Row="0" Grid.Column="0"
                                Style="{StaticResource GlassCardStyle}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnQuickDailyTapped" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="&#x1f3b5;" FontSize="20" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DailyRecommendation]}" FontSize="14"
                                       FontFamily="OpenSansSemibold" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DailyRecommendationDesc]}"
                                       Style="{StaticResource PageSubtitleStyle}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1"
                                Style="{StaticResource GlassCardStyle}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnQuickTopPlayedTapped" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="&#x1f525;" FontSize="20" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FrequentSongs]}" FontSize="14"
                                       FontFamily="OpenSansSemibold" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FrequentSongsDesc]}"
                                       Style="{StaticResource PageSubtitleStyle}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0"
                                Style="{StaticResource GlassCardStyle}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnQuickRecentTapped" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="&#x2728;" FontSize="20" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[NewArrivals]}" FontSize="14"
                                       FontFamily="OpenSansSemibold" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[NewArrivalsDesc]}"
                                       Style="{StaticResource PageSubtitleStyle}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1"
                                Style="{StaticResource GlassCardStyle}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnYukiAvatarClicked" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="&#x1f4ac;" FontSize="20" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[YukiHelpFindSongs]}" FontSize="14"
                                       FontFamily="OpenSansSemibold" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[YukiDesc]}"
                                       Style="{StaticResource PageSubtitleStyle}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Daily Recommend: horizontal cover cards -->
                    <Grid x:Name="DailySectionAnchor"
                          Margin="20,0,20,8" ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TodayRecommendation]}"
                               Style="{StaticResource SectionTitleStyle}" />
                        <ActivityIndicator Grid.Column="1"
                                           IsVisible="{Binding IsLoading}"
                                           IsRunning="{Binding IsLoading}"
                                           Color="{DynamicResource PrimaryColor}" />
                    </Grid>
                    <CollectionView x:Name="DailyList"
                                    Margin="16,0,16,16"
                                    HeightRequest="200"
                                    ItemsSource="{Binding DailyRecommendSongs}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnDailySongSelected">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border WidthRequest="130"
                                        StrokeShape="RoundRectangle 18"
                                        StrokeThickness="1"
                                        Stroke="{DynamicResource GlassStrokeColor}"
                                        BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
                                    <VerticalStackLayout Spacing="0">
                                        <Border WidthRequest="130" HeightRequest="130"
                                                StrokeShape="RoundRectangle 18 18 0 0"
                                                StrokeThickness="0"
                                                BackgroundColor="{DynamicResource SurfaceColor}">
                                            <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}"
                                                   Aspect="AspectFill"
                                                   WidthRequest="130" HeightRequest="130" />
                                        </Border>
                                        <VerticalStackLayout Padding="10,8,10,10" Spacing="3">
                                            <Label Text="{Binding Title}"
                                                   FontSize="12"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="{DynamicResource TextPrimaryColor}"
                                                   MaxLines="1" />
                                            <Label Text="{Binding Artist}"
                                                   FontSize="10"
                                                   TextColor="{DynamicResource TextSecondaryColor}"
                                                   MaxLines="1" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Artists Section -->
                    <Grid Margin="20,0,20,8" ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[RecommendedArtists]}"
                               Style="{StaticResource SectionTitleStyle}" />
                        <Button Grid.Column="1"
                                Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabLibrary]}"
                                FontSize="12" HeightRequest="34"
                                CornerRadius="16"
                                BackgroundColor="{DynamicResource ChipInactiveColor}"
                                TextColor="{DynamicResource ChipInactiveTextColor}"
                                Clicked="OnGoLibraryClicked" />
                    </Grid>
                    <CollectionView x:Name="ArtistsList"
                                    Margin="16,0,16,16"
                                    HeightRequest="140"
                                    ItemsSource="{Binding Artists}"
                                    ItemTemplate="{StaticResource ArtistCardTemplate}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnArtistSelected">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                    </CollectionView>

                    <!-- Albums Section -->
                    <Label Margin="20,0,20,8"
                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[RecommendedAlbums]}"
                           Style="{StaticResource SectionTitleStyle}" />
                    <CollectionView x:Name="AlbumsList"
                                    Margin="16,0,16,18"
                                    HeightRequest="255"
                                    ItemsSource="{Binding Albums}"
                                    ItemTemplate="{StaticResource AlbumCardTemplate}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnAlbumSelected">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                    </CollectionView>

                    <!-- Top Played: horizontal cover cards -->
                    <Label x:Name="TopPlayedSection"
                           Margin="20,8,20,8"
                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FrequentSongs]}"
                           Style="{StaticResource SectionTitleStyle}" />
                    <CollectionView x:Name="TopPlayedList"
                                    Margin="16,0,16,6"
                                    HeightRequest="200"
                                    ItemsSource="{Binding TopPlayedSongs}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnTopPlayedSongSelected">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border WidthRequest="130"
                                        StrokeShape="RoundRectangle 18"
                                        StrokeThickness="1"
                                        Stroke="{DynamicResource GlassStrokeColor}"
                                        BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
                                    <VerticalStackLayout Spacing="0">
                                        <Border WidthRequest="130" HeightRequest="130"
                                                StrokeShape="RoundRectangle 18 18 0 0"
                                                StrokeThickness="0"
                                                BackgroundColor="{DynamicResource SurfaceColor}">
                                            <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}"
                                                   Aspect="AspectFill"
                                                   WidthRequest="130" HeightRequest="130" />
                                        </Border>
                                        <VerticalStackLayout Padding="10,8,10,10" Spacing="3">
                                            <Label Text="{Binding Title}"
                                                   FontSize="12"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="{DynamicResource TextPrimaryColor}"
                                                   MaxLines="1" />
                                            <Label Text="{Binding Artist}"
                                                   FontSize="10"
                                                   TextColor="{DynamicResource TextSecondaryColor}"
                                                   MaxLines="1" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Recent Added: horizontal cover cards -->
                    <Label x:Name="RecentSection"
                           Margin="20,8,20,8"
                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[NewArrivals]}"
                           Style="{StaticResource SectionTitleStyle}" />
                    <CollectionView x:Name="RecentList"
                                    Margin="16,0,16,6"
                                    HeightRequest="200"
                                    ItemsSource="{Binding RecentAddedSongs}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnRecentSongSelected">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border WidthRequest="130"
                                        StrokeShape="RoundRectangle 18"
                                        StrokeThickness="1"
                                        Stroke="{DynamicResource GlassStrokeColor}"
                                        BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
                                    <VerticalStackLayout Spacing="0">
                                        <Border WidthRequest="130" HeightRequest="130"
                                                StrokeShape="RoundRectangle 18 18 0 0"
                                                StrokeThickness="0"
                                                BackgroundColor="{DynamicResource SurfaceColor}">
                                            <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}"
                                                   Aspect="AspectFill"
                                                   WidthRequest="130" HeightRequest="130" />
                                        </Border>
                                        <VerticalStackLayout Padding="10,8,10,10" Spacing="3">
                                            <Label Text="{Binding Title}"
                                                   FontSize="12"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="{DynamicResource TextPrimaryColor}"
                                                   MaxLines="1" />
                                            <Label Text="{Binding Artist}"
                                                   FontSize="10"
                                                   TextColor="{DynamicResource TextSecondaryColor}"
                                                   MaxLines="1" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Empty State -->
                    <Border Margin="16,12,16,10"
                            Padding="22,28"
                            Style="{StaticResource GlassCardStyle}"
                            IsVisible="{Binding IsCurrentTabEmpty}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[NoContent]}"
                                   Style="{StaticResource SectionTitleStyle}"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding EmptyStateText}"
                                   Style="{StaticResource PageSubtitleStyle}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <BoxView HeightRequest="0" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Chat Overlay -->
        <Grid x:Name="ChatOverlay"
              IsVisible="{Binding IsChatMode}"
              Background="{DynamicResource PageBackgroundBrush}"
              RowDefinitions="Auto,*,Auto">

            <Border Grid.Row="0" Margin="16,18,16,10"
                    Style="{StaticResource GlassCardStrongStyle}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Border Style="{StaticResource GlassIconContainerStyle}"
                            VerticalOptions="Center">
                        <ImageButton Source="ic_arrow_back"
                                     WidthRequest="40" HeightRequest="40"
                                     BackgroundColor="Transparent"
                                     Clicked="OnChatBackClicked" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2" VerticalOptions="Center">
                        <Label Text="{Binding AgentName}"
                               Style="{StaticResource SectionTitleStyle}" />
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[YukiDesc]}"
                               Style="{StaticResource PageSubtitleStyle}" />
                    </VerticalStackLayout>
                    <Border Grid.Column="2" Padding="4"
                            StrokeThickness="0" StrokeShape="RoundRectangle 20"
                            BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                            VerticalOptions="Center">
                        <Image Source="avatar_yuki.png"
                               WidthRequest="34" HeightRequest="34" />
                    </Border>
                </Grid>
            </Border>

            <CollectionView x:Name="ChatMessagesList"
                            Grid.Row="1" Margin="12,0,12,0"
                            ItemsSource="{Binding ChatMessages}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,6">
                            <Border Padding="14,12"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="1"
                                    Stroke="{DynamicResource GlassStrokeColor}"
                                    BackgroundColor="{Binding Role, Converter={StaticResource RoleToColorConverter}}">
                                <Label Text="{Binding Content}"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextPrimaryColor}"
                                       LineBreakMode="WordWrap" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border Grid.Row="2" Margin="12,10,12,14"
                    Style="{StaticResource GlassInputStyle}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Entry x:Name="ChatInputBox"
                           Text="{Binding ChatInput, Mode=TwoWay}"
                           Placeholder="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ChatPlaceholder]}"
                           ReturnType="Send"
                           Completed="OnChatInputCompleted" />
                    <Border Grid.Column="1"
                            Style="{StaticResource GlassIconContainerStyle}"
                            BackgroundColor="{DynamicResource ChipActiveColor}">
                        <ImageButton Source="ic_send"
                                     WidthRequest="40" HeightRequest="40"
                                     BackgroundColor="Transparent"
                                     Padding="9"
                                     Clicked="OnSendClicked" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 设置侧滑面板覆盖层（从左到右滑出，85%宽度，点击空白收起） -->
        <Grid x:Name="SettingsPanelOverlay"
              IsVisible="False"
              ZIndex="100">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSettingsBackdropTapped" />
            </Grid.GestureRecognizers>

            <!-- 半透明背景遮罩 -->
            <BoxView x:Name="SettingsBackdrop"
                     Color="Black"
                     Opacity="0"
                     InputTransparent="False" />

            <!-- 设置面板容器（85%宽度，从左侧滑入） -->
            <Grid x:Name="SettingsPanel"
                  WidthRequest="300"
                  HorizontalOptions="Start"
                  TranslationX="-9999"
                  BackgroundColor="{DynamicResource WindowBackgroundColor}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 面板顶部标题栏 -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      Padding="20,16,16,12">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings]}"
                           FontSize="22"
                           FontFamily="OpenSansSemibold"
                           TextColor="{DynamicResource TextPrimaryColor}"
                           VerticalOptions="Center" />
                    <Border Grid.Column="1"
                            Padding="8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            Background="{DynamicResource BadgeBackgroundColor}">
                        <ImageButton Source="ic_close"
                                     WidthRequest="20" HeightRequest="20"
                                     BackgroundColor="Transparent"
                                     Clicked="OnSettingsCloseClicked" />
                    </Border>
                </Grid>

                <!-- 设置内容容器 -->
                <ScrollView Grid.Row="1">
                    <ContentView x:Name="SettingsPanelContent" />
                </ScrollView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
