<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.SearchPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabDiscover]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid Background="{DynamicResource PageBackgroundBrush}">

        <CollectionView x:Name="DiscoverCollection"
                        IsVisible="{Binding IsChatMode, Converter={StaticResource InvertedBoolConverter}}"
                        ItemsSource="{Binding DiscoverPageItems}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" />
            </CollectionView.ItemsLayout>
            <CollectionView.Header>
                <VerticalStackLayout Padding="0,0,0,24" Spacing="0">
                    <Grid Margin="18,16,18,10" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="发现" Style="{StaticResource PageTitleStyle}" />
                            <Label Text="{Binding GreetingText}" Style="{StaticResource PageSubtitleStyle}" Margin="0,2,0,0" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                            <Border Style="{StaticResource GlassIconContainerStyle}">
                                <ImageButton WidthRequest="22" HeightRequest="22" BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" Clicked="OnSearchToggleClicked">
                                    <ImageButton.Source>
                                        <AppThemeBinding Light="ic_search_light" Dark="ic_search" />
                                    </ImageButton.Source>
                                </ImageButton>
                            </Border>
                            <Border Style="{StaticResource GlassIconContainerStyle}">
                                <ImageButton WidthRequest="22" HeightRequest="22" BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" Clicked="OnRefreshClicked">
                                    <ImageButton.Source>
                                        <AppThemeBinding Light="ic_refresh_light" Dark="ic_refresh" />
                                    </ImageButton.Source>
                                </ImageButton>
                            </Border>
                            <Border Style="{StaticResource GlassIconContainerStyle}">
                                <ImageButton WidthRequest="22" HeightRequest="22" BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" Clicked="OnSettingsClicked">
                                    <ImageButton.Source>
                                        <AppThemeBinding Light="ic_settings_light" Dark="ic_settings" />
                                    </ImageButton.Source>
                                </ImageButton>
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>

                    <Border x:Name="SearchBoxContainer" Margin="18,0,18,10" Style="{StaticResource GlassInputStyle}" IsVisible="{Binding IsSearchOpen}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Image Source="ic_search" WidthRequest="18" HeightRequest="18" Opacity="0.9" VerticalOptions="Center" />
                            <Entry Grid.Column="1" x:Name="SearchBox" Text="{Binding SearchQuery, Mode=TwoWay}" Placeholder="搜索歌曲、歌手、专辑..." ReturnType="Search" TextChanged="OnSearchTextChanged" Completed="OnSearchCompleted" />
                            <ImageButton Grid.Column="2" Source="ic_close" WidthRequest="24" HeightRequest="24" BackgroundColor="Transparent" IsVisible="{Binding ShowSearchResults}" Clicked="OnClearSearchClicked" />
                        </Grid>
                    </Border>

                    <Border Margin="18,0,18,10" Padding="0" StrokeShape="RoundRectangle 18" StrokeThickness="1" Stroke="{DynamicResource GlassStrokeColor}" BackgroundColor="{DynamicResource CardBackgroundStrongColor}" IsVisible="{Binding ShowSearchResults}">
                        <ScrollView MaximumHeightRequest="380">
                            <VerticalStackLayout Spacing="0">
                                <VerticalStackLayout IsVisible="{Binding SearchArtistResults.Count, Converter={StaticResource CountToBoolConverter}}">
                                    <Label Text="歌手" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource TextHintColor}" CharacterSpacing="2" Padding="16,12,16,4" />
                                    <CollectionView ItemsSource="{Binding SearchArtistResults}" SelectionMode="Single" SelectionChanged="OnSearchArtistSelected" ItemsUpdatingScrollMode="KeepItemsInView" HeightRequest="{Binding SearchArtistResults.Count, Converter={StaticResource SearchSectionHeightConverter}}">
                                        <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="14,8" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                    <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                                        <Image Source="{Binding CoverSource}" Aspect="AspectFill" WidthRequest="36" HeightRequest="36" />
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                                        <Label Text="{Binding Name}" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{DynamicResource TextPrimaryColor}" MaxLines="1" />
                                                        <Label Text="{Binding Subtitle}" FontSize="11" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                                <VerticalStackLayout IsVisible="{Binding SearchAlbumResults.Count, Converter={StaticResource CountToBoolConverter}}">
                                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource DividerColor}" Margin="16,4" />
                                    <Label Text="专辑" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource TextHintColor}" CharacterSpacing="2" Padding="16,8,16,4" />
                                    <CollectionView ItemsSource="{Binding SearchAlbumResults}" SelectionMode="Single" SelectionChanged="OnSearchAlbumSelected" ItemsUpdatingScrollMode="KeepItemsInView" HeightRequest="{Binding SearchAlbumResults.Count, Converter={StaticResource SearchSectionHeightConverter}}">
                                        <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="14,8" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                    <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                                        <Image Source="{Binding CoverSource}" Aspect="AspectFill" WidthRequest="36" HeightRequest="36" />
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                                        <Label Text="{Binding Title}" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{DynamicResource TextPrimaryColor}" MaxLines="1" />
                                                        <Label FontSize="11" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1">
                                                            <Label.Text><MultiBinding StringFormat="{}{0} · {1}"><Binding Path="ArtistName" TargetNullValue="未知艺术家" /><Binding Path="Subtitle" /></MultiBinding></Label.Text>
                                                        </Label>
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                                <VerticalStackLayout IsVisible="{Binding SearchResults.Count, Converter={StaticResource CountToBoolConverter}}">
                                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource DividerColor}" Margin="16,4" />
                                    <Label Text="歌曲" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource TextHintColor}" CharacterSpacing="2" Padding="16,8,16,4" />
                                    <CollectionView ItemsSource="{Binding SearchResults}" SelectionMode="Single" SelectionChanged="OnSearchResultSelected" ItemsUpdatingScrollMode="KeepItemsInView" HeightRequest="{Binding SearchResults.Count, Converter={StaticResource SearchSectionHeightConverter}}">
                                        <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="14,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                    <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                                        <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}" Aspect="AspectFill" WidthRequest="36" HeightRequest="36" />
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                                        <Label Text="{Binding Title}" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{DynamicResource TextPrimaryColor}" MaxLines="1" />
                                                        <Label FontSize="11" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1">
                                                            <Label.Text><MultiBinding StringFormat="{}{0} · {1}"><Binding Path="Artist" TargetNullValue="未知艺术家" /><Binding Path="Album" TargetNullValue="未知专辑" /></MultiBinding></Label.Text>
                                                        </Label>
                                                    </VerticalStackLayout>
                                                    <Label Grid.Column="2" Text="{Binding Duration, Converter={StaticResource DurationConverter}}" FontSize="11" TextColor="{DynamicResource TextHintColor}" VerticalOptions="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                                <Border Margin="12,8,12,12" Padding="14,12" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnAskYukiTapped" />
                                    </Border.GestureRecognizers>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#667eea" Offset="0" />
                                            <GradientStop Color="#764ba2" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                        <Label Text="🐾" FontSize="20" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="没找到想要的？问问 Yuki 吧" FontSize="14" FontFamily="OpenSansSemibold" TextColor="White" VerticalOptions="Center" />
                                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#CCFFFFFF" VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </ScrollView>
                    </Border>

                    <Grid x:Name="CategoryTabBar" Margin="18,0,18,14" ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <Border Grid.Column="0" x:Name="TabRec" Style="{StaticResource GlassCardStyle}" Padding="12,10" Stroke="{DynamicResource GlassStrokeColor}">
                            <Label x:Name="TabRecLabel" Text="推荐" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="0" /></Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="1" x:Name="TabRank" Style="{StaticResource GlassCardStyle}" Padding="12,10" Stroke="{DynamicResource GlassStrokeColor}">
                            <Label x:Name="TabRankLabel" Text="排行榜" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="1" /></Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="2" x:Name="TabArtist" Style="{StaticResource GlassCardStyle}" Padding="12,10" Stroke="{DynamicResource GlassStrokeColor}">
                            <Label x:Name="TabArtistLabel" Text="歌手" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="2" /></Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="3" x:Name="TabAlbum" Style="{StaticResource GlassCardStyle}" Padding="12,10" Stroke="{DynamicResource GlassStrokeColor}">
                            <Label x:Name="TabAlbumLabel" Text="推荐专辑" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="3" /></Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <VerticalStackLayout x:Name="PanelRecommend" IsVisible="{Binding CurrentCategory, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}" Spacing="0">
                        <Grid Margin="20,0,20,12" ColumnDefinitions="*,Auto">
                            <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                                <Label Text="✨" FontSize="16" VerticalOptions="Center" />
                                <Label Text="智能推荐 AI" FontSize="14" FontFamily="OpenSansSemibold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding IsAiRecommendationEnabled}" VerticalOptions="Center" OnColor="{DynamicResource PrimaryColor}" />
                        </Grid>

                        <CarouselView x:Name="HeroCarousel" Margin="18,0,18,16" ItemsSource="{Binding HeroCards}" HeightRequest="188" IndicatorView="HeroIndicator" IsBounceEnabled="False">
                            <CarouselView.Behaviors><controls:ScrollPerformanceBehavior /></CarouselView.Behaviors>
                            <CarouselView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="18" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnHeroCardTapped" />
                                        </Border.GestureRecognizers>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="{Binding GradientStart}" Offset="0" />
                                                <GradientStop Color="{Binding GradientEnd}" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <VerticalStackLayout VerticalOptions="Start" Spacing="6">
                                                <Border Padding="10,4" StrokeThickness="0" StrokeShape="RoundRectangle 999" BackgroundColor="#30FFFFFF" HorizontalOptions="Start">
                                                    <Label Text="{Binding Tag}" FontSize="10" FontAttributes="Bold" TextColor="White" CharacterSpacing="2" />
                                                </Border>
                                                <Label Text="{Binding Title}" FontSize="22" FontFamily="OpenSansSemibold" TextColor="White" MaxLines="2" Margin="0,4,80,0" />
                                                <Label Text="{Binding Description}" FontSize="12" TextColor="#CCFFFFFF" MaxLines="2" Margin="0,2,80,0" />
                                            </VerticalStackLayout>
                                            <Border WidthRequest="54" HeightRequest="54" StrokeShape="RoundRectangle 27" BackgroundColor="#50FFFFFF" HorizontalOptions="End" VerticalOptions="End">
                                                <ImageButton Source="ic_play" WidthRequest="24" HeightRequest="24" BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" Clicked="OnHeroPlayTapped" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>
                        <IndicatorView x:Name="HeroIndicator" Margin="0,0,0,16" IndicatorColor="#50FFFFFF" SelectedIndicatorColor="White" IndicatorsShape="Circle" HorizontalOptions="Center" />

                        <!-- AI 助手入口卡：位于轮播卡片下方，点击进入 AI 聊天模式 -->
                        <Border x:Name="AiEntryCard"
                                Margin="18,0,18,16"
                                Padding="16,14"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAiEntryTapped" />
                            </Border.GestureRecognizers>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#667eea" Offset="0" />
                                    <GradientStop Color="#764ba2" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border WidthRequest="42" HeightRequest="42" StrokeShape="RoundRectangle 21" StrokeThickness="0" Padding="0">
                                    <Image Source="avatar_yuki.png" Aspect="AspectFill" WidthRequest="42" HeightRequest="42" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="🐾 和 Yuki 聊聊" FontSize="15" FontAttributes="Bold" TextColor="White" />
                                    <Label Text="帮你找歌、推荐、聊天都可以" FontSize="11" TextColor="#CCFFFFFF" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="22" TextColor="#CCFFFFFF" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Grid Margin="20,0,20,8" ColumnDefinitions="*,Auto">
                            <Label Text="每日推荐" Style="{StaticResource SectionTitleStyle}" />
                            <Button Grid.Column="1" Text="换一批 ↻" FontSize="12" HeightRequest="34" CornerRadius="16" BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}" Padding="8,0" Clicked="OnShuffleDailyClicked" />
                        </Grid>
                        <CollectionView x:Name="DailyList" Margin="18,0,18,16" HeightRequest="200" ItemsSource="{Binding DailyRecommendSongs}" SelectionMode="Single" SelectionChanged="OnDailySongSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                            <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                            <CollectionView.ItemsLayout><LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" /></CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border WidthRequest="132" StrokeShape="RoundRectangle 18" StrokeThickness="1" Stroke="{DynamicResource GlassStrokeColor}" BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
                                        <VerticalStackLayout Spacing="0">
                                            <Border WidthRequest="132" HeightRequest="132" StrokeShape="RoundRectangle 18 18 0 0" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                                <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}" Aspect="AspectFill" WidthRequest="132" HeightRequest="132" />
                                            </Border>
                                            <VerticalStackLayout Padding="10,8,10,10" Spacing="3">
                                                <Label Text="{Binding Title}" FontSize="12" FontFamily="OpenSansSemibold" TextColor="{DynamicResource TextPrimaryColor}" MaxLines="1" />
                                                <Label Text="{Binding Artist}" FontSize="10" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Grid Margin="20,0,20,8" ColumnDefinitions="*,Auto">
                            <Label Text="推荐艺人" Style="{StaticResource SectionTitleStyle}" />
                            <Button Grid.Column="1" Text="查看全部 ›" FontSize="12" HeightRequest="34" CornerRadius="16" BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}" Padding="8,0" Clicked="OnViewAllArtistsClicked" />
                        </Grid>
                        <CollectionView x:Name="ArtistsList" Margin="18,0,18,16" HeightRequest="140" ItemsSource="{Binding Artists}" SelectionMode="Single" SelectionChanged="OnArtistSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                            <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                            <CollectionView.ItemsLayout><LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" /></CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout WidthRequest="92" Spacing="6">
                                        <Border WidthRequest="84" HeightRequest="84" StrokeShape="RoundRectangle 42" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}" HorizontalOptions="Center">
                                            <Image Source="{Binding CoverSource}" Aspect="AspectFill" WidthRequest="84" HeightRequest="84" />
                                        </Border>
                                        <Label Text="{Binding Name}" FontSize="13" FontFamily="OpenSansSemibold" HorizontalOptions="Center" MaxLines="1" />
                                        <Label Text="{Binding Subtitle}" FontSize="11" TextColor="{DynamicResource TextHintColor}" HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <ScrollView x:Name="PanelRank" IsVisible="{Binding CurrentCategory, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}" Orientation="Vertical">
                        <ScrollView.Behaviors><controls:ScrollPerformanceBehavior /></ScrollView.Behaviors>
                        <VerticalStackLayout Spacing="0" Margin="0,0,0,16">
                            <Grid Margin="20,0,20,8" ColumnDefinitions="*,Auto">
                                <Label Text="最多播放" Style="{StaticResource SectionTitleStyle}" />
                                <Button Grid.Column="1" Text="查看全部 ›" FontSize="12" HeightRequest="34" CornerRadius="16" BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}" Padding="8,0" Clicked="OnViewAllTopPlayedClicked" />
                            </Grid>
                            <CollectionView x:Name="TopPlayedList" Margin="18,0,18,16" ItemsSource="{Binding TopPlayedSongs}" SelectionMode="Single" SelectionChanged="OnTopPlayedSongSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                                <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource GlassCardStyle}" Padding="12" Margin="0,0,0,8" BindingContextChanged="OnRankItemBindingContextChanged">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnRankItemTapped" />
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
                                                <Label x:Name="RankIndex" Text="" WidthRequest="26" FontSize="15" FontAttributes="Bold" VerticalOptions="Center" HorizontalTextAlignment="Center" />
                                                <Border WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                                    <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}" Aspect="AspectFill" WidthRequest="50" HeightRequest="50" />
                                                </Border>
                                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                                                    <Label Text="{Binding Title}" FontSize="14" FontFamily="OpenSansSemibold" MaxLines="1" />
                                                    <Label Text="{Binding Artist}" FontSize="11" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                                </VerticalStackLayout>
                                                <Grid Grid.Column="3" VerticalOptions="Center" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <Label Text="{Binding PlayCount, StringFormat='{0}次'}" FontSize="10" TextColor="{DynamicResource TextHintColor}" VerticalOptions="Center" IsVisible="{Binding PlayCount, Converter={StaticResource CountToBoolConverter}}" />
                                                    <Border WidthRequest="34" HeightRequest="34" StrokeShape="RoundRectangle 17" BackgroundColor="{DynamicResource PrimaryColor}" VerticalOptions="Center">
                                                        <ImageButton Source="ic_play" WidthRequest="16" HeightRequest="16" BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" Clicked="OnRankPlayTapped" />
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Grid Margin="20,0,20,8" ColumnDefinitions="*,Auto">
                                <Label Text="我的最爱 ★" Style="{StaticResource SectionTitleStyle}" />
                                <Button Grid.Column="1" Text="查看全部 ›" FontSize="12" HeightRequest="34" CornerRadius="16" BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}" Padding="8,0" Clicked="OnViewAllFavoritesClicked" />
                            </Grid>
                            <CollectionView x:Name="FavoriteList" Margin="18,0,18,16" ItemsSource="{Binding FavoriteSongs}" SelectionMode="Single" SelectionChanged="OnFavoriteSongSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                                <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource GlassCardStyle}" Padding="12" Margin="0,0,0,8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnFavItemTapped" />
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
                                                <Label Text="★" WidthRequest="26" FontSize="16" FontAttributes="Bold" TextColor="#FFD700" VerticalOptions="Center" HorizontalTextAlignment="Center" />
                                                <Border WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                                    <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}" Aspect="AspectFill" WidthRequest="50" HeightRequest="50" />
                                                </Border>
                                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                                                    <Label Text="{Binding Title}" FontSize="14" FontFamily="OpenSansSemibold" MaxLines="1" />
                                                    <Label Text="{Binding Artist}" FontSize="11" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                                </VerticalStackLayout>
                                                <Grid Grid.Column="3" VerticalOptions="Center" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <Label Text="已收藏" FontSize="10" TextColor="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                                                    <Border WidthRequest="34" HeightRequest="34" StrokeShape="RoundRectangle 17" BackgroundColor="{DynamicResource PrimaryColor}" VerticalOptions="Center">
                                                        <ImageButton Source="ic_play" WidthRequest="16" HeightRequest="16" BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" Clicked="OnFavPlayTapped" />
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </ScrollView>

                    <VerticalStackLayout x:Name="PanelArtist" IsVisible="{Binding CurrentCategory, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}" Spacing="0">
                        <Grid Margin="20,0,20,8" ColumnDefinitions="*,Auto">
                            <Label Text="推荐歌手" Style="{StaticResource SectionTitleStyle}" />
                            <Button Grid.Column="1" Text="查看全部 ›" FontSize="12" HeightRequest="34" CornerRadius="16" BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}" Padding="8,0" Clicked="OnViewAllArtistsClicked" />
                        </Grid>
                        <CollectionView x:Name="ArtistGrid" Margin="18,0,18,16" ItemsSource="{Binding Artists}" SelectionMode="Single" SelectionChanged="OnArtistSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                            <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                            <CollectionView.ItemsLayout><GridItemsLayout Orientation="Vertical" Span="3" VerticalItemSpacing="12" HorizontalItemSpacing="12" /></CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Spacing="6">
                                        <Border WidthRequest="84" HeightRequest="84" StrokeShape="RoundRectangle 42" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}" HorizontalOptions="Center">
                                            <Image Source="{Binding CoverSource}" Aspect="AspectFill" WidthRequest="84" HeightRequest="84" />
                                        </Border>
                                        <Label Text="{Binding Name}" FontSize="13" FontFamily="OpenSansSemibold" HorizontalOptions="Center" MaxLines="1" />
                                        <Label Text="{Binding Subtitle}" FontSize="11" TextColor="{DynamicResource TextHintColor}" HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="PanelAlbum" IsVisible="{Binding CurrentCategory, Converter={StaticResource IntToBoolConverter}, ConverterParameter=3}" Spacing="0">
                        <Grid Margin="20,0,20,4">
                            <Label Text="推荐专辑" Style="{StaticResource SectionTitleStyle}" />
                        </Grid>
                        <Label Text="从你的曲库里随机挑出的专辑 · 帮你重新发现" FontSize="11.5" TextColor="{DynamicResource TextHintColor}" Margin="20,0,20,10" />
                        <Grid Margin="20,0,20,8" ColumnDefinitions="*,Auto">
                            <Button Grid.Column="1" Text="查看全部 ›" FontSize="12" HeightRequest="34" CornerRadius="16" BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}" Padding="8,0" Clicked="OnViewAllAlbumsClicked" />
                        </Grid>
                        <CollectionView x:Name="AlbumGrid" Margin="18,0,18,16" ItemsSource="{Binding Albums}" SelectionMode="Single" SelectionChanged="OnAlbumSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                            <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                            <CollectionView.ItemsLayout><GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="12" HorizontalItemSpacing="12" /></CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Spacing="6">
                                        <Border StrokeShape="RoundRectangle 24" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                            <Image Source="{Binding CoverSource, TargetNullValue='ic_music_note'}" Aspect="AspectFill" HeightRequest="160" />
                                        </Border>
                                        <Label Text="{Binding Title}" FontSize="13.5" FontFamily="OpenSansSemibold" MaxLines="1" />
                                        <Label Text="{Binding ArtistName}" FontSize="11.5" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <ActivityIndicator Margin="0,10" IsVisible="{Binding IsLoading}" IsRunning="{Binding IsLoading}" Color="{DynamicResource PrimaryColor}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <BoxView HeightRequest="0" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Chat Overlay -->
        <Grid x:Name="ChatOverlay"
              IsVisible="{Binding IsChatMode}"
              Background="{DynamicResource PageBackgroundBrush}"
              RowDefinitions="Auto,*,Auto,Auto">

            <Grid Grid.Row="0" Margin="16,10,16,6" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <controls:BackButton x:Name="ChatBackButton"
                                     VerticalOptions="Center" />
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2" VerticalOptions="Center">
                    <Label Text="{Binding AgentName}"
                           Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[YukiDesc]}"
                           Style="{StaticResource PageSubtitleStyle}" />
                </VerticalStackLayout>
                <Border Grid.Column="2" Padding="4"
                        StrokeThickness="0" StrokeShape="RoundRectangle 20"
                        BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                        VerticalOptions="Center">
                    <Image Source="avatar_yuki.png"
                           WidthRequest="34" HeightRequest="34" />
                </Border>
            </Grid>

            <CollectionView x:Name="ChatMessagesList"
                            Grid.Row="1" Margin="12,0,12,0"
                            ItemsSource="{Binding ChatMessages}"
                            SelectionMode="None"
                            ItemsUpdatingScrollMode="KeepLastItemInView"
                            Scrolled="OnChatMessagesScrolled">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="2,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <!-- Yuki 头像（左）：assistant 消息显示 -->
                            <Border Grid.Column="0"
                                    WidthRequest="36" HeightRequest="36"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                    IsVisible="{Binding Role, Converter={StaticResource IsAssistantConverter}}"
                                    VerticalOptions="End">
                                <Image Source="avatar_yuki.png" Aspect="AspectFill" WidthRequest="36" HeightRequest="36" />
                            </Border>
                            <BoxView Grid.Column="0" WidthRequest="36" IsVisible="{Binding Role, Converter={StaticResource IsUserConverter}}" />

                            <!-- 消息气泡 -->
                            <Border Grid.Column="1"
                                    Padding="14,10"
                                    StrokeThickness="0"
                                    MaximumWidthRequest="280"
                                    StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{Binding Role, Converter={StaticResource ChatBubbleColorConverter}}"
                                    HorizontalOptions="{Binding Role, Converter={StaticResource ChatBubbleAlignmentConverter}}"
                                    VerticalOptions="Start">
                                <Label Text="{Binding Content}"
                                       FontSize="14"
                                       TextColor="White"
                                       LineBreakMode="WordWrap" />
                            </Border>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

                            <!-- 用户头像（右）：user 消息显示 -->
                            <Border Grid.Column="2"
                                    WidthRequest="36" HeightRequest="36"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    IsVisible="{Binding Role, Converter={StaticResource IsUserConverter}}"
                                    VerticalOptions="End">
                                <Label Text="👤"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <BoxView Grid.Column="2" WidthRequest="36" IsVisible="{Binding Role, Converter={StaticResource IsAssistantConverter}}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border Grid.Row="3" Margin="12,10,12,14"
                    Style="{StaticResource GlassInputStyle}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Entry x:Name="ChatInputBox"
                           Text="{Binding ChatInput, Mode=TwoWay}"
                           Placeholder="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ChatPlaceholder]}"
                           ReturnType="Send"
                           Completed="OnChatInputCompleted" />
                    <Border Grid.Column="1"
                            Style="{StaticResource GlassIconContainerStyle}"
                            BackgroundColor="{DynamicResource ChipActiveColor}">
                        <ImageButton Source="ic_send"
                                     WidthRequest="40" HeightRequest="40"
                                     BackgroundColor="Transparent"
                                     Padding="9"
                                     Clicked="OnSendClicked" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 设置侧滑面板覆盖层（从左到右滑出，85%宽度，点击空白收起） -->
        <Grid x:Name="SettingsPanelOverlay"
              IsVisible="False"
              ZIndex="100">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSettingsBackdropTapped" />
            </Grid.GestureRecognizers>

            <!-- 半透明背景遮罩 -->
            <BoxView x:Name="SettingsBackdrop"
                     Color="Black"
                     Opacity="0"
                     InputTransparent="False" />

            <!-- 设置面板容器（85%宽度，从左侧滑入） -->
            <Grid x:Name="SettingsPanel"
                  WidthRequest="300"
                  HorizontalOptions="Start"
                  TranslationX="-9999"
                  BackgroundColor="{DynamicResource WindowBackgroundColor}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 面板顶部标题栏 -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      Padding="20,16,16,12">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings]}"
                           FontSize="22"
                           FontFamily="OpenSansSemibold"
                           TextColor="{DynamicResource TextPrimaryColor}"
                           VerticalOptions="Center" />
                    <Border Grid.Column="1"
                            Padding="8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            Background="{DynamicResource BadgeBackgroundColor}">
                        <ImageButton Source="ic_close"
                                     WidthRequest="20" HeightRequest="20"
                                     BackgroundColor="Transparent"
                                     Clicked="OnSettingsCloseClicked" />
                    </Border>
                </Grid>

                <!-- 设置内容容器 -->
                <ScrollView Grid.Row="1">
                    <ContentView x:Name="SettingsPanelContent" />
                </ScrollView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
