<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.PlaylistDetailPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitlePlaylistDetail]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="16"
                      Padding="44,0,0,0">
                    <Border Grid.Column="0"
                            WidthRequest="100"
                            HeightRequest="100"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0"
                            BackgroundColor="{DynamicResource SurfaceColor}">
                        <Image Source="{Binding PlaylistCover, TargetNullValue='ic_playlist'}"
                               Aspect="AspectFill"
                               WidthRequest="100"
                               HeightRequest="100" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1"
                                         VerticalOptions="Center"
                                         Spacing="6">
                        <Label Text="{Binding Playlist.Name}"
                               FontSize="20"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}"
                               MaxLines="2" />
                        <Label Text="{Binding Playlist.SongCount, StringFormat='共 {0} 首歌曲'}"
                               FontSize="13"
                               TextColor="{DynamicResource TextSecondaryColor}" />
                        <Label Text="{Binding Songs.Count, StringFormat='当前 {0} 首'}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}" />
                        <Grid ColumnDefinitions="Auto"
                              ColumnSpacing="10"
                              Margin="0,6,0,0">
                            <Button Text="▶ 播放"
                                    Command="{Binding PlayAllCommand}"
                                    BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                    TextColor="White"
                                    CornerRadius="20"
                                    HeightRequest="36"
                                    FontSize="12" />
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <Label Grid.Row="1"
               Text="{Binding Songs.Count, StringFormat='共 {0} 首歌曲'}"
               FontSize="12"
               TextColor="{DynamicResource TextHintColor}"
               Margin="20,6,20,10" />

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Songs}"
                        SelectionMode="Single"
                        SelectionChanged="OnSongSelected"
                        ItemsUpdatingScrollMode="KeepItemsInView"
                        ItemTemplate="{StaticResource SongItemTemplate}">
            <CollectionView.Behaviors>
                <controls:ScrollPerformanceBehavior />
            </CollectionView.Behaviors>
        </CollectionView>
</Grid>
</ContentPage>
