<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatClawMusic.Maui.Pages.LibraryPage"
             Title="音乐库"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <Border Grid.Row="0"
                Margin="16,18,16,14"
                Style="{StaticResource GlassCardStrongStyle}"
                Background="{DynamicResource HeroBrush}">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="音乐库"
                           Style="{StaticResource PageTitleStyle}"
                           TextColor="White" />
                    <Label Text="把本地和网络收藏放进一座更好看的玻璃唱片馆。"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextColor="#F2F4FF" />
                </VerticalStackLayout>
                <Border Grid.Column="1"
                        Style="{StaticResource GlassBadgeStyle}"
                        BackgroundColor="#26FFFFFF"
                        Stroke="#40FFFFFF"
                        VerticalOptions="Start">
                    <Label Text="ANDROID"
                           FontSize="11"
                           FontFamily="OpenSansSemibold"
                           TextColor="White" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="16,0,16,14"
                Style="{StaticResource GlassInputStyle}">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                  ColumnSpacing="8"
                  VerticalOptions="Center">
                <Image Source="ic_search"
                       WidthRequest="18"
                       HeightRequest="18"
                       Opacity="0.8"
                       VerticalOptions="Center" />
                <Entry Grid.Column="1"
                       x:Name="SearchBox"
                       Text="{Binding SearchQuery, Mode=TwoWay}"
                       Placeholder="搜索歌曲、艺术家、专辑"
                       ReturnType="Search" />
                <ImageButton Grid.Column="2"
                             Source="ic_sort"
                             WidthRequest="34"
                             HeightRequest="34"
                             BackgroundColor="Transparent"
                             Padding="6"
                             Clicked="OnSortClicked" />
                <ImageButton Grid.Column="3"
                             Source="ic_refresh"
                             WidthRequest="34"
                             HeightRequest="34"
                             BackgroundColor="Transparent"
                             Padding="6"
                             Command="{Binding RefreshCommand}" />
                <ImageButton Grid.Column="4"
                             Source="ic_close"
                             WidthRequest="34"
                             HeightRequest="34"
                             BackgroundColor="Transparent"
                             Padding="6"
                             Clicked="OnClearClicked"
                             IsVisible="{Binding SearchQuery, Converter={StaticResource StringToBoolConverter}}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Margin="16,0,16,14"
              ColumnDefinitions="*,*,*"
              ColumnSpacing="10">
            <Border Grid.Column="0"
                    Style="{StaticResource GlassCardStyle}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="歌曲"
                           Style="{StaticResource StatCaptionStyle}" />
                    <Label Text="{Binding SongCount}"
                           Style="{StaticResource StatValueStyle}" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="1"
                    Style="{StaticResource GlassCardStyle}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="专辑"
                           Style="{StaticResource StatCaptionStyle}" />
                    <Label Text="{Binding AlbumCount}"
                           Style="{StaticResource StatValueStyle}" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="2"
                    Style="{StaticResource GlassCardStyle}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="艺术家"
                           Style="{StaticResource StatCaptionStyle}" />
                    <Label Text="{Binding ArtistCount}"
                           Style="{StaticResource StatValueStyle}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="16,0,16,10"
                Style="{StaticResource GlassCardStyle}"
                Padding="4">
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8">
                <Button Grid.Column="0"
                        Text="本地音乐"
                        HeightRequest="44"
                        CornerRadius="18"
                        FontAttributes="Bold"
                        BackgroundColor="{DynamicResource ChipInactiveColor}"
                        TextColor="{DynamicResource ChipInactiveTextColor}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Local">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding CurrentTab}"
                                     Value="Local">
                            <Setter Property="BackgroundColor" Value="{DynamicResource ChipActiveColor}" />
                            <Setter Property="TextColor" Value="{DynamicResource ChipActiveTextColor}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="1"
                        Text="网络音乐"
                        HeightRequest="44"
                        CornerRadius="18"
                        FontAttributes="Bold"
                        BackgroundColor="{DynamicResource ChipInactiveColor}"
                        TextColor="{DynamicResource ChipInactiveTextColor}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Network">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding CurrentTab}"
                                     Value="Network">
                            <Setter Property="BackgroundColor" Value="{DynamicResource ChipActiveColor}" />
                            <Setter Property="TextColor" Value="{DynamicResource ChipActiveTextColor}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="16,0,16,10"
                Style="{StaticResource GlassCardStyle}"
                IsVisible="{Binding IsNetworkTabVisible}">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12">
                <Label Text="网络协议"
                       FontSize="13"
                       TextColor="{DynamicResource TextSecondaryColor}"
                       VerticalOptions="Center" />
                <Picker Grid.Column="1"
                        x:Name="ProtocolPicker"
                        ItemsSource="{Binding ProtocolOptions}"
                        SelectedIndex="{Binding SelectedProtocolIndex, Mode=TwoWay}" />
            </Grid>
        </Border>

        <CollectionView x:Name="SongList"
                        Grid.Row="5"
                        Margin="0,0,0,8"
                        SelectionMode="Single"
                        SelectionChanged="OnSongSelected"
                        ItemsSource="{Binding FilteredSongs}"
                        ItemTemplate="{StaticResource SongItemTemplate}"
                        RemainingItemsThreshold="5"
                        RemainingItemsThresholdReached="OnLoadMore" />

        <Border Grid.Row="5"
                Margin="16,0,16,18"
                VerticalOptions="End"
                HorizontalOptions="Center"
                Style="{StaticResource GlassBadgeStyle}"
                IsVisible="{Binding IsLoading}">
            <Label x:Name="StatusLabel"
                   Text="{Binding StatusText}"
                   FontSize="12"
                   TextColor="{DynamicResource TextSecondaryColor}" />
        </Border>
    </Grid>
</ContentPage>
