<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.LibraryPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabLibrary]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <Border Grid.Row="0"
                Margin="16,8,16,8"
                Style="{StaticResource GlassCardStrongStyle}"
                Background="{DynamicResource HeroBrush}">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabLibrary]}"
                           Style="{StaticResource PageTitleStyle}"
                           TextColor="White" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[LibrarySubtitle]}"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextColor="#F2F4FF" />
                </VerticalStackLayout>
                <Border Grid.Column="1"
                        Style="{StaticResource GlassBadgeStyle}"
                        BackgroundColor="#26FFFFFF"
                        Stroke="{DynamicResource GlassStrokeColor}"
                        VerticalOptions="Start">
                    <Label Text="{OnPlatform Default='ANDROID',
                                              Android='ANDROID',
                                              WinUI='WINDOWS',
                                              iOS='IOS',
                                              MacCatalyst='MACOS'}"
                           FontSize="11"
                           FontFamily="OpenSansSemibold"
                           TextColor="White" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="16,0,16,14"
                Style="{StaticResource GlassInputStyle}">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                  ColumnSpacing="8"
                  VerticalOptions="Center">
                <Image Source="ic_search"
                       WidthRequest="18"
                       HeightRequest="18"
                       Opacity="0.8"
                       VerticalOptions="Center" />
                <Entry Grid.Column="1"
                       x:Name="SearchBox"
                       Text="{Binding SearchQuery, Mode=TwoWay}"
                       Placeholder="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[SearchPlaceholder]}"
                       ReturnType="Search" />
                <ImageButton Grid.Column="2"
                             Source="ic_sort"
                             WidthRequest="34"
                             HeightRequest="34"
                             BackgroundColor="Transparent"
                             Padding="6"
                             Clicked="OnSortClicked" />
                <ImageButton Grid.Column="3"
                             Source="ic_refresh"
                             WidthRequest="34"
                             HeightRequest="34"
                             BackgroundColor="Transparent"
                             Padding="6"
                             Command="{Binding RefreshCommand}" />
                <ImageButton Grid.Column="4"
                             Source="ic_close"
                             WidthRequest="34"
                             HeightRequest="34"
                             BackgroundColor="Transparent"
                             Padding="6"
                             Clicked="OnClearClicked"
                             IsVisible="{Binding SearchQuery, Converter={StaticResource StringToBoolConverter}}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Margin="16,0,16,14"
              ColumnDefinitions="*,*,*"
              ColumnSpacing="10">
            <Border Grid.Column="0"
                    Style="{StaticResource GlassCardStyle}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSongsClicked" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabSongs]}"
                           Style="{StaticResource StatCaptionStyle}" />
                    <Label Text="{Binding SongCount}"
                           Style="{StaticResource StatValueStyle}" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="1"
                    Style="{StaticResource GlassCardStyle}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAlbumsClicked" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabAlbums]}"
                           Style="{StaticResource StatCaptionStyle}" />
                    <Label Text="{Binding AlbumCount}"
                           Style="{StaticResource StatValueStyle}" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="2"
                    Style="{StaticResource GlassCardStyle}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnArtistsClicked" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Artists]}"
                           Style="{StaticResource StatCaptionStyle}" />
                    <Label Text="{Binding ArtistCount}"
                           Style="{StaticResource StatValueStyle}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="16,0,16,10"
                Style="{StaticResource GlassCardStyle}"
                Padding="4">
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8">
                <Button Grid.Column="0"
                        x:Name="LocalTabBtn"
                        Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[LocalMusic]}"
                        HeightRequest="44"
                        CornerRadius="18"
                        FontAttributes="Bold"
                        BackgroundColor="{DynamicResource ChipInactiveColor}"
                        TextColor="{DynamicResource ChipInactiveTextColor}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Local">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding CurrentTab}"
                                     Value="Local">
                            <Setter Property="BackgroundColor" Value="{DynamicResource ChipActiveColor}" />
                            <Setter Property="TextColor" Value="{DynamicResource ChipActiveTextColor}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding HasNetworkProtocols}"
                                     Value="False">
                            <Setter Property="Grid.ColumnSpan" Value="2" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="1"
                        Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[RemoteMusicSection]}"
                        HeightRequest="44"
                        CornerRadius="18"
                        FontAttributes="Bold"
                        BackgroundColor="{DynamicResource ChipInactiveColor}"
                        TextColor="{DynamicResource ChipInactiveTextColor}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Network"
                        IsVisible="{Binding HasNetworkProtocols}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding CurrentTab}"
                                     Value="Network">
                            <Setter Property="BackgroundColor" Value="{DynamicResource ChipActiveColor}" />
                            <Setter Property="TextColor" Value="{DynamicResource ChipActiveTextColor}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="16,0,16,10"
                Style="{StaticResource GlassCardStyle}"
                IsVisible="{Binding IsNetworkTabVisible}">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12">
                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[NetworkProtocol]}"
                       FontSize="13"
                       TextColor="{DynamicResource TextSecondaryColor}"
                       VerticalOptions="Center" />
                <Picker Grid.Column="1"
                        x:Name="ProtocolPicker"
                        ItemsSource="{Binding ProtocolOptions}"
                        SelectedIndex="{Binding SelectedProtocolIndex, Mode=TwoWay}" />
            </Grid>
        </Border>

        <CollectionView x:Name="SongList"
                        Grid.Row="5"
                        Margin="0,0,0,8"
                        SelectionMode="Single"
                        SelectionChanged="OnSongSelected"
                        ItemsSource="{Binding FilteredSongs}"
                        ItemTemplate="{StaticResource SongItemTemplate}"
                        RemainingItemsThreshold="5"
                        RemainingItemsThresholdReached="OnLoadMore" />

        <Border Grid.Row="5"
                Margin="16,0,16,18"
                VerticalOptions="End"
                HorizontalOptions="Center"
                Style="{StaticResource GlassBadgeStyle}"
                IsVisible="{Binding IsLoading}">
            <Label x:Name="StatusLabel"
                   Text="{Binding StatusText}"
                   FontSize="12"
                   TextColor="{DynamicResource TextSecondaryColor}" />
        </Border>
    </Grid>
</ContentPage>
