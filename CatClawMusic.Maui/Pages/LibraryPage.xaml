<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:converters="clr-namespace:CatClawMusic.Maui.Converters"
             x:Class="CatClawMusic.Maui.Pages.LibraryPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabLibrary]}"
             BackgroundColor="Transparent">

    <Grid Background="Transparent">
        <ScrollView Background="Transparent">
            <VerticalStackLayout Padding="18,8,18,132" Spacing="0">
            <!-- Hero 区域 -->
            <Border Padding="0" StrokeShape="RoundRectangle 24" StrokeThickness="1" Stroke="{DynamicResource GlassStrokeColor}" Margin="0,6,0,0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,1">
                        <GradientStop Offset="0" Color="#4D8C7BFF" />
                        <GradientStop Offset="1" Color="#2955D6FF" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- 右上角刷新图标 -->
                    <Border HorizontalOptions="End" VerticalOptions="Start"
                            Margin="0,14,14,0"
                            WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            BackgroundColor="#33FFFFFF">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnScanTapped" />
                        </Border.GestureRecognizers>
                        <Image Source="ic_refresh.svg"
                               WidthRequest="16" HeightRequest="16"
                               Aspect="AspectFit"
                               VerticalOptions="Center" HorizontalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Padding="22,20" Spacing="0">
                        <VerticalStackLayout>
                            <Label Text="我的音乐库" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="{Binding LibraryCount, StringFormat='本地 + 网络 · 共 {0} 个资料库'}"
                                   FontSize="12.5" TextColor="{DynamicResource TextSecondaryColor}" Margin="0,3,0,0" />
                        </VerticalStackLayout>
                        <Grid ColumnDefinitions="*,*,*,*" Margin="0,18,0,0" ColumnSpacing="8">
                            <Border Grid.Column="0" BackgroundColor="{DynamicResource GlassButtonColor}" Stroke="{DynamicResource GlassStrokeColor}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="12,10" HorizontalOptions="Fill" VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStatSongsTapped" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding TotalSongCount, StringFormat='{0:N0}'}" FontSize="19" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimaryColor}" HorizontalOptions="Center" />
                                    <Label Text="歌曲" FontSize="11" TextColor="{DynamicResource TextHintColor}"
                                           HorizontalOptions="Center" Margin="0,2,0,0" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="{DynamicResource GlassButtonColor}" Stroke="{DynamicResource GlassStrokeColor}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="12,10" HorizontalOptions="Fill" VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStatArtistsTapped" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding TotalArtistCount, StringFormat='{0:N0}'}" FontSize="19" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimaryColor}" HorizontalOptions="Center" />
                                    <Label Text="艺术家" FontSize="11" TextColor="{DynamicResource TextHintColor}"
                                           HorizontalOptions="Center" Margin="0,2,0,0" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="{DynamicResource GlassButtonColor}" Stroke="{DynamicResource GlassStrokeColor}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="12,10" HorizontalOptions="Fill" VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStatAlbumsTapped" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding TotalAlbumCount, StringFormat='{0:N0}'}" FontSize="19" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimaryColor}" HorizontalOptions="Center" />
                                    <Label Text="专辑" FontSize="11" TextColor="{DynamicResource TextHintColor}"
                                           HorizontalOptions="Center" Margin="0,2,0,0" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="3" BackgroundColor="{DynamicResource GlassButtonColor}" Stroke="{DynamicResource GlassStrokeColor}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="12,10" HorizontalOptions="Fill" VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStatRecentTapped" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding TotalHours, StringFormat='{0:F1}'}" FontSize="19" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimaryColor}" HorizontalOptions="Center" />
                                    <Label Text="小时" FontSize="11" TextColor="{DynamicResource TextHintColor}"
                                           HorizontalOptions="Center" Margin="0,2,0,0" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- 资料库列表 -->
            <Border Margin="0,18,0,0" Padding="16" StrokeShape="RoundRectangle 22" StrokeThickness="1"
                    Stroke="{DynamicResource GlassStrokeColor}" BackgroundColor="{DynamicResource CardBackgroundColor}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="资料库" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" />
                            <Border StrokeShape="RoundRectangle 999" StrokeThickness="1"
                                    Stroke="{DynamicResource BadgeStrokeColor}"
                                    BackgroundColor="{DynamicResource BadgeBackgroundColor}"
                                    Padding="8,2" VerticalOptions="Center">
                                <Label Text="{Binding LibraryCount}" FontSize="10" TextColor="{DynamicResource AccentColor}" />
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>
                    <VerticalStackLayout x:Name="LibraryCardsContainer" Spacing="12" />
                </VerticalStackLayout>
            </Border>

            <!-- 数据洞察 -->
            <Border Margin="0,18,0,0" Padding="16" StrokeShape="RoundRectangle 22" StrokeThickness="1"
                    Stroke="{DynamicResource GlassStrokeColor}" BackgroundColor="{DynamicResource CardBackgroundColor}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="数据洞察" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" />
                            <Border StrokeShape="RoundRectangle 999" StrokeThickness="1"
                                    Stroke="{DynamicResource BadgeStrokeColor}"
                                    BackgroundColor="{DynamicResource BadgeBackgroundColor}"
                                    Padding="8,2" VerticalOptions="Center">
                                <Label x:Name="PieNameBadge" Text="音频格式" FontSize="10" TextColor="{DynamicResource AccentColor}" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label x:Name="PieCounter" Grid.Column="1" Text="1 / 3" FontSize="12" FontAttributes="Bold"
                               TextColor="{DynamicResource TextHintColor}" VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <controls:DonutView x:Name="PieDonut" Grid.Column="0" />
                        <VerticalStackLayout x:Name="PieLegend" Grid.Column="1" Spacing="0" VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" Margin="0,14,0,0">
                        <Border x:Name="PiePrev" Grid.Column="0" WidthRequest="30" HeightRequest="30"
                                StrokeShape="RoundRectangle 999" StrokeThickness="1"
                                Stroke="{DynamicResource GlassStrokeColor}" BackgroundColor="{DynamicResource GlassButtonColor}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPiePrevTapped" />
                            </Border.GestureRecognizers>
                            <Label Text="‹" FontSize="20" TextColor="{DynamicResource TextPrimaryColor}"
                                   VerticalOptions="Center" HorizontalOptions="Center" />
                        </Border>
                        <HorizontalStackLayout x:Name="PieDots" Grid.Column="1" HorizontalOptions="Center" Spacing="7" VerticalOptions="Center" />
                        <Border x:Name="PieNext" Grid.Column="2" WidthRequest="30" HeightRequest="30"
                                StrokeShape="RoundRectangle 999" StrokeThickness="1"
                                Stroke="{DynamicResource GlassStrokeColor}" BackgroundColor="{DynamicResource GlassButtonColor}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPieNextTapped" />
                            </Border.GestureRecognizers>
                            <Label Text="›" FontSize="20" TextColor="{DynamicResource TextPrimaryColor}"
                                   VerticalOptions="Center" HorizontalOptions="Center" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- 存储占用 -->
            <Border Margin="0,18,0,0" Padding="16" StrokeShape="RoundRectangle 22" StrokeThickness="1"
                    Stroke="{DynamicResource GlassStrokeColor}" BackgroundColor="{DynamicResource CardBackgroundColor}">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                    <HorizontalStackLayout Spacing="8">
                            <Label Text="存储占用" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" />
                            <Border StrokeShape="RoundRectangle 999" StrokeThickness="1"
                                    Stroke="{DynamicResource BadgeStrokeColor}"
                                    BackgroundColor="{DynamicResource BadgeBackgroundColor}"
                                    Padding="8,2" VerticalOptions="Center">
                                <Label Text="本机" FontSize="10" TextColor="{DynamicResource AccentColor}" />
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>
                    <HorizontalStackLayout Spacing="8" VerticalOptions="End">
                        <Label Text="{Binding TotalMusicSizeText}" FontSize="26" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" />
                        <Label Text="音乐文件总大小" FontSize="12" TextColor="{DynamicResource TextHintColor}" VerticalOptions="End" Margin="0,0,0,4" />
                    </HorizontalStackLayout>
                    <VerticalStackLayout x:Name="FormatBarsContainer" Spacing="11" />
                    <Grid ColumnDefinitions="*,*" Padding="0,2,0,0">
                        <BoxView HeightRequest="1" Color="{DynamicResource DividerColor}" Grid.ColumnSpan="2" />
                        <Label Grid.Column="0" Text="设备剩余空间" FontSize="12" TextColor="{DynamicResource TextHintColor}"
                               VerticalOptions="Center" Margin="0,12,0,0" />
                        <Label Grid.Column="1" Text="{Binding FreeSpaceText}" FontSize="12" FontAttributes="Bold"
                               TextColor="{DynamicResource TextSecondaryColor}" VerticalOptions="Center" HorizontalOptions="End" Margin="0,12,0,0" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- 最近添加 -->
            <Border Margin="0,18,0,0" Padding="16" StrokeShape="RoundRectangle 22" StrokeThickness="1"
                    Stroke="{DynamicResource GlassStrokeColor}" BackgroundColor="{DynamicResource CardBackgroundColor}">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="最近添加" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" />
                            <Border StrokeShape="RoundRectangle 999" StrokeThickness="1"
                                    Stroke="{DynamicResource BadgeStrokeColor}"
                                    BackgroundColor="{DynamicResource BadgeBackgroundColor}"
                                    Padding="8,2" VerticalOptions="Center">
                                <Label Text="本周" FontSize="10" TextColor="{DynamicResource AccentColor}" />
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout x:Name="RecentAddContainer" Spacing="12" />
                    </ScrollView>
                </VerticalStackLayout>
            </Border>

            <controls:AppPopup x:Name="DiscoverSourcePopup" Title="发现页来源" CloseOnMaskTapped="True" />
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
