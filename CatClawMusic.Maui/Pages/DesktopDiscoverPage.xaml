<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:models="clr-namespace:CatClawMusic.Maui.ViewModels"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.DesktopDiscoverPage"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid>
        <VerticalStackLayout x:Name="RootStack" Padding="26,22,26,26" Spacing="0">

            <!-- ═══ Page Head: 发现 + 问候 + AI 开关 + 主题按钮 ═══ -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,0,0,4">
                <VerticalStackLayout VerticalOptions="Center" Spacing="3">
                    <Label Text="发现" FontSize="30" FontFamily="OpenSansSemibold" TextColor="{DynamicResource TextPrimaryColor}" />
                    <Label Text="{Binding GreetingText}" FontSize="13" TextColor="{DynamicResource TextSecondaryColor}" />
                </VerticalStackLayout>
                <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="10">
                    <Border StrokeShape="RoundRectangle 999" StrokeThickness="1" Stroke="{DynamicResource GlassStrokeColor}"
                            BackgroundColor="{DynamicResource CardBackgroundColor}" Padding="12,8">
                        <HorizontalStackLayout Spacing="9" VerticalOptions="Center">
                            <Label Text="智能推荐" FontSize="13" TextColor="{DynamicResource TextSecondaryColor}" VerticalOptions="Center" />
                            <Border BackgroundColor="{DynamicResource PrimaryColor}" StrokeThickness="0" StrokeShape="RoundRectangle 999" WidthRequest="26" HeightRequest="26">
                                <Label Text="AI" FontSize="10" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Switch IsToggled="{Binding IsAiRecommendationEnabled}" VerticalOptions="Center" OnColor="{DynamicResource PrimaryColor}" Scale="0.85" />
                        </HorizontalStackLayout>
                    </Border>
                    <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="1" Stroke="{DynamicResource GlassStrokeColor}"
                            BackgroundColor="{DynamicResource CardBackgroundColor}" VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSearchToggleClicked" />
                        </Border.GestureRecognizers>
                        <Image WidthRequest="16" HeightRequest="16" HorizontalOptions="Center" VerticalOptions="Center">
                            <Image.Source>
                                <AppThemeBinding Light="ic_search_light" Dark="ic_search" />
                            </Image.Source>
                        </Image>
                    </Border>
                    <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="1" Stroke="{DynamicResource GlassStrokeColor}"
                            BackgroundColor="{DynamicResource CardBackgroundColor}" VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRefreshClicked" />
                        </Border.GestureRecognizers>
                        <Image WidthRequest="16" HeightRequest="16" HorizontalOptions="Center" VerticalOptions="Center">
                            <Image.Source>
                                <AppThemeBinding Light="ic_refresh_light" Dark="ic_refresh" />
                            </Image.Source>
                        </Image>
                    </Border>
                    <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="1" Stroke="{DynamicResource GlassStrokeColor}"
                            BackgroundColor="{DynamicResource CardBackgroundColor}" VerticalOptions="Center">
                        <Label x:Name="ThemeIcon" Text="&#x1f319;" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnThemeToggleClicked" />
                        </Border.GestureRecognizers>
                    </Border>
                </HorizontalStackLayout>
            </Grid>

            <!-- 搜索框 -->
            <Border x:Name="SearchBoxContainer" Margin="0,0,0,0" Style="{StaticResource GlassInputStyle}" IsVisible="{Binding IsSearchOpen}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Image Source="ic_search" WidthRequest="18" HeightRequest="18" Opacity="0.9" VerticalOptions="Center" />
                    <Entry Grid.Column="1" x:Name="SearchBox" Text="{Binding SearchQuery, Mode=TwoWay}" Placeholder="搜索歌曲、歌手、专辑..." ReturnType="Search" TextChanged="OnSearchTextChanged" Completed="OnSearchCompleted" />
                    <ImageButton Grid.Column="2" Source="ic_close" WidthRequest="24" HeightRequest="24" BackgroundColor="Transparent" IsVisible="{Binding ShowSearchResults}" Clicked="OnClearSearchClicked" />
                </Grid>
            </Border>

            <!-- 搜索结果下拉 -->
            <Border Margin="0,4,0,10" Padding="0" StrokeShape="RoundRectangle 18" StrokeThickness="1" Stroke="{DynamicResource GlassStrokeColor}" BackgroundColor="{DynamicResource CardBackgroundStrongColor}" IsVisible="{Binding ShowSearchResults}">
                <ScrollView MaximumHeightRequest="380">
                    <VerticalStackLayout Spacing="0">
                        <VerticalStackLayout IsVisible="{Binding SearchArtistResults.Count, Converter={StaticResource CountToBoolConverter}}">
                            <Label Text="歌手" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource TextHintColor}" CharacterSpacing="2" Padding="16,12,16,4" />
                            <CollectionView ItemsSource="{Binding SearchArtistResults}" SelectionMode="Single" SelectionChanged="OnSearchArtistSelected" ItemsUpdatingScrollMode="KeepItemsInView" HeightRequest="{Binding SearchArtistResults.Count, Converter={StaticResource SearchSectionHeightConverter}}">
                                <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="14,8" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                            <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                                <Image Source="{Binding CoverSource}" Aspect="AspectFill" WidthRequest="36" HeightRequest="36" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                                <Label Text="{Binding Name}" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{DynamicResource TextPrimaryColor}" MaxLines="1" />
                                                <Label Text="{Binding Subtitle}" FontSize="11" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                        <VerticalStackLayout IsVisible="{Binding SearchAlbumResults.Count, Converter={StaticResource CountToBoolConverter}}">
                            <BoxView HeightRequest="1" BackgroundColor="{DynamicResource DividerColor}" Margin="16,4" />
                            <Label Text="专辑" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource TextHintColor}" CharacterSpacing="2" Padding="16,8,16,4" />
                            <CollectionView ItemsSource="{Binding SearchAlbumResults}" SelectionMode="Single" SelectionChanged="OnSearchAlbumSelected" ItemsUpdatingScrollMode="KeepItemsInView" HeightRequest="{Binding SearchAlbumResults.Count, Converter={StaticResource SearchSectionHeightConverter}}">
                                <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="14,8" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                            <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                                <Image Source="{Binding CoverSource}" Aspect="AspectFill" WidthRequest="36" HeightRequest="36" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                                <Label Text="{Binding Title}" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{DynamicResource TextPrimaryColor}" MaxLines="1" />
                                                <Label Text="{Binding ArtistName}" FontSize="11" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                        <VerticalStackLayout IsVisible="{Binding SearchResults.Count, Converter={StaticResource CountToBoolConverter}}">
                            <BoxView HeightRequest="1" BackgroundColor="{DynamicResource DividerColor}" Margin="16,4" />
                            <Label Text="歌曲" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource TextHintColor}" CharacterSpacing="2" Padding="16,8,16,4" />
                            <CollectionView ItemsSource="{Binding SearchResults}" SelectionMode="Single" SelectionChanged="OnSearchSongSelected" ItemsUpdatingScrollMode="KeepItemsInView" HeightRequest="{Binding SearchResults.Count, Converter={StaticResource SearchSectionHeightConverter}}">
                                <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="14,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                                <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}" Aspect="AspectFill" WidthRequest="36" HeightRequest="36" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                                <Label Text="{Binding Title}" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{DynamicResource TextPrimaryColor}" MaxLines="1" />
                                                <Label Text="{Binding Artist}" FontSize="11" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                            </VerticalStackLayout>
                                            <ImageButton Source="ic_play" WidthRequest="28" HeightRequest="28" BackgroundColor="Transparent" Clicked="OnSearchSongPlayTapped" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                        <VerticalStackLayout IsVisible="{Binding HasNoSearchResults}">
                            <Label Text="没找到想要的？问问 Yuki 吧" FontSize="13" TextColor="{DynamicResource TextSecondaryColor}" Padding="16,16" HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAiEntryTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>

            <!-- ═══ Segmented Tabs ═══ -->
            <Grid x:Name="CategoryTabBar" ColumnDefinitions="*,*,*,*" ColumnSpacing="8" Margin="0,16,0,16">
                <Border Grid.Column="0" x:Name="TabRec" Style="{StaticResource GlassCardStyle}" Padding="12,10" Stroke="{DynamicResource GlassStrokeColor}">
                    <Label x:Name="TabRecLabel" Text="推荐" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="0" /></Border.GestureRecognizers>
                </Border>
                <Border Grid.Column="1" x:Name="TabRank" Style="{StaticResource GlassCardStyle}" Padding="12,10" Stroke="{DynamicResource GlassStrokeColor}">
                    <Label x:Name="TabRankLabel" Text="排行榜" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="1" /></Border.GestureRecognizers>
                </Border>
                <Border Grid.Column="2" x:Name="TabArtist" Style="{StaticResource GlassCardStyle}" Padding="12,10" Stroke="{DynamicResource GlassStrokeColor}">
                    <Label x:Name="TabArtistLabel" Text="歌手" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="2" /></Border.GestureRecognizers>
                </Border>
                <Border Grid.Column="3" x:Name="TabAlbum" Style="{StaticResource GlassCardStyle}" Padding="12,10" Stroke="{DynamicResource GlassStrokeColor}">
                    <Label x:Name="TabAlbumLabel" Text="推荐专辑" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="3" /></Border.GestureRecognizers>
                </Border>
            </Grid>

            <!-- ═══ 推荐面板 ═══ -->
            <VerticalStackLayout x:Name="PanelRecommend" IsVisible="{Binding CurrentCategory, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}" Spacing="0">

                <!-- Hero 横向多卡轮播 -->
                <Grid x:Name="HeroWrap" Margin="0,0,0,6">
                    <ScrollView x:Name="HeroScroll" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Scrolled="OnHeroScrolled">
                        <HorizontalStackLayout x:Name="HeroTrack" Spacing="18" Padding="2,2,2,2"
                                               BindableLayout.ItemsSource="{Binding HeroCards}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border HeightRequest="168" StrokeThickness="0" StrokeShape="RoundRectangle 18">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnHeroCardTapped" />
                                        </Border.GestureRecognizers>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="{Binding GradientStart}" Offset="0" />
                                                <GradientStop Color="{Binding GradientEnd}" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid Padding="18">
                                            <VerticalStackLayout VerticalOptions="Start" Spacing="6">
                                                <Border Padding="9,3" StrokeThickness="0" StrokeShape="RoundRectangle 999" BackgroundColor="#30FFFFFF" HorizontalOptions="Start">
                                                    <Label Text="{Binding Tag}" FontSize="10" FontAttributes="Bold" TextColor="White" />
                                                </Border>
                                                <Label Text="{Binding Title}" FontSize="20" FontFamily="OpenSansSemibold" TextColor="White" MaxLines="2" Margin="0,4,72,0" />
                                                <Label Text="{Binding Description}" FontSize="12" TextColor="#CCFFFFFF" MaxLines="2" Margin="0,2,72,0" />
                                            </VerticalStackLayout>
                                            <Border WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 24" BackgroundColor="#50FFFFFF" HorizontalOptions="End" VerticalOptions="End">
                                                <ImageButton Source="{Binding PlayIcon}" WidthRequest="22" HeightRequest="22" BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" Aspect="AspectFit" Clicked="OnHeroPlayTapped" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                    <ImageButton x:Name="HeroPrev" WidthRequest="30" HeightRequest="30"
                                 BackgroundColor="#1A000000" CornerRadius="15" Padding="6" Aspect="AspectFit"
                                 HorizontalOptions="Start" VerticalOptions="Center" Margin="6,0,0,0" Clicked="OnHeroPrevClicked" />
                    <ImageButton x:Name="HeroNext" WidthRequest="30" HeightRequest="30"
                                 BackgroundColor="#1A000000" CornerRadius="15" Padding="6" Aspect="AspectFit"
                                 HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,6,0" Clicked="OnHeroNextClicked" />
                </Grid>
                <IndicatorView x:Name="HeroDots" Margin="0,4,0,18"
                              IndicatorColor="{DynamicResource TextHintColor}" SelectedIndicatorColor="{DynamicResource PrimaryColor}"
                              IndicatorsShape="Circle" HorizontalOptions="Center" />

                <!-- AI 助手入口卡：位于轮播卡片下方，点击进入 AI 聊天模式 -->
                <Border x:Name="AiEntryCard"
                        Margin="0,0,0,16"
                        Padding="16,14"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAiEntryTapped" />
                    </Border.GestureRecognizers>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#667eea" Offset="0" />
                            <GradientStop Color="#764ba2" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border WidthRequest="42" HeightRequest="42" StrokeShape="RoundRectangle 21" StrokeThickness="0" Padding="0">
                            <Image Source="avatar_yuki.png" Aspect="AspectFill" WidthRequest="42" HeightRequest="42" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="🐾 和 Yuki 聊聊" FontSize="15" FontAttributes="Bold" TextColor="White" />
                            <Label Text="帮你找歌、推荐、聊天都可以" FontSize="11" TextColor="#CCFFFFFF" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22" TextColor="#CCFFFFFF" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- 每日推荐横滑（左右箭头导航） -->
                <Grid Margin="0,4,0,8" ColumnDefinitions="*,Auto">
                    <Label Text="每日推荐" Style="{StaticResource SectionTitleStyle}" />
                    <Button Grid.Column="1" Text="换一批 ↻" FontSize="12" HeightRequest="34" CornerRadius="16"
                            BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}" Padding="8,0" Clicked="OnShuffleDailyClicked" />
                </Grid>
                <Grid x:Name="DailyWrap">
                    <CollectionView x:Name="DailyList" Margin="0,0,40,16" HeightRequest="206"
                                    ItemsSource="{Binding DailyRecommendSongs}" SelectionMode="Single"
                                    SelectionChanged="OnDailySongSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                        <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                        <CollectionView.ItemsLayout><LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" /></CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border WidthRequest="150" StrokeShape="RoundRectangle 18" StrokeThickness="1" Stroke="{DynamicResource GlassStrokeColor}" BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
                                    <VerticalStackLayout Spacing="0">
                                        <Border WidthRequest="150" HeightRequest="150" StrokeShape="RoundRectangle 18 18 0 0" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                            <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}" Aspect="AspectFill" WidthRequest="150" HeightRequest="150" />
                                        </Border>
                                        <VerticalStackLayout Padding="10,8,10,10" Spacing="3">
                                            <Label Text="{Binding Title}" FontSize="12.5" FontFamily="OpenSansSemibold" TextColor="{DynamicResource TextPrimaryColor}" MaxLines="1" />
                                            <Label Text="{Binding Artist}" FontSize="10.5" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <ImageButton x:Name="DailyPrev" WidthRequest="30" HeightRequest="30"
                                 BackgroundColor="#1A000000" CornerRadius="15" Padding="6" Aspect="AspectFit"
                                 HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,4,0" Clicked="OnDailyPrevClicked" />
                    <ImageButton x:Name="DailyNext" WidthRequest="30" HeightRequest="30"
                                 BackgroundColor="#1A000000" CornerRadius="15" Padding="6" Aspect="AspectFit"
                                 HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,4,0" Clicked="OnDailyNextClicked" IsVisible="False" />
                </Grid>

                <!-- 推荐艺人横滑（左右箭头导航） -->
                <Grid Margin="0,4,0,8" ColumnDefinitions="*,Auto">
                    <Label Text="推荐艺人" Style="{StaticResource SectionTitleStyle}" />
                    <Button Grid.Column="1" Text="查看全部 ›" FontSize="12" HeightRequest="34" CornerRadius="16"
                            BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}" Padding="8,0" Clicked="OnArtistsViewAllClicked" />
                </Grid>
                <Grid x:Name="ArtistsWrap">
                    <CollectionView x:Name="ArtistsRow" Margin="0,0,40,16" HeightRequest="142"
                                    ItemsSource="{Binding Artists}" SelectionMode="Single"
                                    SelectionChanged="OnArtistSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                        <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                        <CollectionView.ItemsLayout><LinearItemsLayout Orientation="Horizontal" ItemSpacing="14" /></CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout WidthRequest="92" Spacing="6">
                                    <Border WidthRequest="84" HeightRequest="84" StrokeShape="RoundRectangle 42" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}" HorizontalOptions="Center">
                                        <Image Source="{Binding CoverSource}" Aspect="AspectFill" WidthRequest="84" HeightRequest="84" />
                                    </Border>
                                    <Label Text="{Binding Name}" FontSize="13" FontFamily="OpenSansSemibold" HorizontalOptions="Center" MaxLines="1" />
                                    <Label Text="{Binding Subtitle}" FontSize="11" TextColor="{DynamicResource TextHintColor}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <ImageButton x:Name="ArtistPrev" WidthRequest="30" HeightRequest="30"
                                 BackgroundColor="#1A000000" CornerRadius="15" Padding="6" Aspect="AspectFit"
                                 HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,4,0" Clicked="OnArtistPrevClicked" />
                    <ImageButton x:Name="ArtistNext" WidthRequest="30" HeightRequest="30"
                                 BackgroundColor="#1A000000" CornerRadius="15" Padding="6" Aspect="AspectFit"
                                 HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,4,0" Clicked="OnArtistNextClicked" IsVisible="False" />
                </Grid>
            </VerticalStackLayout>

            <!-- ═══ 排行榜面板（双列） ═══ -->
            <Grid x:Name="PanelRank" IsVisible="{Binding CurrentCategory, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}"
                  ColumnDefinitions="1*,1*" ColumnSpacing="22">
                <VerticalStackLayout Grid.Column="0" Spacing="0">
                    <Label Text="最多播放" Style="{StaticResource SectionTitleStyle}" Margin="0,4,0,10" />
                    <CollectionView x:Name="TopPlayedList" ItemsSource="{Binding TopPlayedSongs}" SelectionMode="Single"
                                    SelectionChanged="OnTopPlayedSongSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                        <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GlassCardStyle}" Padding="12" Margin="0,0,0,8" BindingContextChanged="OnRankItemBindingContextChanged">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnRankItemTapped" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
                                        <Label x:Name="RankLabel" Text="" WidthRequest="26" FontSize="15" FontAttributes="Bold" VerticalOptions="Center" HorizontalTextAlignment="Center" />
                                        <Border WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                            <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}" Aspect="AspectFill" WidthRequest="50" HeightRequest="50" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding Title}" FontSize="14" FontFamily="OpenSansSemibold" MaxLines="1" />
                                            <Label Text="{Binding Artist}" FontSize="11" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                        </VerticalStackLayout>
                                        <Grid Grid.Column="3" VerticalOptions="Center" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Label Text="{Binding PlayCount, StringFormat='{0} 次'}" FontSize="10" TextColor="{DynamicResource TextHintColor}" VerticalOptions="Center"
                                                   IsVisible="{Binding PlayCount, Converter={StaticResource CountToBoolConverter}}" />
                                            <Border WidthRequest="34" HeightRequest="34" StrokeShape="RoundRectangle 17" BackgroundColor="{DynamicResource PrimaryColor}" VerticalOptions="Center">
                                                <ImageButton Source="ic_play" WidthRequest="16" HeightRequest="16" BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" Clicked="OnRankPlayTapped" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="0">
                    <Label Text="我的最爱 ★" Style="{StaticResource SectionTitleStyle}" Margin="0,4,0,10" />
                    <CollectionView x:Name="FavoriteList" ItemsSource="{Binding FavoriteSongs}" SelectionMode="Single"
                                    SelectionChanged="OnFavoriteSongSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                        <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GlassCardStyle}" Padding="12" Margin="0,0,0,8">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnFavItemTapped" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
                                        <Label Text="★" WidthRequest="26" FontSize="16" FontAttributes="Bold" TextColor="#FFD700" VerticalOptions="Center" HorizontalTextAlignment="Center" />
                                        <Border WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                            <Image Source="{Binding CoverArtPath, TargetNullValue='ic_music_note'}" Aspect="AspectFill" WidthRequest="50" HeightRequest="50" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding Title}" FontSize="14" FontFamily="OpenSansSemibold" MaxLines="1" />
                                            <Label Text="{Binding Artist}" FontSize="11" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                                        </VerticalStackLayout>
                                        <Grid Grid.Column="3" VerticalOptions="Center" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Label Text="已收藏" FontSize="10" TextColor="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                                            <Border WidthRequest="34" HeightRequest="34" StrokeShape="RoundRectangle 17" BackgroundColor="{DynamicResource PrimaryColor}" VerticalOptions="Center">
                                                <ImageButton Source="ic_play" WidthRequest="16" HeightRequest="16" BackgroundColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" Clicked="OnFavPlayTapped" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Grid>

            <!-- ═══ 歌手网格面板 ═══ -->
            <VerticalStackLayout x:Name="PanelArtist" IsVisible="{Binding CurrentCategory, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}" Spacing="0">
                <Grid Margin="0,4,0,8" ColumnDefinitions="*,Auto">
                    <Label Text="推荐歌手" Style="{StaticResource SectionTitleStyle}" />
                    <Button Grid.Column="1" Text="查看全部 ›" FontSize="12" HeightRequest="34" CornerRadius="16"
                            BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}" Padding="8,0" Clicked="OnArtistsViewAllClicked" />
                </Grid>
                <CollectionView x:Name="ArtistGrid" ItemsSource="{Binding Artists}" SelectionMode="Single"
                                SelectionChanged="OnArtistSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                    <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                    <CollectionView.ItemsLayout><GridItemsLayout Orientation="Vertical" Span="8" VerticalItemSpacing="14" HorizontalItemSpacing="12" /></CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border WidthRequest="84" HeightRequest="84" StrokeShape="RoundRectangle 42" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}" HorizontalOptions="Center">
                                    <Image Source="{Binding CoverSource}" Aspect="AspectFill" WidthRequest="84" HeightRequest="84" />
                                </Border>
                                <Label Text="{Binding Name}" FontSize="13" FontFamily="OpenSansSemibold" HorizontalOptions="Center" MaxLines="1" />
                                <Label Text="{Binding Subtitle}" FontSize="11" TextColor="{DynamicResource TextHintColor}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- ═══ 推荐专辑网格面板 ═══ -->
            <VerticalStackLayout x:Name="PanelAlbum" IsVisible="{Binding CurrentCategory, Converter={StaticResource IntToBoolConverter}, ConverterParameter=3}" Spacing="0">
                <Grid Margin="0,4,0,4">
                    <Label Text="推荐专辑" Style="{StaticResource SectionTitleStyle}" />
                </Grid>
                <Label Text="从你的曲库里随机挑出的专辑 · 帮你重新发现" FontSize="11.5" TextColor="{DynamicResource TextHintColor}" Margin="0,0,0,10" />
                <CollectionView x:Name="AlbumGrid" ItemsSource="{Binding Albums}" SelectionMode="Single"
                                SelectionChanged="OnAlbumSelected" ItemsUpdatingScrollMode="KeepItemsInView">
                    <CollectionView.Behaviors><controls:ScrollPerformanceBehavior /></CollectionView.Behaviors>
                    <CollectionView.ItemsLayout><GridItemsLayout Orientation="Vertical" Span="6" VerticalItemSpacing="14" HorizontalItemSpacing="12" /></CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Spacing="6">
                                <Border StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceColor}">
                                    <Image Source="{Binding CoverSource, TargetNullValue='ic_music_note'}" Aspect="AspectFill" HeightRequest="156" />
                                </Border>
                                <Label Text="{Binding Title}" FontSize="13.5" FontFamily="OpenSansSemibold" MaxLines="1" />
                                <Label Text="{Binding ArtistName}" FontSize="11.5" TextColor="{DynamicResource TextSecondaryColor}" MaxLines="1" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <ActivityIndicator Margin="0,10" IsVisible="{Binding IsLoading}" IsRunning="{Binding IsLoading}" Color="{DynamicResource PrimaryColor}" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Chat Overlay: AI 聊天覆盖层 -->
        <Grid x:Name="ChatOverlay"
              IsVisible="{Binding IsChatMode}"
              Background="{DynamicResource PageBackgroundBrush}"
              RowDefinitions="Auto,*,Auto,Auto">

            <Grid Grid.Row="0" Margin="0,10,0,6" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <controls:BackButton x:Name="ChatBackButton"
                                     VerticalOptions="Center"
                                     Clicked="OnChatBackClicked" />
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="{Binding AgentName}" FontSize="18" FontFamily="OpenSansSemibold" TextColor="{DynamicResource TextPrimaryColor}" />
                    <Label Text="你的 AI 音乐助手" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}" />
                </VerticalStackLayout>
                <Border Grid.Column="2" Padding="4" StrokeThickness="0" StrokeShape="RoundRectangle 20"
                        BackgroundColor="{DynamicResource CardBackgroundStrongColor}" VerticalOptions="Center">
                    <Image Source="avatar_yuki.png" WidthRequest="34" HeightRequest="34" />
                </Border>
            </Grid>

            <CollectionView x:Name="ChatMessagesList" Grid.Row="1" Margin="0,0,0,0"
                            ItemsSource="{Binding ChatMessages}"
                            SelectionMode="None"
                            ItemsUpdatingScrollMode="KeepLastItemInView"
                            Scrolled="OnChatMessagesScrolled">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="2,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <!-- Yuki 头像（左）：assistant 消息显示 -->
                            <Border Grid.Column="0" WidthRequest="36" HeightRequest="36" StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                    IsVisible="{Binding Role, Converter={StaticResource IsAssistantConverter}}"
                                    VerticalOptions="Start" Margin="0,2,0,0">
                                <Image Source="avatar_yuki.png" Aspect="AspectFill" WidthRequest="36" HeightRequest="36" />
                            </Border>

                            <!-- 占位（对方消息时空，自己消息时让气泡靠右） -->
                            <BoxView Grid.Column="0" WidthRequest="36" IsVisible="{Binding Role, Converter={StaticResource IsUserConverter}}" Color="Transparent" />

                            <!-- 消息气泡：位于中间列，根据角色左/右对齐 -->
                            <Border Grid.Column="1" Padding="14,10" StrokeThickness="0" MaximumWidthRequest="280" StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{Binding Role, Converter={StaticResource ChatBubbleColorConverter}}"
                                    HorizontalOptions="{Binding Role, Converter={StaticResource ChatBubbleAlignmentConverter}}"
                                    VerticalOptions="Start">
                                <Label Text="{Binding Content}" FontSize="14" TextColor="White" LineBreakMode="WordWrap" />
                            </Border>

                            <!-- 占位（自己消息时空，对方消息时让气泡靠左） -->
                            <BoxView Grid.Column="2" WidthRequest="36" IsVisible="{Binding Role, Converter={StaticResource IsAssistantConverter}}" Color="Transparent" />

                            <!-- 用户头像（右）：user 消息显示 -->
                            <Border Grid.Column="2" WidthRequest="36" HeightRequest="36" StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    IsVisible="{Binding Role, Converter={StaticResource IsUserConverter}}"
                                    VerticalOptions="Start" Margin="0,2,0,0">
                                <Label Text="👤" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border Grid.Row="2" Margin="0,4,0,0" Padding="14,10" StrokeThickness="1" Stroke="{DynamicResource GlassStrokeColor}"
                    StrokeShape="RoundRectangle 14" BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                    IsVisible="{Binding HasThinkingSteps}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleThinkingCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <ActivityIndicator Grid.Column="0" IsRunning="{Binding IsAgentThinking}" IsVisible="{Binding IsAgentThinking}"
                                       Color="{DynamicResource PrimaryColor}" WidthRequest="16" HeightRequest="16" />
                    <Label Grid.Column="0" Text="✓" FontSize="14" TextColor="{DynamicResource PrimaryColor}"
                           IsVisible="{Binding IsAgentThinking, Converter={StaticResource InvertedBoolConverter}}"
                           VerticalOptions="Center" WidthRequest="16" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="1" Text="{Binding ThinkingSummary}" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}"
                           VerticalOptions="Center" LineBreakMode="TailTruncation" />
                </Grid>
            </Border>

            <Border Grid.Row="3" Margin="0,10,0,14" Style="{StaticResource GlassInputStyle}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Entry x:Name="ChatInputBox" Text="{Binding ChatInput, Mode=TwoWay}"
                           Placeholder="输入消息..." ReturnType="Send" Completed="OnChatInputCompleted" />
                    <Border Grid.Column="1" Style="{StaticResource GlassIconContainerStyle}" BackgroundColor="{DynamicResource ChipActiveColor}">
                        <ImageButton Source="ic_send" WidthRequest="40" HeightRequest="40" BackgroundColor="Transparent" Padding="9" Clicked="OnSendClicked" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
