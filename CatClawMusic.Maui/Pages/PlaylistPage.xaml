<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.PlaylistPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabPlaylists]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid Background="{DynamicResource PageBackgroundBrush}">

        <Grid RowDefinitions="Auto,Auto,*">

            <!-- Header -->
            <Grid Grid.Row="0" Margin="16,16,16,10"
                  ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabPlaylists]}"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalOptions="Center" />
                <Border Grid.Column="1"
                        Style="{StaticResource GlassIconContainerStyle}"
                        VerticalOptions="Center">
                    <ImageButton Source="ic_add"
                                 WidthRequest="40" HeightRequest="40"
                                 BackgroundColor="Transparent"
                                 Clicked="OnCreatePlaylistClicked" />
                </Border>
            </Grid>

            <!-- Status -->
            <Label Grid.Row="1"
                   Text="{Binding StatusText}"
                   FontSize="12"
                   TextColor="{DynamicResource TextHintColor}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,6"
                   IsVisible="{Binding IsLoading}" />

            <!-- Playlist List -->
            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding Playlists}"
                            SelectionMode="Single"
                            SelectionChanged="OnPlaylistSelected"
                            Margin="0,0,0,8">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="16,0,16,10"
                                Padding="14"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="1"
                                Stroke="{DynamicResource GlassStrokeColor}"
                                BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="14">
                                <Border Grid.Column="0"
                                        WidthRequest="60" HeightRequest="60"
                                        StrokeShape="RoundRectangle 16"
                                        StrokeThickness="0"
                                        BackgroundColor="{DynamicResource SurfaceColor}">
                                    <Grid>
                                        <Image Source="{Binding CoverPath}"
                                               Aspect="AspectFill"
                                               WidthRequest="60" HeightRequest="60"
                                               IsVisible="{Binding CoverPath, Converter={StaticResource StringToBoolConverter}}" />
                                        <Label Text="{Binding Name, Converter={StaticResource PlaylistIconConverter}}"
                                               FontSize="24"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding CoverPath, Converter={StaticResource InvertedStringToBoolConverter}}" />
                                    </Grid>
                                </Border>
                                <VerticalStackLayout Grid.Column="1"
                                                     VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="16"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{DynamicResource TextPrimaryColor}"
                                           MaxLines="1" />
                                    <Label Text="{Binding SongCount, StringFormat='{0} 首歌曲'}"
                                           FontSize="12"
                                           TextColor="{DynamicResource TextHintColor}" />
                                </VerticalStackLayout>
                                <ImageButton Grid.Column="2"
                                             Source="ic_menu"
                                             WidthRequest="34" HeightRequest="34"
                                             BackgroundColor="Transparent"
                                             Padding="6"
                                             VerticalOptions="Center"
                                             IsVisible="{Binding IsSystem, Converter={StaticResource InvertedBoolConverter}}"
                                             Clicked="OnPlaylistMenuClicked" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
