<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             x:Class="CatClawMusic.Maui.Pages.PlaylistPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabPlaylists]}"
             BackgroundColor="Transparent">

    <Grid Background="Transparent">

        <Grid RowDefinitions="Auto,Auto,*">

            <!-- Hero Card（与其他页面样式一致） -->
            <Border Grid.Row="0"
                    Margin="16,16,16,8"
                    Style="{StaticResource GlassCardStrongStyle}"
                    Background="{DynamicResource HeroBrush}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabPlaylists]}"
                               Style="{StaticResource PageTitleStyle}"
                               TextColor="White" />
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PlaylistSubtitle]}"
                               Style="{StaticResource PageSubtitleStyle}"
                               TextColor="#F2F4FF" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            Style="{StaticResource GlassIconContainerStyle}"
                            BackgroundColor="#26FFFFFF"
                            Stroke="{DynamicResource GlassStrokeColor}"
                            VerticalOptions="Start">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCreatePlaylistClicked" />
                        </Border.GestureRecognizers>
                        <Image Source="ic_add"
                               WidthRequest="22" HeightRequest="22"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- Status -->
            <Label Grid.Row="1"
                   Text="{Binding StatusText}"
                   FontSize="12"
                   TextColor="{DynamicResource TextHintColor}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,6"
                   IsVisible="{Binding IsLoading}" />

            <!-- Playlist List -->
            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding Playlists}"
                            SelectionMode="Single"
                            SelectionChanged="OnPlaylistSelected"
                            Margin="0,0,0,8">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="16,0,16,10"
                                Padding="14"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="1"
                                Stroke="{DynamicResource GlassStrokeColor}"
                                BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="14">
                                <Border Grid.Column="0"
                                        WidthRequest="60" HeightRequest="60"
                                        StrokeShape="RoundRectangle 16"
                                        StrokeThickness="0"
                                        BackgroundColor="{DynamicResource SurfaceColor}">
                                    <Grid>
                                        <Image Source="{Binding CoverPath}"
                                               Aspect="AspectFill"
                                               WidthRequest="60" HeightRequest="60"
                                               IsVisible="{Binding CoverPath, Converter={StaticResource StringToBoolConverter}}" />
                                        <Label Text="{Binding Name, Converter={StaticResource PlaylistIconConverter}}"
                                               FontSize="24"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding CoverPath, Converter={StaticResource InvertedStringToBoolConverter}}" />
                                    </Grid>
                                </Border>
                                <VerticalStackLayout Grid.Column="1"
                                                     VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="16"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{DynamicResource TextPrimaryColor}"
                                           MaxLines="1" />
                                    <Label Text="{Binding SongCount, StringFormat='{0} 首歌曲'}"
                                           FontSize="12"
                                           TextColor="{DynamicResource TextHintColor}" />
                                </VerticalStackLayout>
                                <ImageButton Grid.Column="2"
                                             Source="ic_menu"
                                             WidthRequest="34" HeightRequest="34"
                                             BackgroundColor="Transparent"
                                             Padding="6"
                                             VerticalOptions="Center"
                                             IsVisible="{Binding IsSystem, Converter={StaticResource InvertedBoolConverter}}"
                                             Clicked="OnPlaylistMenuClicked" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- 新建歌单输入弹窗（替代 DisplayPromptAsync，避免 MAUI 11 兼容性问题） -->
        <controls:AppPopup x:Name="CreatePlaylistPopup"
                           Title="新建歌单"
                           CloseOnMaskTapped="True" />
    </Grid>
</ContentPage>
