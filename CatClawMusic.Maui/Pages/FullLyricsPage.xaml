<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             x:Class="CatClawMusic.Maui.Pages.FullLyricsPage"
             Title="全屏歌词"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid>
        <!-- 雾面动态背景层（铺满整个页面，参数与播放页保持一致） -->
        <controls:FrostedBackground x:Name="FrostedBg"
                                    Source="{Binding CoverImage}"
                                    CacheKey="{Binding CurrentCoverPath}"
                                    IsActive="{Binding IsPlaying}"
                                    IsVisible="{DynamicResource FrostedBackgroundEnabled}"
                                    TintColor="{DynamicResource PrimaryColor}"
                                    TintOpacity="0.25"
                                    DimAmount="0.15"
                                    InputTransparent="True"
                                    Aspect="AspectFill" />

        <!-- 内容层 -->
        <Grid x:Name="ContentGrid" RowDefinitions="Auto,*">

        <Border Grid.Row="0"
                Margin="16,18,16,10"
                Style="{StaticResource GlassCardStrongStyle}"
                Background="{DynamicResource HeroBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12">
                <Border Grid.Column="0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        WidthRequest="40" HeightRequest="40"
                        VerticalOptions="Center">
                    <ImageButton Source="{Binding CoverImage}"
                                 Aspect="AspectFill"
                                 BackgroundColor="Transparent"
                                 CornerRadius="10"
                                 Clicked="OnBackClicked" />
                </Border>
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2"
                                     VerticalOptions="Center">
                    <Label Text="{Binding Title}"
                           FontSize="16"
                           FontFamily="OpenSansSemibold"
                           TextColor="{DynamicResource TextPrimaryColor}"
                           MaxLines="1" />
                    <Label Text="{Binding Artist}"
                           FontSize="12"
                           TextColor="{DynamicResource TextSecondaryColor}"
                           MaxLines="1" />
                </VerticalStackLayout>
                <Border Grid.Column="2"
                        Style="{StaticResource GlassBadgeStyle}"
                        VerticalOptions="Center">
                    <Label Text="LRC"
                           FontSize="10"
                           TextColor="{DynamicResource TextSecondaryColor}" />
                </Border>
            </Grid>
        </Border>

        <CollectionView Grid.Row="1"
                        x:Name="LyricCollectionView"
                        ItemsSource="{Binding LyricPlaceholderItems}"
                        SelectionMode="None"
                        VerticalScrollBarVisibility="Never">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" />
            </CollectionView.ItemsLayout>
            <CollectionView.Header>
                <VerticalStackLayout x:Name="LyricStack"
                                     Padding="24,100,24,300"
                                     Spacing="14" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <BoxView HeightRequest="0" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="1"
                Margin="20,0"
                VerticalOptions="End"
                Style="{StaticResource GlassBadgeStyle}"
                IsVisible="{Binding HasLyrics, Converter={StaticResource InvertedBoolConverter}}">
            <Label Text="{Binding NoLyricsText}"
                   FontSize="14"
                   TextColor="{DynamicResource TextSecondaryColor}"
                   HorizontalTextAlignment="Center" />
        </Border>
        </Grid>
    </Grid>
</ContentPage>
