<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.MusicFolderSettingsPage"
             x:Name="RootPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitleMusicFolderSettings]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid Background="{DynamicResource PageBackgroundBrush}">

        <ScrollView>
            <VerticalStackLayout Padding="16,18,16,22"
                                 Spacing="14">

                <Border Style="{StaticResource GlassCardStrongStyle}"
                        Background="{DynamicResource HeroBrush}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[MusicFolders]}"
                               Style="{StaticResource PageTitleStyle}"
                               TextColor="White" />
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[MusicFolderSettingsDesc]}"
                               Style="{StaticResource PageSubtitleStyle}"
                               TextColor="#F3F5FF" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FolderList]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />

                        <CollectionView ItemsSource="{Binding MusicFolders}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto"
                                          Padding="0,8">
                                        <Label Grid.Column="0"
                                               Text="{Binding .}"
                                               FontSize="14"
                                               TextColor="{DynamicResource TextPrimaryColor}"
                                               VerticalOptions="Center"
                                               LineBreakMode="TailTruncation" />
                                        <Button Grid.Column="1"
                                                Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Remove]}"
                                                Command="{Binding BindingContext.RemoveFolderCommand, Source={x:Reference RootPage}}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{DynamicResource ErrorColor}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                HeightRequest="30"
                                                WidthRequest="60"
                                                FontSize="12" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AddFolder]}"
                                Command="{Binding AddFolderCommand}"
                                BackgroundColor="{DynamicResource PrimaryColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="40"
                                FontSize="13"
                                Margin="0,8,0,0" />

                        <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ScanAllFolders]}"
                                Command="{Binding ScanAllFoldersCommand}"
                                BackgroundColor="{DynamicResource PrimaryColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="42"
                                FontSize="13"
                                FontAttributes="Bold"
                                IsVisible="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" />

                        <VerticalStackLayout Spacing="6"
                                             IsVisible="{Binding IsScanning}">
                            <ProgressBar Progress="{Binding ScanProgress}"
                                         ProgressColor="{DynamicResource PrimaryColor}" />
                            <Label Text="{Binding ScanStatus}"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextSecondaryColor}" />
                        </VerticalStackLayout>

                        <Label Text="{Binding TotalSongsImported, StringFormat='上次导入 {0} 首歌曲'}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}"
                               IsVisible="{Binding TotalSongsImported, Converter={StaticResource IntToBoolConverter}}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ScanOptions]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <CheckBox IsChecked="{Binding ScanSubfolders}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ScanSubfolders]}"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <CheckBox IsChecked="{Binding AutoScan}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoScan]}"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
            <controls:BackButton Margin="16,16,0,0"
                             VerticalOptions="Start"
                             HorizontalOptions="Start"
                             ZIndex="100" />
</Grid>
</ContentPage>
