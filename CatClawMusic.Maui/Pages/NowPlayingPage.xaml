<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.NowPlayingPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitleNowPlaying]}"
             BackgroundColor="Transparent"
             Shell.NavBarIsVisible="False">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid>
        <!-- 雾面动态背景层（铺满整个页面，覆盖状态栏和导航栏区域） -->
        <controls:FrostedBackground x:Name="FrostedBg"
                                    Source="{Binding CoverImage}"
                                    CacheKey="{Binding CurrentCoverPath}"
                                    IsActive="{Binding IsPlaying}"
                                    IsScrolling="{Binding IsUserScrolling}"
                                    IsVisible="{DynamicResource FrostedBackgroundEnabled}"
                                    TintColor="{DynamicResource PrimaryColor}"
                                    TintOpacity="0.25"
                                    DimAmount="0.15"
                                    InputTransparent="True"
                                    Aspect="AspectFill" />

        <!-- 暗色遮罩层：在雾面背景上叠加一层半透明暗色，确保文字可读 -->
        <BoxView Color="#70000000" InputTransparent="True" />

        <!-- 内容层：3行Grid - 返回按钮/Auto, 主体/Star, 进度+控件/Auto -->
        <Grid x:Name="RootGrid"
              RowDefinitions="Auto,*,Auto"
              Padding="24,16,24,20">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnPageTapped" />
            </Grid.GestureRecognizers>

            <!-- Row 0: 顶部导航栏（左上角收起按钮 + 歌曲信息 + 右上角窗口控件） -->
            <Grid x:Name="TopNavBar"
                  Grid.Row="0"
                  ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                  HeightRequest="40">
                <!-- 左上角收起按钮（向下箭头，点击收起播放页；Windows端同时承担返回功能） -->
                <Border Grid.Column="0"
                        x:Name="CollapseButton"
                        StrokeThickness="0"
                        BackgroundColor="Transparent"
                        WidthRequest="44" HeightRequest="44"
                        HorizontalOptions="Start" VerticalOptions="Center"
                        ZIndex="10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCollapseButtonTapped" />
                    </Border.GestureRecognizers>
                    <Image x:Name="CollapseIcon"
                           WidthRequest="22" HeightRequest="22"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <!-- 歌曲信息（收起按钮右侧） -->
                <Grid Grid.Column="1" ColumnDefinitions="Auto" VerticalOptions="Center">
                    <Grid Grid.Column="0" RowDefinitions="Auto,Auto" RowSpacing="0">
                        <Label Grid.Row="0"
                               Text="{Binding Title}"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               TextColor="White"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               HorizontalTextAlignment="Start" />
                        <Label Grid.Row="1"
                               Text="{Binding Artist}"
                               FontSize="11"
                               TextColor="{DynamicResource TextSecondaryColor}"
                               Opacity="0.9"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               HorizontalTextAlignment="Start" />
                    </Grid>
                </Grid>

                <!-- 右上角窗口控制按钮（仅 Windows 端显示） -->
                <!-- 最小化按钮 -->
                <Border Grid.Column="2"
                        IsVisible="{OnPlatform Default=false, WinUI=true}"
                        WidthRequest="46" HeightRequest="40"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        HorizontalOptions="End" VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMinimizeTapped" />
                    </Border.GestureRecognizers>
                    <Path WidthRequest="20" HeightRequest="20"
                          Data="M 4,10 L 16,10"
                          Stroke="White"
                          StrokeThickness="1.5"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>

                <!-- 最大化/还原按钮 -->
                <Border Grid.Column="3"
                        IsVisible="{OnPlatform Default=false, WinUI=true}"
                        WidthRequest="46" HeightRequest="40"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        HorizontalOptions="End" VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMaximizeTapped" />
                    </Border.GestureRecognizers>
                    <Grid>
                        <Path x:Name="MaximizeIcon"
                              WidthRequest="20" HeightRequest="20"
                              Data="M 3,3 L 17,3 L 17,17 L 3,17 Z"
                              Stroke="White"
                              StrokeThickness="1.5"
                              HorizontalOptions="Center"
                              VerticalOptions="Center"
                              IsVisible="true" />
                        <Path x:Name="RestoreIcon"
                              WidthRequest="20" HeightRequest="20"
                              Data="M 3,6 L 14,6 L 14,17 L 3,17 Z M 6,3 L 17,3 L 17,14 L 14,14 L 14,6 L 6,6 Z"
                              Stroke="White"
                              StrokeThickness="1.5"
                              HorizontalOptions="Center"
                              VerticalOptions="Center"
                              IsVisible="false" />
                    </Grid>
                </Border>

                <!-- 关闭按钮 -->
                <Border Grid.Column="4"
                        IsVisible="{OnPlatform Default=false, WinUI=true}"
                        WidthRequest="46" HeightRequest="40"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        HorizontalOptions="End" VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseTapped" />
                    </Border.GestureRecognizers>
                    <Path WidthRequest="20" HeightRequest="20"
                          Data="M 4,4 L 16,16 M 4,16 L 16,4"
                          Stroke="White"
                          StrokeThickness="1.5"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- Row 1: 主体内容 -->
            <!-- 2行3列 Grid：手机用上下布局(跨列)，桌面用左右布局(跨行) -->
            <Grid Grid.Row="1"
                  x:Name="MainContent"
                  RowDefinitions="Auto,*"
                  ColumnDefinitions="1*,Auto,1*"
                  Padding="0,8,0,4">

                <!-- 封面（位置由代码后台根据屏幕方向动态设置） -->
                <Grid Grid.Row="0"
                      Grid.Column="0"
                      Grid.RowSpan="1"
                      Grid.ColumnSpan="3"
                      x:Name="LeftHalf"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      Padding="0,0">
                    <!-- 封面容器：辉光投影层与封面本体层重叠，居中显示，整体下移 -->
                    <Grid HorizontalOptions="Center" VerticalOptions="Center"
                          TranslationY="16">
                        <!-- 封面辉光（模糊投影）- 底层 -->
                        <Border x:Name="CoverGlow"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 28"
                                BackgroundColor="Transparent"
                                WidthRequest="286"
                                HeightRequest="286"
                                Opacity="0.35"
                                Scale="1.08"
                                TranslationY="10"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        <!-- 封面本体 - 上层 -->
                        <Border x:Name="CoverArea"
                                StrokeThickness="0.5"
                                Stroke="#30FFFFFF"
                                StrokeShape="RoundRectangle 28"
                                BackgroundColor="Transparent"
                                WidthRequest="286"
                                HeightRequest="286"
                                HorizontalOptions="Center">
                            <Image x:Name="ArtworkImage"
                                   Source="{Binding CoverImage}"
                                   Aspect="AspectFill"
                                   WidthRequest="286"
                                   HeightRequest="286" />
                        </Border>
                    </Grid>
                </Grid>


                <Grid Grid.Row="1"
                      Grid.Column="0"
                      Grid.RowSpan="1"
                      Grid.ColumnSpan="3"
                      x:Name="RightHalf"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      Padding="16,0">
                    <Grid x:Name="LyricsContainer"
                          IsVisible="{Binding HasLyrics}"
                          IsClippedToBounds="True"
                          VerticalOptions="Fill"
                          HorizontalOptions="Fill">
                        <CollectionView x:Name="LyricCollectionView"
                                        ItemsSource="{Binding LyricPlaceholderItems}"
                                        SelectionMode="None"
                                        VerticalScrollBarVisibility="Never">
                            <CollectionView.Behaviors>
                                <controls:ScrollPerformanceBehavior />
                            </CollectionView.Behaviors>
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.Header>
                                <VerticalStackLayout x:Name="LyricStack"
                                                     Padding="0,10,0,10"
                                                     Spacing="8"
                                                     HorizontalOptions="Center" />
                            </CollectionView.Header>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <BoxView HeightRequest="0" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                    <!-- 无歌词提示（当没有歌词时显示） -->
                    <Label x:Name="NoLyricsLabel"
                           Text="{Binding NoLyricsText}"
                           FontSize="13"
                           TextColor="{DynamicResource TextHintColor}"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Opacity="0.6"
                           IsVisible="{Binding HasLyrics, Converter={StaticResource InvertedBoolConverter}}" />
                </Grid>
            </Grid>

            <!-- Row 2: 收藏按钮 + 进度条 + 播放控件 + 歌曲详情 -->
            <Grid x:Name="BottomControlsRoot"
                  Grid.Row="2"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="6"
                  Margin="0,4,0,0">
                <!-- 收藏按钮（进度条右上方） -->
                <ImageButton Grid.Row="0"
                        WidthRequest="36" HeightRequest="36"
                        CornerRadius="18" Padding="6"
                        Aspect="AspectFit"
                        BackgroundColor="Transparent"
                        Source="{Binding LikeIconSourceWhite}"
                        Command="{Binding ToggleLikeCommand}"
                        HorizontalOptions="End" VerticalOptions="Center" />
                <!-- 进度条 -->
                <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Slider x:Name="ProgressSlider"
                            Minimum="0"
                            Maximum="1"
                            Value="0"
                            ThumbColor="White"
                            MinimumTrackColor="White"
                            MaximumTrackColor="#40FFFFFF"
                            HeightRequest="24"
                            DragStarted="OnSliderDragStarted"
                            DragCompleted="OnSliderDragCompleted" />
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                        <Label Text="{Binding CurrentTimeDisplay}"
                               FontSize="11"
                               TextColor="White"
                               Opacity="0.7" />
                        <Label Grid.Column="2"
                               Text="{Binding TotalTimeDisplay}"
                               FontSize="11"
                               TextColor="White"
                               Opacity="0.7" />
                    </Grid>
                </Grid>

                <!-- ═══ 竖屏播放控件：5个按钮等分居中 ═══ -->
                <Grid Grid.Row="2"
                      x:Name="PhoneControls"
                      IsVisible="True"
                      ColumnDefinitions="*,*,*,*,*"
                      HeightRequest="80"
                      VerticalOptions="End">
                    <!-- 播放模式 -->
                    <ImageButton Grid.Column="0" WidthRequest="40" HeightRequest="40"
                            CornerRadius="20" Padding="8"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Source="{Binding PlayModeIconSourceWhite}"
                            Command="{Binding CyclePlayModeCommand}"
                            HorizontalOptions="Center" VerticalOptions="Center" />
                    <!-- 上一首（增大30%） -->
                    <ImageButton Grid.Column="1" WidthRequest="52" HeightRequest="52"
                            CornerRadius="26" Padding="10"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Source="{Binding PlayPreviousIconSourceWhite}"
                            Command="{Binding PlayPreviousCommand}"
                            HorizontalOptions="Center" VerticalOptions="Center" />
                    <!-- 播放/暂停（增大30%） -->
                    <ImageButton Grid.Column="2" WidthRequest="73" HeightRequest="73"
                            CornerRadius="36" Padding="16"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Source="{Binding PlayPauseIconSourceWhite}"
                            Command="{Binding TogglePlayPauseCommand}"
                            HorizontalOptions="Center" VerticalOptions="Center" />
                    <!-- 下一首（增大30%） -->
                    <ImageButton Grid.Column="3" WidthRequest="52" HeightRequest="52"
                            CornerRadius="26" Padding="10"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Source="{Binding PlayNextIconSourceWhite}"
                            Command="{Binding PlayNextCommand}"
                            HorizontalOptions="Center" VerticalOptions="Center" />
                    <!-- 播放列表 -->
                    <ImageButton Grid.Column="4" WidthRequest="40" HeightRequest="40"
                            CornerRadius="20" Padding="8"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Source="{Binding PlaylistIconSource}"
                            Clicked="OnOpenPlaylistClicked"
                            HorizontalOptions="Center" VerticalOptions="Center" />
                </Grid>

                <!-- ═══ 横屏播放控件：左/中/右三栏 ═══ -->
                <Grid Grid.Row="2"
                      x:Name="DesktopControls"
                      IsVisible="False"
                      ColumnDefinitions="*,Auto,*"
                      HeightRequest="80"
                      VerticalOptions="End">

                    <!-- 左侧：歌曲信息 + 收藏 -->
                    <Grid Grid.Column="0" ColumnDefinitions="*,Auto" ColumnSpacing="8"
                          HorizontalOptions="Start" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="1">
                            <Label Text="{Binding Title}"
                                   FontSize="13" FontFamily="OpenSansSemibold"
                                   TextColor="White" MaxLines="1"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Artist}"
                                   FontSize="11" TextColor="#CCFFFFFF" MaxLines="1"
                                   LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                        <ImageButton Grid.Column="1" WidthRequest="32" HeightRequest="32"
                                CornerRadius="16" Padding="6"
                                Aspect="AspectFit"
                                BackgroundColor="Transparent"
                                Source="{Binding LikeIconSourceWhite}"
                                Command="{Binding ToggleLikeCommand}"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                    </Grid>

                    <!-- 中间：播放控制按钮紧凑排列 -->
                    <Grid Grid.Column="1"
                          ColumnDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="16"
                          HorizontalOptions="Center" VerticalOptions="Center">
                        <!-- 播放模式 -->
                        <ImageButton Grid.Column="0" WidthRequest="40" HeightRequest="40"
                                CornerRadius="20" Padding="8"
                                Aspect="AspectFit"
                                BackgroundColor="Transparent"
                                Source="{Binding PlayModeIconSourceWhite}"
                                Command="{Binding CyclePlayModeCommand}"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                        <!-- 上一首（增大30%） -->
                        <ImageButton Grid.Column="1" WidthRequest="52" HeightRequest="52"
                                CornerRadius="26" Padding="10"
                                Aspect="AspectFit"
                                BackgroundColor="Transparent"
                                Source="{Binding PlayPreviousIconSourceWhite}"
                                Command="{Binding PlayPreviousCommand}"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                        <!-- 播放/暂停（增大30%） -->
                        <ImageButton Grid.Column="2" WidthRequest="73" HeightRequest="73"
                                CornerRadius="36" Padding="16"
                                Aspect="AspectFit"
                                BackgroundColor="Transparent"
                                Source="{Binding PlayPauseIconSourceWhite}"
                                Command="{Binding TogglePlayPauseCommand}"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                        <!-- 下一首（增大30%） -->
                        <ImageButton Grid.Column="3" WidthRequest="52" HeightRequest="52"
                                CornerRadius="26" Padding="10"
                                Aspect="AspectFit"
                                BackgroundColor="Transparent"
                                Source="{Binding PlayNextIconSourceWhite}"
                                Command="{Binding PlayNextCommand}"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                        <!-- 播放列表 -->
                        <ImageButton Grid.Column="4" WidthRequest="40" HeightRequest="40"
                                CornerRadius="20" Padding="8"
                                Aspect="AspectFit"
                                BackgroundColor="Transparent"
                                Source="{Binding PlaylistIconSource}"
                                Clicked="OnOpenPlaylistClicked"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                    </Grid>

                    <!-- 右侧：歌词 -->
                    <ImageButton Grid.Column="2" WidthRequest="40" HeightRequest="40"
                            CornerRadius="20" Padding="8"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Source="{Binding LyricsIconSource}"
                            Clicked="OnOpenLyricsClicked"
                            HorizontalOptions="End" VerticalOptions="Center" />
                </Grid>

                <!-- ═══ 底部操作栏：歌词 / 定时关闭 / 歌曲详情 / 音效 / 横屏 / 更多（占位图标，均布屏幕底部，暂未接功能） ═══ -->
                <Grid Grid.Row="3"
                      x:Name="BottomActionBar"
                      ColumnDefinitions="*,*,*,*,*,*"
                      Margin="8,6,8,2">
                    <!-- 进入歌词页面 -->
                    <ImageButton Grid.Column="0" WidthRequest="22" HeightRequest="22"
                                 CornerRadius="11" Padding="5"
                                 Aspect="AspectFit" BackgroundColor="Transparent"
                                 Source="ic_lyrics_full"
                                 Clicked="OnOpenLyricsClicked" />
                    <!-- 定时关闭 -->
                    <ImageButton Grid.Column="1" WidthRequest="22" HeightRequest="22"
                                 CornerRadius="11" Padding="5"
                                 Aspect="AspectFit" BackgroundColor="Transparent"
                                 Source="ic_timer"
                                 Clicked="OnSleepTimerClicked" />
                    <!-- 歌曲详情（白色图标） -->
                    <ImageButton Grid.Column="2" WidthRequest="22" HeightRequest="22"
                                 CornerRadius="11" Padding="5"
                                 Aspect="AspectFit" BackgroundColor="Transparent"
                                 Source="ic_info"
                                 Clicked="OnSongDetailTapped" />
                    <!-- 音效/均衡器 -->
                    <ImageButton Grid.Column="3" WidthRequest="22" HeightRequest="22"
                                 CornerRadius="11" Padding="5"
                                 Aspect="AspectFit" BackgroundColor="Transparent"
                                 Source="ic_equalizer"
                                 Clicked="OnEqualizerClicked" />
                    <!-- 切换横屏 -->
                    <ImageButton Grid.Column="4" WidthRequest="22" HeightRequest="22"
                                 CornerRadius="11" Padding="5"
                                 Aspect="AspectFit" BackgroundColor="Transparent"
                                 Source="ic_rotate"
                                 Clicked="OnRotateClicked" />
                    <!-- 更多 -->
                    <ImageButton Grid.Column="5" WidthRequest="22" HeightRequest="22"
                                 CornerRadius="11" Padding="5"
                                 Aspect="AspectFit" BackgroundColor="Transparent"
                                 Source="ic_more"
                                 Clicked="OnMoreClicked" />
                </Grid>
            </Grid>

            <!-- ═══ 横屏 / Windows 布局：左封面 + 右信息/控制（覆盖主内容+底部区域） ═══ -->
            <Grid x:Name="LandscapeRoot"
                  Grid.Row="1" Grid.RowSpan="2"
                  IsVisible="False"
                  ColumnDefinitions="1*,1.15*"
                  ColumnSpacing="40"
                  Padding="54,8,54,24">

                <!-- 左：封面（尽量大）+ 竖屏切换按钮 -->
                <Grid Grid.Column="0"
                      HorizontalOptions="Center" VerticalOptions="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!-- 竖屏切换按钮（始终可见，便于退出横屏） -->
                    <ImageButton Grid.Row="0"
                                 Source="ic_rotate"
                                 WidthRequest="34" HeightRequest="34" CornerRadius="17" Padding="7"
                                 BackgroundColor="#20FFFFFF" Aspect="AspectFit"
                                 HorizontalOptions="End" VerticalOptions="Center"
                                 Margin="0,0,0,12"
                                 Clicked="OnRotateClicked" />
                    <Border Grid.Row="1"
                            x:Name="LandscapeCover"
                            StrokeThickness="0.5"
                            Stroke="#30FFFFFF"
                            StrokeShape="RoundRectangle 28"
                            BackgroundColor="Transparent"
                            WidthRequest="360" HeightRequest="360"
                            HorizontalOptions="Center" VerticalOptions="Center">
                        <Image x:Name="LandscapeCoverImage"
                               Source="{Binding CoverImage}"
                               Aspect="AspectFill"
                               WidthRequest="360" HeightRequest="360" />
                    </Border>
                </Grid>

                <!-- 右：信息 + 控制 + 歌词（Grid 行布局，歌词面板占满剩余高度） -->
                <Grid Grid.Column="1"
                      RowDefinitions="Auto,Auto,Auto,*,Auto,Auto"
                      RowSpacing="14"
                      ColumnDefinitions="*"
                      VerticalOptions="Fill"
                      HorizontalOptions="Fill"
                      Padding="0,4">

                    <!-- 标题 + 艺人 + 音质徽章 -->
                    <VerticalStackLayout x:Name="LandscapeTitleBlock" Grid.Row="0" Spacing="3">
                        <Label Text="{Binding Title}"
                               FontSize="34" FontFamily="OpenSansSemibold"
                               TextColor="White"
                               MaxLines="1" LineBreakMode="TailTruncation" />
                        <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                            <Label Text="{Binding Artist}"
                                   FontSize="15" TextColor="{DynamicResource TextSecondaryColor}"
                                   MaxLines="1" LineBreakMode="TailTruncation" />
                            <Label Text="Hi-Res" FontSize="9" FontAttributes="Bold"
                                   TextColor="{DynamicResource PrimaryColor}"
                                   Padding="5,2" />
                            <Label Text="无损" FontSize="9" FontAttributes="Bold"
                                   TextColor="{DynamicResource PrimaryColor}"
                                   Padding="5,2" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- 工具图标：播放列表 / 睡眠定时（竖屏切换已移到封面角） -->
                    <HorizontalStackLayout x:Name="LandscapeToolsRow" Grid.Row="1" Spacing="14">
                        <ImageButton WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="6"
                                     Aspect="AspectFit" BackgroundColor="Transparent"
                                     Source="{Binding PlaylistIconSource}"
                                     Clicked="OnOpenPlaylistClicked" />
                        <ImageButton WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="6"
                                     Aspect="AspectFit" BackgroundColor="Transparent"
                                     Source="ic_timer"
                                     Clicked="OnSleepTimerClicked" />
                    </HorizontalStackLayout>

                    <!-- 当前歌词（点击进入歌词模式，横屏就地显示多行歌词） -->
                    <VerticalStackLayout x:Name="LandscapeCurrentLyric" Grid.Row="2" Spacing="4">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenLyricsClicked" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label Text="当前歌词" FontSize="10"
                               TextColor="{DynamicResource TextHintColor}"
                               CharacterSpacing="2" />
                        <Label Text="{Binding LyricCurrent}"
                               FontSize="17" FontAttributes="Bold" TextColor="White"
                               MaxLines="1" LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <!-- 多行歌词面板（歌词模式显示，占满右栏剩余高度） -->
                    <ScrollView x:Name="LandscapeLyricsScroll" Grid.Row="3"
                                IsVisible="False"
                                VerticalScrollBarVisibility="Never"
                                HorizontalOptions="Fill" VerticalOptions="Fill">
                        <VerticalStackLayout x:Name="LandscapeLyricStack"
                                             Spacing="14"
                                             Padding="0,16,0,60"
                                             HorizontalOptions="Fill" />
                    </ScrollView>

                    <!-- 进度条 -->
                    <Grid Grid.Row="4" RowDefinitions="Auto,Auto" RowSpacing="1">
                        <Slider x:Name="LandscapeProgressSlider"
                                Minimum="0" Maximum="1" Value="0"
                                ThumbColor="White"
                                MinimumTrackColor="White"
                                MaximumTrackColor="#40FFFFFF"
                                HeightRequest="16"
                                DragStarted="OnSliderDragStarted"
                                DragCompleted="OnSliderDragCompleted" />
                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                            <Label Text="{Binding CurrentTimeDisplay}" FontSize="10"
                                   TextColor="White" Opacity="0.7" />
                            <Label Grid.Column="2" Text="{Binding TotalTimeDisplay}" FontSize="10"
                                   TextColor="White" Opacity="0.7" />
                        </Grid>
                    </Grid>

                    <!-- 播放控制行 -->
                    <HorizontalStackLayout Grid.Row="5" Spacing="14" VerticalOptions="Center">
                        <ImageButton WidthRequest="44" HeightRequest="44" CornerRadius="22" Padding="9"
                                     Aspect="AspectFit" BackgroundColor="Transparent"
                                     Source="{Binding LikeIconSourceWhite}"
                                     Command="{Binding ToggleLikeCommand}" />
                        <ImageButton WidthRequest="44" HeightRequest="44" CornerRadius="22" Padding="9"
                                     Aspect="AspectFit" BackgroundColor="Transparent"
                                     Source="{Binding PlayPreviousIconSourceWhite}"
                                     Command="{Binding PlayPreviousCommand}" />
                        <ImageButton WidthRequest="64" HeightRequest="64" CornerRadius="32" Padding="13"
                                     Aspect="AspectFit" BackgroundColor="{DynamicResource PrimaryColor}"
                                     Source="{Binding PlayPauseIconSourceWhite}"
                                     Command="{Binding TogglePlayPauseCommand}" />
                        <ImageButton WidthRequest="44" HeightRequest="44" CornerRadius="22" Padding="9"
                                     Aspect="AspectFit" BackgroundColor="Transparent"
                                     Source="{Binding PlayNextIconSourceWhite}"
                                     Command="{Binding PlayNextCommand}" />
                        <ImageButton WidthRequest="44" HeightRequest="44" CornerRadius="22" Padding="9"
                                     Aspect="AspectFit" BackgroundColor="Transparent"
                                     Source="{Binding PlayModeIconSourceWhite}"
                                     Command="{Binding CyclePlayModeCommand}" />
                        <ImageButton WidthRequest="40" HeightRequest="40" CornerRadius="20" Padding="8"
                                     Aspect="AspectFit" BackgroundColor="Transparent"
                                     Source="{Binding LyricsIconSource}"
                                     Clicked="OnOpenLyricsClicked" />
                    </HorizontalStackLayout>
                </Grid>
            </Grid>

        </Grid>

        <!-- 播放列表弹窗（预定义，默认隐藏） -->
        <controls:AppPopup x:Name="PlaylistPopup"
                           Title="播放列表"
                           CloseOnMaskTapped="True" />

        <!-- 定时停止音乐弹窗 -->
        <controls:AppPopup x:Name="SleepTimerPopup"
                           Title="定时停止音乐"
                           CloseOnMaskTapped="True" />

        <!-- 更多操作：虚拟化选择器（替代居中弹窗，从底部滑入更自然，歌单子列表支持虚拟化） -->
        <controls:VirtualizedSelect x:Name="VsMore" />
    </Grid>
</ContentPage>
