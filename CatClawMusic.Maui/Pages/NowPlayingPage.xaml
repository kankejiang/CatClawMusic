<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatClawMusic.Maui.Pages.NowPlayingPage"
             Title="正在播放"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid Background="{DynamicResource PageBackgroundBrush}"
          RowDefinitions="*,Auto,Auto"
          Padding="20,12,20,16">

        <!-- Decorative glows -->
        <Border WidthRequest="300" HeightRequest="300"
                StrokeThickness="0" StrokeShape="Ellipse"
                Background="{DynamicResource PrimaryGlowBrush}"
                HorizontalOptions="Center" VerticalOptions="Start"
                TranslationY="-100" />

        <!-- Row 0: Cover + Song Info (fills remaining space) -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="12">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                    WidthRequest="220" HeightRequest="220"
                    HorizontalOptions="Center">
                <Image x:Name="ArtworkImage"
                       Source="{Binding CoverImage}"
                       Aspect="AspectFill"
                       WidthRequest="220" HeightRequest="220" />
            </Border>

            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label Text="{Binding Title}"
                       FontSize="20"
                       FontFamily="OpenSansSemibold"
                       TextColor="{DynamicResource TextPrimaryColor}"
                       HorizontalTextAlignment="Center"
                       MaxLines="1" />
                <Label Text="{Binding Artist}"
                       FontSize="14"
                       TextColor="{DynamicResource TextSecondaryColor}"
                       HorizontalTextAlignment="Center"
                       MaxLines="1" />
            </VerticalStackLayout>

            <!-- Current lyric line only -->
            <Label Text="{Binding LyricCurrent}"
                   FontSize="14"
                   TextColor="{DynamicResource PrimaryLightColor}"
                   HorizontalTextAlignment="Center"
                   MaxLines="2"
                   LineBreakMode="WordWrap"
                   HeightRequest="40"
                   IsVisible="{Binding HasLyrics}" />
            <Label Text="{Binding NoLyricsText}"
                   FontSize="13"
                   TextColor="{DynamicResource TextHintColor}"
                   HorizontalTextAlignment="Center"
                   HeightRequest="20"
                   IsVisible="{Binding HasLyrics, Converter={StaticResource InvertedBoolConverter}}" />
        </VerticalStackLayout>

        <!-- Row 1: Progress -->
        <VerticalStackLayout Grid.Row="1" Spacing="2" Margin="0,8,0,0">
            <Slider x:Name="ProgressSlider"
                    Minimum="0"
                    Maximum="{Binding Duration, Mode=OneWay}"
                    Value="{Binding Progress, Mode=TwoWay}"
                    ThumbColor="{DynamicResource PrimaryColor}"
                    MinimumTrackColor="{DynamicResource PrimaryColor}"
                    MaximumTrackColor="{DynamicResource DividerColor}"
                    DragStarted="OnSliderDragStarted"
                    DragCompleted="OnSliderDragCompleted" />
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="{Binding CurrentTimeDisplay}"
                       FontSize="11" TextColor="{DynamicResource TextHintColor}" />
                <Label Grid.Column="2"
                       Text="{Binding TotalTimeDisplay}"
                       FontSize="11" TextColor="{DynamicResource TextHintColor}" />
            </Grid>
        </VerticalStackLayout>

        <!-- Row 2: Main Controls -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,*,*,*,*"
              HeightRequest="64"
              Margin="0,4,0,0">
            <!-- Play Mode -->
            <Border Grid.Column="0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    Background="{DynamicResource PrimaryGlowBrush}"
                    WidthRequest="32" HeightRequest="32"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <ImageButton Source="{Binding PlayModeIconSource}"
                             WidthRequest="20" HeightRequest="20"
                             BackgroundColor="Transparent"
                             Command="{Binding CyclePlayModeCommand}"
                             HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <!-- Previous -->
            <Border Grid.Column="1"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    Background="{DynamicResource PrimaryGlowBrush}"
                    WidthRequest="40" HeightRequest="40"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <ImageButton Source="ic_skip_previous"
                             WidthRequest="24" HeightRequest="24"
                             BackgroundColor="Transparent"
                             Command="{Binding PlayPreviousCommand}"
                             HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <!-- Play/Pause -->
            <Border Grid.Column="2"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 28"
                    Background="{DynamicResource HeroBrush}"
                    WidthRequest="56" HeightRequest="56"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <ImageButton Source="{Binding PlayPauseIconSource}"
                             WidthRequest="36" HeightRequest="36"
                             BackgroundColor="Transparent"
                             Command="{Binding TogglePlayPauseCommand}"
                             HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <!-- Next -->
            <Border Grid.Column="3"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    Background="{DynamicResource PrimaryGlowBrush}"
                    WidthRequest="40" HeightRequest="40"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <ImageButton Source="ic_skip_next"
                             WidthRequest="24" HeightRequest="24"
                             BackgroundColor="Transparent"
                             Command="{Binding PlayNextCommand}"
                             HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <!-- Like -->
            <Border Grid.Column="4"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    Background="{DynamicResource AccentGlowBrush}"
                    WidthRequest="32" HeightRequest="32"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <ImageButton Source="{Binding LikeIconSource}"
                             WidthRequest="20" HeightRequest="20"
                             BackgroundColor="Transparent"
                             Command="{Binding ToggleLikeCommand}"
                             HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

    </Grid>
</ContentPage>
