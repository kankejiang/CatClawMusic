<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.NowPlayingPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitleNowPlaying]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid>
        <!-- 雾面动态背景层（铺满整个页面，覆盖状态栏和导航栏区域） -->
        <controls:FrostedBackground x:Name="FrostedBg"
                                    Source="{Binding CoverImage}"
                                    CacheKey="{Binding CurrentCoverPath}"
                                    IsActive="{Binding IsPlaying}"
                                    IsVisible="{DynamicResource FrostedBackgroundEnabled}"
                                    TintColor="{DynamicResource PrimaryColor}"
                                    TintOpacity="0.25"
                                    DimAmount="0.15"
                                    InputTransparent="True"
                                    Aspect="AspectFill" />

        <!-- 暗色遮罩层：在雾面背景上叠加一层半透明暗色，确保文字可读 -->
        <BoxView Color="#70000000" InputTransparent="True" />

        <!-- 内容层：3行Grid - 返回按钮/Auto, 主体(封面左+信息歌词右)/Star, 进度+控件/Auto -->
        <Grid x:Name="RootGrid"
              RowDefinitions="Auto,*,Auto"
              Padding="24,16,24,20">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnPageTapped" />
            </Grid.GestureRecognizers>

            <!-- Row 0: 顶部导航栏（返回按钮） -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" HeightRequest="40">
                <!-- Windows桌面端返回按钮（移动端通过ViewPager滑动返回，不显示此按钮） -->
                <Border Grid.Column="0"
                        x:Name="BackButton"
                        IsVisible="{OnPlatform Default=false, WinUI=true}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        BackgroundColor="#40FFFFFF"
                        WidthRequest="40" HeightRequest="40"
                        HorizontalOptions="Start" VerticalOptions="Center"
                        ZIndex="10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackButtonTapped" />
                    </Border.GestureRecognizers>
                    <Image Source="ic_arrow_back"
                           WidthRequest="20" HeightRequest="20"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- Row 1: 主体（左半：封面+信息居中 / 右半：歌词居中，中间竖直分割线） -->
            <Grid Grid.Row="1"
                  x:Name="MainContent"
                  ColumnDefinitions="1*,Auto,1*"
                  Padding="0,8,0,4">
                <!-- 左半部分：封面 + 歌曲信息，整体垂直+水平居中 -->
                <VerticalStackLayout Grid.Column="0"
                                     x:Name="LeftHalf"
                                     Spacing="22"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Padding="16,0">
                    <!-- 封面容器：辉光投影层与封面本体层重叠，辉光在下、封面在上 -->
                    <Grid HorizontalOptions="Center">
                        <!-- 封面辉光（模糊投影）- 底层 -->
                        <Border x:Name="CoverGlow"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 24"
                                BackgroundColor="{DynamicResource PrimaryColor}"
                                WidthRequest="{OnIdiom Phone=220, Default=380}"
                                HeightRequest="{OnIdiom Phone=220, Default=380}"
                                Opacity="0.35"
                                Scale="1.08"
                                TranslationY="8"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        <!-- 封面本体 - 上层 -->
                        <Border x:Name="CoverArea"
                                StrokeThickness="0.5"
                                Stroke="#30FFFFFF"
                                StrokeShape="RoundRectangle 24"
                                BackgroundColor="{DynamicResource SurfaceColor}"
                                WidthRequest="{OnIdiom Phone=220, Default=380}"
                                HeightRequest="{OnIdiom Phone=220, Default=380}"
                                HorizontalOptions="Center">
                            <Image x:Name="ArtworkImage"
                                   Source="{Binding CoverImage}"
                                   Aspect="AspectFill"
                                   WidthRequest="{OnIdiom Phone=220, Default=380}"
                                   HeightRequest="{OnIdiom Phone=220, Default=380}" />
                        </Border>
                    </Grid>
                    <!-- 歌曲信息（居中） -->
                    <VerticalStackLayout Spacing="6"
                                         HorizontalOptions="Center">
                        <Label Text="{Binding Title}"
                               FontSize="22"
                               FontFamily="OpenSansSemibold"
                               TextColor="White"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Artist}"
                               FontSize="15"
                               TextColor="{DynamicResource TextSecondaryColor}"
                               Opacity="0.9"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Album}"
                               FontSize="13"
                               TextColor="{DynamicResource TextHintColor}"
                               Opacity="0.8"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- 中间竖直分割线 -->
                <BoxView Grid.Column="1"
                         WidthRequest="1"
                         Color="#30FFFFFF"
                         HorizontalOptions="Center"
                         VerticalOptions="Fill"
                         Margin="0,24,0,24" />

                <!-- 右半部分：歌词（居中滚动） -->
                <Grid Grid.Column="2"
                      x:Name="RightHalf"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      Padding="16,0">
                    <Grid x:Name="LyricsContainer"
                          IsVisible="{Binding HasLyrics}"
                          IsClippedToBounds="True"
                          VerticalOptions="Fill"
                          HorizontalOptions="Fill">
                        <CollectionView x:Name="LyricCollectionView"
                                        ItemsSource="{Binding LyricPlaceholderItems}"
                                        SelectionMode="None"
                                        VerticalScrollBarVisibility="Never">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.Header>
                                <VerticalStackLayout x:Name="LyricStack"
                                                     Padding="0,40,0,40"
                                                     Spacing="8"
                                                     HorizontalOptions="Center" />
                            </CollectionView.Header>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <BoxView HeightRequest="0" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                    <!-- 无歌词提示（当没有歌词时显示） -->
                    <Label x:Name="NoLyricsLabel"
                           Text="{Binding NoLyricsText}"
                           FontSize="13"
                           TextColor="{DynamicResource TextHintColor}"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Opacity="0.6"
                           IsVisible="{Binding HasLyrics, Converter={StaticResource InvertedBoolConverter}}" />
                </Grid>
            </Grid>

            <!-- Row 2: 进度条 + 播放控件 -->
            <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,4,0,0">
                <!-- 进度条 -->
                <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Slider x:Name="ProgressSlider"
                            Minimum="0"
                            Maximum="1"
                            Value="0"
                            ThumbColor="White"
                            MinimumTrackColor="White"
                            MaximumTrackColor="#40FFFFFF"
                            HeightRequest="24"
                            DragStarted="OnSliderDragStarted"
                            DragCompleted="OnSliderDragCompleted" />
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                        <Label Text="{Binding CurrentTimeDisplay}"
                               FontSize="11"
                               TextColor="White"
                               Opacity="0.7" />
                        <Label Grid.Column="2"
                               Text="{Binding TotalTimeDisplay}"
                               FontSize="11"
                               TextColor="White"
                               Opacity="0.7" />
                    </Grid>
                </Grid>

                <!-- 播放控件行 -->
                <Grid ColumnDefinitions="*,*,*,*,*"
                      HeightRequest="56"
                      VerticalOptions="End">
                    <!-- 播放模式 -->
                    <ImageButton Grid.Column="0"
                                 Source="{Binding PlayModeIconSource}"
                                 WidthRequest="22" HeightRequest="22"
                                 BackgroundColor="Transparent"
                                 Command="{Binding CyclePlayModeCommand}"
                                 HorizontalOptions="Center" VerticalOptions="Center"
                                 Opacity="0.85" />
                    <!-- 上一首 -->
                    <ImageButton Grid.Column="1"
                                 Source="ic_skip_previous"
                                 WidthRequest="28" HeightRequest="28"
                                 BackgroundColor="Transparent"
                                 Command="{Binding PlayPreviousCommand}"
                                 HorizontalOptions="Center" VerticalOptions="Center"
                                 Opacity="0.9" />
                    <!-- 播放/暂停：主题色圆形背景 + 白色图标 -->
                    <Border Grid.Column="2"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 28"
                            Background="{DynamicResource HeroBrush}"
                            WidthRequest="56" HeightRequest="56"
                            HorizontalOptions="Center" VerticalOptions="Center">
                        <ImageButton Source="{Binding PlayPauseIconSource}"
                                     Padding="14"
                                     BackgroundColor="Transparent"
                                     Command="{Binding TogglePlayPauseCommand}"
                                     HorizontalOptions="Fill" VerticalOptions="Fill" />
                    </Border>
                    <!-- 下一首 -->
                    <ImageButton Grid.Column="3"
                                 Source="ic_skip_next"
                                 WidthRequest="28" HeightRequest="28"
                                 BackgroundColor="Transparent"
                                 Command="{Binding PlayNextCommand}"
                                 HorizontalOptions="Center" VerticalOptions="Center"
                                 Opacity="0.9" />
                    <!-- 收藏 -->
                    <ImageButton Grid.Column="4"
                                 Source="{Binding LikeIconSource}"
                                 WidthRequest="22" HeightRequest="22"
                                 BackgroundColor="Transparent"
                                 Command="{Binding ToggleLikeCommand}"
                                 HorizontalOptions="Center" VerticalOptions="Center"
                                 Opacity="0.85" />
                </Grid>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
