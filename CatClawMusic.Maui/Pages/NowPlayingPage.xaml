<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatClawMusic.Maui.Pages.NowPlayingPage"
             Title="正在播放"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="24">
            
            <!-- Album Art -->
            <Frame CornerRadius="16"
                   WidthRequest="250" HeightRequest="250"
                   HorizontalOptions="Center"
                   IsClippedToBounds="True"
                   BackgroundColor="{DynamicResource CardBackgroundColor}">
                <Image x:Name="ArtworkImage" 
                       Source="{Binding AlbumArtUrl}"
                       Aspect="AspectFill"
                       WidthRequest="250" HeightRequest="250"/>
            </Frame>

            <!-- Song Info -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="{Binding Title}" 
                       FontSize="24" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimaryColor}"
                       HorizontalOptions="Center"
                       LineBreakMode="TailTruncation"/>
                
                <Label Text="{Binding Artist}" 
                       FontSize="16"
                       TextColor="{DynamicResource TextSecondaryColor}"
                       HorizontalOptions="Center"
                       LineBreakMode="TailTruncation"/>
            </VerticalStackLayout>

            <!-- Lyrics Preview -->
            <Label Text="{Binding CurrentLyric}"
                   FontSize="16"
                   TextColor="{DynamicResource TextPrimaryColor}"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="Center"
                   HeightRequest="60"
                   LineBreakMode="WordWrap"/>

            <!-- Progress Section -->
            <VerticalStackLayout Spacing="8">
                <Slider x:Name="ProgressSlider" 
                        Minimum="0" 
                        Maximum="{Binding Duration}"
                        Value="{Binding Progress, Mode=TwoWay}"
                        ThumbColor="{DynamicResource PrimaryColor}"
                        MinimumTrackColor="{DynamicResource PrimaryColor}"/>
                
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Label Text="{Binding CurrentTimeDisplay}" 
                           TextColor="{DynamicResource TextSecondaryColor}" 
                           FontSize="12"/>
                    <Label Grid.Column="2" 
                           Text="{Binding TotalTimeDisplay}" 
                           TextColor="{DynamicResource TextSecondaryColor}" 
                           FontSize="12"
                           HorizontalOptions="End"/>
                </Grid>
            </VerticalStackLayout>

            <!-- Playback Controls -->
            <HorizontalStackLayout Spacing="30" 
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                
                <Button Text="🔀"
                        FontSize="20"
                        BackgroundColor="Transparent"
                        TextColor="{Binding ShuffleColor}"
                        WidthRequest="50" HeightRequest="50"
                        Command="{Binding ToggleShuffleCommand}"/>
                
                <Button Text="⏮"
                        FontSize="28"
                        BackgroundColor="Transparent"
                        TextColor="{DynamicResource TextPrimaryColor}"
                        WidthRequest="60" HeightRequest="60"
                        Command="{Binding PlayPreviousCommand}"/>
                
                <Button x:Name="PlayPauseButton" 
                        Text="{Binding PlayPauseIcon}"
                        FontSize="36"
                        BackgroundColor="{DynamicResource PrimaryColor}"
                        TextColor="White"
                        WidthRequest="70" HeightRequest="70"
                        CornerRadius="35"
                        Command="{Binding TogglePlayPauseCommand}"/>
                
                <Button Text="⏭"
                        FontSize="28"
                        BackgroundColor="Transparent"
                        TextColor="{DynamicResource TextPrimaryColor}"
                        WidthRequest="60" HeightRequest="60"
                        Command="{Binding PlayNextCommand}"/>
                
                <Button Text="🔁"
                        FontSize="20"
                        BackgroundColor="Transparent"
                        TextColor="{Binding RepeatColor}"
                        WidthRequest="50" HeightRequest="50"
                        Command="{Binding ToggleRepeatCommand}"/>
            </HorizontalStackLayout>

            <!-- Secondary Controls -->
            <HorizontalStackLayout Spacing="20" 
                                HorizontalOptions="Center">
                
                <Button Text="❤"
                        FontSize="18"
                        BackgroundColor="Transparent"
                        TextColor="{Binding LikeColor}"
                        WidthRequest="44" HeightRequest="44"
                        Command="{Binding ToggleLikeCommand}"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
