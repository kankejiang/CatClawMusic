<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.SplashSettingsPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitleSplashSettings]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Border Margin="16,18,16,22"
                Style="{StaticResource GlassCardStrongStyle}">
            <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitleSplashSettings]}" Style="{StaticResource PageTitleStyle}" />
                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FeatureInDev]}"
                       Style="{StaticResource PageSubtitleStyle}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>
            <controls:BackButton Margin="16,16,0,0"
                             VerticalOptions="Start"
                             HorizontalOptions="Start"
                             ZIndex="100" />
</Grid>
</ContentPage>
