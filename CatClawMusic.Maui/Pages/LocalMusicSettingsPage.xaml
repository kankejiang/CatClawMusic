<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             x:Class="CatClawMusic.Maui.Pages.LocalMusicSettingsPage"
             Title="本地音乐设置"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid Background="{DynamicResource PageBackgroundBrush}">

        <ScrollView>
            <VerticalStackLayout Padding="16,18,16,22"
                                 Spacing="14">

                <Border Style="{StaticResource GlassCardStrongStyle}"
                        Background="{DynamicResource HeroBrush}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="本地音乐"
                               Style="{StaticResource PageTitleStyle}"
                               TextColor="White" />
                        <Label Text="选择扫描方式、添加音乐文件夹、扫描歌曲。"
                               Style="{StaticResource PageSubtitleStyle}"
                               TextColor="#F3F5FF" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="扫描方式"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <CheckBox IsChecked="{Binding UseMediaStore}" />
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="使用 Android 媒体库扫描"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                                <Label Text="扫描系统媒体库中的所有音乐文件（需要读取权限）"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <CheckBox IsChecked="{Binding UseSafScan}" />
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="使用 SAF 文件夹扫描"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                                <Label Text="使用系统 SAF 选择文件夹进行扫描（兼容 Android 11+）"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="提示：若同时开启多个扫描方式，最终扫描结果为并集；若仅使用自定义文件夹，请关闭以上两个选项。"
                               FontSize="11"
                               TextColor="{DynamicResource TextHintColor}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="音乐文件夹"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Text="选择SAF文件夹"
                                    Command="{Binding SelectFolderCommand}"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    TextColor="White"
                                    CornerRadius="16"
                                    HeightRequest="40"
                                    FontSize="13" />
                            <Button Grid.Column="1"
                                    Text="浏览文件系统"
                                    Clicked="OnBrowseFilesystemClicked"
                                    BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                                    TextColor="{DynamicResource TextPrimaryColor}"
                                    CornerRadius="16"
                                    HeightRequest="40"
                                    FontSize="13" />
                        </Grid>

                        <Label Text="{Binding FolderSummaryText}"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondaryColor}" />

                        <CollectionView ItemsSource="{Binding MusicFolders}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="8"
                                          Margin="0,4,0,4">
                                        <Image Source="ic_folder"
                                               WidthRequest="18"
                                               HeightRequest="18"
                                               VerticalOptions="Center"
                                               Opacity="0.7" />
                                        <VerticalStackLayout Grid.Column="1"
                                                             VerticalOptions="Center"
                                                             Spacing="2">
                                            <Label Text="{Binding DisplayName}"
                                                   FontSize="13"
                                                   TextColor="{DynamicResource TextSecondaryColor}"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Path}"
                                                   FontSize="10"
                                                   TextColor="{DynamicResource TextHintColor}"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2"
                                                Text="删除"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFolderCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{DynamicResource ErrorColor}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                HeightRequest="30"
                                                FontSize="11"
                                                WidthRequest="50" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="扫描状态"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Label Text="{Binding ScanStatus}"
                               FontSize="13"
                               TextColor="{DynamicResource TextSecondaryColor}" />
                        <ProgressBar Progress="{Binding ScanProgress}"
                                     ProgressColor="{DynamicResource PrimaryColor}"
                                     IsVisible="{Binding IsScanning}" />
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10"
                              IsVisible="{Binding IsScanning}">
                            <Button Text="扫描音乐"
                                    Command="{Binding ScanMusicCommand}"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    TextColor="White"
                                    CornerRadius="16"
                                    HeightRequest="40"
                                    FontSize="13"
                                    IsEnabled="False" />
                            <Button Grid.Column="1"
                                    Text="取消"
                                    Command="{Binding CancelScanCommand}"
                                    BackgroundColor="{DynamicResource ErrorColor}"
                                    TextColor="White"
                                    CornerRadius="16"
                                    HeightRequest="40"
                                    FontSize="13" />
                        </Grid>
                        <Button Text="扫描音乐"
                                Command="{Binding ScanMusicCommand}"
                                BackgroundColor="{DynamicResource PrimaryColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="40"
                                FontSize="13"
                                IsVisible="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" />
                        <Label Text="{Binding TotalSongsImported, StringFormat='共导入 {0} 首歌曲'}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}"
                               IsVisible="{Binding TotalSongsImported, Converter={StaticResource IntToBoolConverter}}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="解码设置"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <CheckBox IsChecked="{Binding IsFfmpegEnabled}" />
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="启用 FFmpeg 软解码"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                                <Label Text="支持更多音频格式，会增加少量CPU占用"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
            <controls:BackButton Margin="16,16,0,0"
                             VerticalOptions="Start"
                             HorizontalOptions="Start"
                             ZIndex="100" />
</Grid>
</ContentPage>
