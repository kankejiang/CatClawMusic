<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.LocalMusicSettingsPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitleLocalMusicSettings]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <!-- Frosted glass background: blurred theme image, semi-transparent -->
        <controls:FrostedBackground Grid.RowSpan="2"
            Source="{DynamicResource ThemeBackgroundImage}"
            IsActive="{DynamicResource ThemeBackgroundEnabled}"
            IsVisible="{DynamicResource ThemeBackgroundEnabled}"
            TintColor="{DynamicResource TabBarGlassTint}"
            TintOpacity="0.45"
            DimAmount="0.25"
            Opacity="0.8"
            Aspect="AspectFill"
            UseNativeBlur="True"
            InputTransparent="True" />

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Padding="44,0,0,0" Spacing="8">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[LocalMusic]}"
                           Style="{StaticResource PageTitleStyle}"
                           TextColor="White" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[LocalMusicSettingsDesc]}"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextColor="#F3F5FF" />
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,22"
                                 Spacing="14">

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ScanMethod]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10"
                              IsVisible="{OnPlatform Default=false, Android=true}">
                            <CheckBox IsChecked="{Binding UseMediaStore}" />
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AndroidMediaScan]}"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AndroidMediaScanDesc]}"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10"
                              IsVisible="{OnPlatform Default=false, Android=true}">
                            <CheckBox IsChecked="{Binding UseSafScan}" />
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[SAFScan]}"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[SAFScanDesc]}"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ScanTip]}"
                               FontSize="11"
                               TextColor="{DynamicResource TextHintColor}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[MusicFolders]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        
                        <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AddFolder]}"
                                Clicked="OnAddFolderClicked"
                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="40"
                                FontSize="13" />

                        <Label Text="{Binding FolderSummaryText}"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondaryColor}" />

                        <CollectionView ItemsSource="{Binding MusicFolders}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="8"
                                          Margin="0,4,0,4">
                                        <Image Source="ic_folder"
                                               WidthRequest="18"
                                               HeightRequest="18"
                                               VerticalOptions="Center"
                                               Opacity="0.7" />
                                        <VerticalStackLayout Grid.Column="1"
                                                             VerticalOptions="Center"
                                                             Spacing="2">
                                            <Label Text="{Binding DisplayName}"
                                                   FontSize="13"
                                                   TextColor="{DynamicResource TextSecondaryColor}"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Path}"
                                                   FontSize="10"
                                                   TextColor="{DynamicResource TextHintColor}"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2"
                                                Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Delete]}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFolderCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{DynamicResource ErrorColor}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                HeightRequest="30"
                                                FontSize="11"
                                                WidthRequest="50" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ScanStatus]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Label Text="{Binding ScanStatus}"
                               FontSize="13"
                               TextColor="{DynamicResource TextSecondaryColor}" />
                        <ProgressBar Progress="{Binding ScanProgress}"
                                     ProgressColor="{DynamicResource PrimaryColor}"
                                     IsVisible="{Binding IsScanning}" />
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10"
                              IsVisible="{Binding IsScanning}">
                            <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ScanMusic]}"
                                    Command="{Binding ScanMusicCommand}"
                                    BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                    TextColor="White"
                                    CornerRadius="16"
                                    HeightRequest="40"
                                    FontSize="13"
                                    IsEnabled="False" />
                            <Button Grid.Column="1"
                                    Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Cancel]}"
                                    Command="{Binding CancelScanCommand}"
                                    BackgroundColor="{DynamicResource ErrorColor}"
                                    TextColor="White"
                                    CornerRadius="16"
                                    HeightRequest="40"
                                    FontSize="13" />
                        </Grid>
                        <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ScanMusic]}"
                                Command="{Binding ScanMusicCommand}"
                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="40"
                                FontSize="13"
                                IsVisible="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" />
                        <Label Text="{Binding TotalSongsImported, StringFormat='共导入 {0} 首歌曲'}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}"
                               IsVisible="{Binding TotalSongsImported, Converter={StaticResource IntToBoolConverter}}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DecodeSettings]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <CheckBox IsChecked="{Binding IsFfmpegEnabled}" />
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[EnableFFmpeg]}"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[EnableFFmpegDesc]}"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
</Grid>
</ContentPage>
