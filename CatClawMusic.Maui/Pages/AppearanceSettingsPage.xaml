<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             x:Class="CatClawMusic.Maui.Pages.AppearanceSettingsPage"
             Title="外观与个性化"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid Background="{DynamicResource PageBackgroundBrush}">

        <ScrollView>
            <VerticalStackLayout Padding="16,18,16,22"
                                 Spacing="14">

                <Border Style="{StaticResource GlassCardStrongStyle}"
                        Background="{DynamicResource HeroBrush}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="外观与个性化"
                               Style="{StaticResource PageTitleStyle}"
                               TextColor="White" />
                        <Label Text="选择主题颜色、切换深色模式、设置启动页。"
                               Style="{StaticResource PageSubtitleStyle}"
                               TextColor="#F3F5FF" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="主题颜色"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Grid ColumnDefinitions="*,*,*,*,*"
                              ColumnSpacing="10"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="10">
                            <Border Grid.Row="0" Grid.Column="0"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="2"
                                    Stroke="#52FFFFFF"
                                    BackgroundColor="#9B7ED8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeColorCommand}"
                                                          CommandParameter="#9B7ED8" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="2"
                                    Stroke="#52FFFFFF"
                                    BackgroundColor="#EC407A">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeColorCommand}"
                                                          CommandParameter="#EC407A" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="2"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="2"
                                    Stroke="#52FFFFFF"
                                    BackgroundColor="#42A5F5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeColorCommand}"
                                                          CommandParameter="#42A5F5" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="3"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="2"
                                    Stroke="#52FFFFFF"
                                    BackgroundColor="#66BB6A">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeColorCommand}"
                                                          CommandParameter="#66BB6A" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="4"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="2"
                                    Stroke="#52FFFFFF"
                                    BackgroundColor="#FF7043">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeColorCommand}"
                                                          CommandParameter="#FF7043" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="2"
                                    Stroke="#52FFFFFF"
                                    BackgroundColor="#EF5350">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeColorCommand}"
                                                          CommandParameter="#EF5350" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="2"
                                    Stroke="#52FFFFFF"
                                    BackgroundColor="#26A69A">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeColorCommand}"
                                                          CommandParameter="#26A69A" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="2"
                                    Stroke="#52FFFFFF"
                                    BackgroundColor="#FFC107">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeColorCommand}"
                                                          CommandParameter="#FFC107" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="3"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="2"
                                    Stroke="#52FFFFFF"
                                    BackgroundColor="#5C6BC0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeColorCommand}"
                                                          CommandParameter="#5C6BC0" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="4"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 22"
                                    StrokeThickness="2"
                                    Stroke="#52FFFFFF"
                                    BackgroundColor="#00BCD4">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeColorCommand}"
                                                          CommandParameter="#00BCD4" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="深色模式"
                               FontSize="16"
                               TextColor="{DynamicResource TextPrimaryColor}"
                               VerticalOptions="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsDarkMode}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="启动页"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Border Style="{StaticResource GlassInputStyle}"
                                Padding="0">
                            <Picker ItemsSource="{Binding StartupPageOptions}"
                                    SelectedIndex="{Binding SelectedStartupPageIndex, Mode=TwoWay}"
                                    BackgroundColor="Transparent"
                                    TextColor="{DynamicResource TextPrimaryColor}" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="自定义背景图片"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Label Text="选择自己喜欢的图片作为应用背景，让猫爪音乐更具个性"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondaryColor}" />

                        <Grid ColumnDefinitions="80,*"
                              ColumnSpacing="12"
                              IsVisible="{Binding HasCustomBackground}">
                            <Border Grid.Column="0"
                                    WidthRequest="80" HeightRequest="80"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="0"
                                    Padding="0">
                                <Image Source="{Binding CustomBackgroundPreview}"
                                       Aspect="AspectFill"
                                       WidthRequest="80" HeightRequest="80" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4"
                                                 VerticalOptions="Center">
                                <Label Text="当前背景"
                                       FontSize="12"
                                       TextColor="{DynamicResource TextSecondaryColor}" />
                                <Label Text="{Binding CustomBackgroundName}"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextPrimaryColor}"
                                       MaxLines="1"
                                       LineBreakMode="MiddleTruncation" />
                                <HorizontalStackLayout Spacing="8" Margin="0,6,0,0">
                                    <Button Text="更换图片"
                                            Command="{Binding SelectBackgroundCommand}"
                                            FontSize="13"
                                            Padding="12,6"
                                            BackgroundColor="{DynamicResource PrimaryColor}"
                                            TextColor="White"
                                            CornerRadius="16" />
                                    <Button Text="清除"
                                            Command="{Binding ClearBackgroundCommand}"
                                            FontSize="13"
                                            Padding="12,6"
                                            BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                                            TextColor="{DynamicResource TextSecondaryColor}"
                                            CornerRadius="16" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding HasCustomBackground, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Grid.Column="0"
                                   Text="未设置自定义背景，使用主题渐变背景"
                                   FontSize="13"
                                   TextColor="{DynamicResource TextHintColor}"
                                   VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="选择图片"
                                    Command="{Binding SelectBackgroundCommand}"
                                    FontSize="13"
                                    Padding="14,7"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    TextColor="White"
                                    CornerRadius="16" />
                        </Grid>

                        <VerticalStackLayout Spacing="6"
                                             IsVisible="{Binding HasCustomBackground}">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="背景透明度"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextSecondaryColor}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding BackgroundOpacity, StringFormat='{0:P0}'}"
                                       FontSize="13"
                                       TextColor="{DynamicResource TextHintColor}"
                                       VerticalOptions="Center" />
                            </Grid>
                            <Slider Minimum="0.1"
                                    Maximum="1.0"
                                    Value="{Binding BackgroundOpacity, Mode=TwoWay}"
                                    MinimumTrackColor="{DynamicResource PrimaryColor}"
                                    MaximumTrackColor="{DynamicResource InputBorderColor}"
                                    ThumbColor="{DynamicResource PrimaryColor}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
            <controls:BackButton Margin="16,16,0,0"
                             VerticalOptions="Start"
                             HorizontalOptions="Start"
                             ZIndex="100" />
</Grid>
</ContentPage>
