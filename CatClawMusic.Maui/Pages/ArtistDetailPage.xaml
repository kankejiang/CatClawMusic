<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.ArtistDetailPage"
             Title="艺术家详情"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                    <Border Grid.Column="0"
                            WidthRequest="72"
                            HeightRequest="72"
                            StrokeShape="RoundRectangle 36"
                            StrokeThickness="0"
                            BackgroundColor="{DynamicResource SurfaceColor}">
                        <Image Source="{Binding ArtistCoverPath, TargetNullValue='ic_artist'}"
                               Aspect="AspectFill"
                               WidthRequest="72"
                               HeightRequest="72" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1"
                                         VerticalOptions="Center"
                                         Spacing="2">
                        <Label Text="{Binding Artist.Name}"
                               FontSize="22"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}"
                               MaxLines="2" />
                        <Label Text="{Binding Albums.Count, StringFormat='{0} 张专辑'}"
                               FontSize="13"
                               TextColor="{DynamicResource TextSecondaryColor}" />
                        <Label Text="{Binding Songs.Count, StringFormat='{0} 首歌曲'}"
                               FontSize="13"
                               TextColor="{DynamicResource TextSecondaryColor}" />
                        <Button Text="▶ 播放全部"
                                Command="{Binding PlayAllCommand}"
                                BackgroundColor="{DynamicResource PrimaryColor}"
                                TextColor="White"
                                CornerRadius="20"
                                HeightRequest="36"
                                FontSize="12"
                                Padding="16,0"
                                Margin="0,6,0,0"
                                HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </Grid>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <Border Grid.Row="1"
                Margin="16,0,16,10"
                Style="{StaticResource GlassCardStyle}"
                Padding="4">
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8">
                <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabAlbums]}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Albums"
                        CornerRadius="18"
                        HeightRequest="44"
                        FontAttributes="Bold"
                        BackgroundColor="{Binding AlbumsTabColor}"
                        TextColor="White"
                        FontSize="14" />
                <Button Grid.Column="1"
                        Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabSongs]}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Songs"
                        CornerRadius="18"
                        HeightRequest="44"
                        FontAttributes="Bold"
                        BackgroundColor="{Binding SongsTabColor}"
                        TextColor="White"
                        FontSize="14" />
            </Grid>
        </Border>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Albums}"
                        IsVisible="{Binding IsAlbumsTabVisible}"
                        SelectionMode="Single"
                        SelectionChanged="OnAlbumSelected"
                        Margin="0,0,0,8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="16,0,16,10"
                            Padding="12"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="1"
                            Stroke="{DynamicResource GlassStrokeColor}"
                            BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border Grid.Column="0"
                                    WidthRequest="56"
                                    HeightRequest="56"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="0"
                                    BackgroundColor="{DynamicResource SurfaceColor}">
                                <Image Source="{Binding CoverArtPath}"
                                       Aspect="AspectFill"
                                       WidthRequest="56"
                                       HeightRequest="56" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding Title}"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{DynamicResource TextPrimaryColor}"
                                       MaxLines="1" />
                                <Label Text="{Binding Year}"
                                       FontSize="12"
                                       TextColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Songs}"
                        IsVisible="{Binding IsSongsTabVisible}"
                        SelectionMode="Single"
                        SelectionChanged="OnSongSelected"
                        ItemsUpdatingScrollMode="KeepItemsInView"
                        ItemTemplate="{StaticResource SongItemTemplate}">
            <CollectionView.Behaviors>
                <controls:ScrollPerformanceBehavior />
            </CollectionView.Behaviors>
        </CollectionView>
</Grid>
</ContentPage>
