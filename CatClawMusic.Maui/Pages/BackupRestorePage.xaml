<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:viewmodels="clr-namespace:CatClawMusic.Maui.ViewModels"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.BackupRestorePage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupRestore]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Padding="44,0,0,0" Spacing="8">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupRestore]}"
                           Style="{StaticResource PageTitleStyle}"
                           TextColor="White" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupRestoreSubtitle]}"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextColor="#F3F5FF" />
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,22"
                                 Spacing="14">

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupData]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupDataDesc]}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}" />
                        <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[CreateBackup]}"
                                Command="{Binding CreateBackupCommand}"
                                BackgroundColor="{DynamicResource PrimaryColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="42"
                                FontSize="13" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[RestoreData]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[RestoreDataDesc]}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}" />
                        <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[SelectBackupFile]}"
                                Command="{Binding RestoreBackupCommand}"
                                BackgroundColor="{DynamicResource PrimaryColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="42"
                                FontSize="13" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}"
                        IsVisible="{Binding IsBackingUp}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="备份进度"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <ProgressBar Progress="{Binding Progress}"
                                     ProgressColor="{DynamicResource PrimaryColor}" />
                        <Label Text="{Binding ProgressMessage}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}"
                        IsVisible="{Binding IsRestoring}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="恢复进度"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <ProgressBar Progress="{Binding Progress}"
                                     ProgressColor="{DynamicResource PrimaryColor}" />
                        <Label Text="{Binding ProgressMessage}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="现有备份"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="4,12,0,2" />

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="管理备份文件"
                               FontSize="14"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <CollectionView ItemsSource="{Binding BackupFiles}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:BackupFileInfo">
                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                          Padding="0,8"
                                          ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0"
                                                             VerticalOptions="Center"
                                                             Spacing="2">
                                            <Label Text="{Binding DisplayDate}"
                                                   FontSize="14"
                                                   TextColor="{DynamicResource TextPrimaryColor}"
                                                   VerticalOptions="Center" />
                                            <Label Text="{Binding SizeStr}"
                                                   FontSize="11"
                                                   TextColor="{DynamicResource TextHintColor}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1"
                                                Text="恢复"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RestoreBackupCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{DynamicResource PrimaryColor}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                HeightRequest="30"
                                                WidthRequest="56"
                                                FontSize="12" />
                                        <Button Grid.Column="2"
                                                Text="删除"
                                                Clicked="OnDeleteBackupClicked"
                                                BackgroundColor="{DynamicResource ErrorColor}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                HeightRequest="30"
                                                WidthRequest="56"
                                                FontSize="12" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
</Grid>
</ContentPage>
