<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:viewmodels="clr-namespace:CatClawMusic.Maui.ViewModels"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.BackupRestorePage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupRestore]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <!-- Frosted glass background: blurred theme image, semi-transparent -->
        <controls:FrostedBackground Grid.RowSpan="2"
            Source="{DynamicResource ThemeBackgroundImage}"
            IsActive="{DynamicResource ThemeBackgroundEnabled}"
            IsVisible="{DynamicResource ThemeBackgroundEnabled}"
            TintColor="{DynamicResource TabBarGlassTint}"
            TintOpacity="0.45"
            DimAmount="0.25"
            Opacity="0.8"
            Aspect="AspectFill"
            UseNativeBlur="True"
            InputTransparent="True" />

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Padding="44,0,0,0" Spacing="8">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupRestore]}"
                           Style="{StaticResource PageTitleStyle}"
                           TextColor="White" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupRestoreSubtitle]}"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextColor="#F3F5FF" />
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,22"
                                 Spacing="14">

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupData]}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupDataDesc]}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}" />
                        <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[CreateBackup]}"
                                Command="{Binding ShowBackupOptionsCommand}"
                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="42"
                                FontSize="13" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}"
                        IsVisible="{Binding IsBackingUp}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="备份进度"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <ProgressBar Progress="{Binding Progress}"
                                     ProgressColor="{DynamicResource PrimaryColor}" />
                        <Label Text="{Binding ProgressMessage}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}"
                        IsVisible="{Binding IsRestoring}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="恢复进度"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <ProgressBar Progress="{Binding Progress}"
                                     ProgressColor="{DynamicResource PrimaryColor}" />
                        <Label Text="{Binding ProgressMessage}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="现有备份"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="4,12,0,2" />

                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="管理备份文件"
                               FontSize="14"
                               TextColor="{DynamicResource TextPrimaryColor}" />
                        <CollectionView ItemsSource="{Binding BackupFiles}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:BackupFileInfo">
                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                          Padding="0,8"
                                          ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0"
                                                             VerticalOptions="Center"
                                                             Spacing="2">
                                            <Label Text="{Binding DisplayDate}"
                                                   FontSize="14"
                                                   TextColor="{DynamicResource TextPrimaryColor}"
                                                   VerticalOptions="Center" />
                                            <Label Text="{Binding SizeStr}"
                                                   FontSize="11"
                                                   TextColor="{DynamicResource TextHintColor}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1"
                                                Text="恢复"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ShowRestoreOptionsCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                HeightRequest="30"
                                                WidthRequest="56"
                                                FontSize="12" />
                                        <Button Grid.Column="2"
                                                Text="删除"
                                                Clicked="OnDeleteBackupClicked"
                                                BackgroundColor="{DynamicResource ErrorColor}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                HeightRequest="30"
                                                WidthRequest="56"
                                                FontSize="12" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 备份选项对话框 -->
        <Grid IsVisible="{Binding IsBackupOptionsVisible}"
              BackgroundColor="#99000000"
              ZIndex="50">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelBackupOptionsCommand}" />
            </Grid.GestureRecognizers>
            <Border Margin="24,0,24,0"
                    Padding="0"
                    StrokeThickness="1"
                    Stroke="{DynamicResource GlassStrokeColor}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{DynamicResource WindowBackgroundColor}"
                    VerticalOptions="Center">
                <VerticalStackLayout Spacing="0">
                    <Label Text="选择备份内容"
                           FontSize="17" FontFamily="OpenSansSemibold"
                           TextColor="{DynamicResource TextPrimaryColor}"
                           HorizontalOptions="Center" Margin="0,18,0,4" />
                    <Label Text="勾选需要备份的数据"
                           FontSize="12" TextColor="{DynamicResource TextHintColor}"
                           HorizontalOptions="Center" Margin="0,0,0,14" />
                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource DividerColor}" />

                    <VerticalStackLayout Padding="20,14" Spacing="12">
                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding OptChatHistory}" Color="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Label Text="AI 聊天记录" FontSize="14" TextColor="{DynamicResource TextPrimaryColor}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding OptAiMemory}" Color="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Label Text="记忆内容" FontSize="14" TextColor="{DynamicResource TextPrimaryColor}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding OptLlmConfigs}" Color="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Label Text="已保存的模型" FontSize="14" TextColor="{DynamicResource TextPrimaryColor}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding OptPlayHistory}" Color="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Label Text="播放记录" FontSize="14" TextColor="{DynamicResource TextPrimaryColor}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource DividerColor}" />
                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,0">
                        <Button Grid.Column="0" Text="全选" Command="{Binding SelectAllOptionsCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}"
                                CornerRadius="0" HeightRequest="46" FontSize="14" />
                        <Button Grid.Column="1" Text="开始备份" Command="{Binding ConfirmBackupCommand}"
                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}" TextColor="White"
                                CornerRadius="0" HeightRequest="46" FontSize="14" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- 恢复选项对话框 -->
        <Grid IsVisible="{Binding IsRestoreOptionsVisible}"
              BackgroundColor="#99000000"
              ZIndex="50">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelRestoreOptionsCommand}" />
            </Grid.GestureRecognizers>
            <Border Margin="24,0,24,0"
                    Padding="0"
                    StrokeThickness="1"
                    Stroke="{DynamicResource GlassStrokeColor}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{DynamicResource WindowBackgroundColor}"
                    VerticalOptions="Center">
                <VerticalStackLayout Spacing="0">
                    <Label Text="选择恢复内容"
                           FontSize="17" FontFamily="OpenSansSemibold"
                           TextColor="{DynamicResource TextPrimaryColor}"
                           HorizontalOptions="Center" Margin="0,18,0,4" />
                    <Label Text="勾选需要恢复的数据"
                           FontSize="12" TextColor="{DynamicResource TextHintColor}"
                           HorizontalOptions="Center" Margin="0,0,0,14" />
                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource DividerColor}" />

                    <VerticalStackLayout Padding="20,14" Spacing="12">
                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding OptChatHistory}" Color="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Label Text="AI 聊天记录" FontSize="14" TextColor="{DynamicResource TextPrimaryColor}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding OptAiMemory}" Color="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Label Text="记忆内容" FontSize="14" TextColor="{DynamicResource TextPrimaryColor}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding OptLlmConfigs}" Color="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Label Text="已保存的模型" FontSize="14" TextColor="{DynamicResource TextPrimaryColor}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding OptPlayHistory}" Color="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Label Text="播放记录" FontSize="14" TextColor="{DynamicResource TextPrimaryColor}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource DividerColor}" />
                    <Grid ColumnDefinitions="*,*">
                        <Button Grid.Column="0" Text="取消" Command="{Binding CancelRestoreOptionsCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondaryColor}"
                                CornerRadius="0" HeightRequest="46" FontSize="14" />
                        <Button Grid.Column="1" Text="开始恢复" Command="{Binding ConfirmRestoreCommand}"
                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}" TextColor="White"
                                CornerRadius="0" HeightRequest="46" FontSize="14" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

</Grid>
</ContentPage>
