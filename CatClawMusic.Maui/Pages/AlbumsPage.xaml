<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:converters="clr-namespace:CatClawMusic.Maui.Converters"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.AlbumsPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabAlbums]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <ContentPage.Resources>
        <converters:InitialConverter x:Key="InitialConverter" />
        <converters:CoverArtConverter x:Key="CoverArtConverter" />
        <converters:PlaceholderColorConverter x:Key="PlaceholderColorConverter" />
        <converters:PlaybackCountConverter x:Key="PlaybackCountConverter" />
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <!-- 顶栏 -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Padding="16,12,16,8"
              Background="{DynamicResource PageBackgroundBrush}">
            <Border Grid.Column="0"
                    BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                    Stroke="{DynamicResource GlassStrokeColor}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    WidthRequest="38" HeightRequest="38">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
                <Image Source="ic_arrow_left.svg"
                       WidthRequest="18" HeightRequest="18"
                       Aspect="AspectFit"
                       VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>

            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="Center"
                                 Margin="14,0,0,0">
                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabAlbums]}"
                       FontSize="17"
                       FontFamily="OpenSansSemibold"
                       TextColor="{DynamicResource TextPrimaryColor}" />
                <Label Text="浏览音乐库中的所有专辑"
                       FontSize="11"
                       TextColor="{DynamicResource TextHintColor}"
                       Margin="0,1,0,0" />
            </VerticalStackLayout>

            <Border Grid.Column="2"
                    BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                    Stroke="{DynamicResource GlassStrokeColor}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    WidthRequest="38" HeightRequest="38">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSearchTapped" />
                </Border.GestureRecognizers>
                <Image Source="ic_search.svg"
                       WidthRequest="18" HeightRequest="18"
                       Aspect="AspectFit"
                       VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
        </Grid>

        <!-- Hero 区域 -->
        <Border Grid.Row="1"
                Margin="16,6,16,14"
                Padding="22,20"
                StrokeShape="RoundRectangle 22"
                StrokeThickness="1"
                Stroke="{DynamicResource GlassStrokeColor}"
                BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
            <Border.Shadow>
                <Shadow Brush="#40000000" Offset="0,10" Radius="24" Opacity="0.3" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2">
                    <Label Text="我的专辑库"
                           FontSize="24"
                           FontFamily="OpenSansSemibold"
                           TextColor="{DynamicResource TextPrimaryColor}" />
                    <Label Text="按年份、来源与播放热度浏览你的收藏"
                           FontSize="12.5"
                           TextColor="{DynamicResource TextSecondaryColor}"
                           Margin="0,6,0,0" />
                    <FlexLayout Direction="Row"
                                Wrap="NoWrap"
                                Margin="0,14,0,0">
                        <VerticalStackLayout Spacing="1">
                            <Label Text="{Binding TotalAlbums, StringFormat='{0}'}"
                                   FontSize="19"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="张专辑"
                                   FontSize="10.5"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                        <BoxView WidthRequest="1" Color="#22FFFFFF" Margin="18,2" />
                        <VerticalStackLayout Spacing="1">
                            <Label Text="{Binding TotalSongs, StringFormat='{0}'}"
                                   FontSize="19"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="首歌曲"
                                   FontSize="10.5"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                        <BoxView WidthRequest="1" Color="#22FFFFFF" Margin="18,2" />
                        <VerticalStackLayout Spacing="1">
                            <Label Text="{Binding TotalArtists, StringFormat='{0}'}"
                                   FontSize="19"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="位艺术家"
                                   FontSize="10.5"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                    </FlexLayout>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- 搜索框 -->
        <Border Grid.Row="2"
                Margin="16,0,12,0"
                Padding="11,0,14,0"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1"
                Stroke="{DynamicResource GlassStrokeColor}"
                BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                IsVisible="{Binding IsSearchVisible}">
            <Grid ColumnDefinitions="Auto,*"
                  VerticalOptions="Center">
                <Image Source="ic_search.svg"
                       WidthRequest="16" HeightRequest="16" />
                <Entry Grid.Column="1"
                       Placeholder="搜索专辑或艺术家"
                       Text="{Binding SearchQuery}"
                       FontSize="13.5"
                       TextColor="{DynamicResource TextPrimaryColor}"
                       PlaceholderColor="{DynamicResource TextHintColor}"
                       VerticalOptions="Center"
                       Margin="9,0,0,0" />
            </Grid>
        </Border>

        <!-- 来源筛选 chips -->
        <ScrollView Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,12,0,0"
                    Padding="16,0">
            <HorizontalStackLayout Spacing="8" x:Name="FilterChips"
                                   BindableLayout.ItemsSource="{Binding SourceFilters}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14,7"
                                StrokeShape="RoundRectangle 999"
                                StrokeThickness="1"
                                BackgroundColor="{Binding BackgroundColor}"
                                Stroke="{Binding BorderColor}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterChipTapped" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding Label}"
                                   FontSize="12.5"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{Binding TextColor}" />
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- 工具栏 -->
        <Grid Grid.Row="3"
              ColumnDefinitions="*,Auto"
              Padding="16,8,16,8"
              Margin="0,52,0,0"
              VerticalOptions="Start">
            <ScrollView Grid.Column="0"
                        Orientation="Horizontal">
                <HorizontalStackLayout Spacing="6" x:Name="SortButtons"
                                       BindableLayout.ItemsSource="{Binding SortOptions}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="11,5"
                                    StrokeShape="RoundRectangle 999"
                                    StrokeThickness="1"
                                    Stroke="{Binding BorderColor}"
                                    BackgroundColor="{Binding BackgroundColor}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSortChipTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Label}"
                                       FontSize="11.5"
                                       TextColor="{Binding TextColor}" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- 视图切换 -->
            <Border Grid.Column="1"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="1"
                    Stroke="{DynamicResource GlassStrokeColor}"
                    BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                    Margin="10,0,0,0">
                <Grid ColumnDefinitions="Auto,Auto"
                      ColumnSpacing="0">
                    <Border Grid.Column="0"
                            WidthRequest="34" HeightRequest="30"
                            BackgroundColor="{Binding GridButtonColor}"
                            StrokeShape="RoundRectangle 10,0,0,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewToggleTapped" CommandParameter="grid" />
                        </Border.GestureRecognizers>
                        <Image Source="ic_grid.svg"
                               WidthRequest="16" HeightRequest="16"
                               Aspect="AspectFit"
                               VerticalOptions="Center" HorizontalOptions="Center" />
                    </Border>
                    <Border Grid.Column="1"
                            WidthRequest="34" HeightRequest="30"
                            BackgroundColor="{Binding ListButtonColor}"
                            StrokeShape="RoundRectangle 0,10,10,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewToggleTapped" CommandParameter="list" />
                        </Border.GestureRecognizers>
                        <Image Source="ic_list.svg"
                               WidthRequest="16" HeightRequest="16"
                               Aspect="AspectFit"
                               VerticalOptions="Center" HorizontalOptions="Center" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 主体布局：网格/列表 + 右侧年代 rail -->
        <Grid Grid.Row="4"
              ColumnDefinitions="*,Auto"
              Padding="8,4,0,8"
              ColumnSpacing="8">
            <!-- 网格视图 -->
                        <!-- 网格视图（虚拟化 + 按年代分组：ScrollView+嵌套FlexLayout 会一次性创建所有 cell，数据量大时主线程卡死） -->
            <CollectionView Grid.Column="0"
                            x:Name="GridCollectionView"
                            ItemsSource="{Binding EraGroups}"
                            IsGrouped="True"
                            SelectionMode="None"
                            IsVisible="{Binding IsGridView}"
                            Margin="0,4,0,0">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="8" VerticalItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate>
                        <HorizontalStackLayout Spacing="8" Padding="0,14,0,0">
                            <Label Text="{Binding Era}"
                                   FontSize="12"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextSecondaryColor}"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding Count, StringFormat='{0} 张'}"
                                   FontSize="10.5"
                                   TextColor="{DynamicResource TextHintColor}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="Transparent">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAlbumTapped" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="7">
                                <Border StrokeShape="RoundRectangle 14"
                                        StrokeThickness="0"
                                        BackgroundColor="{Binding Id, Converter={StaticResource PlaceholderColorConverter}}">
                                    <Grid>
                                        <Image Source="{Binding CoverArtPath}"
                                               Aspect="AspectFill"
                                               IsVisible="{Binding CoverArtPath, Converter={StaticResource CoverArtConverter}}" />
                                        <Label Text="{Binding Title, Converter={StaticResource InitialConverter}}"
                                               FontSize="30"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="#99FFFFFF"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               IsVisible="{Binding CoverArtPath, Converter={StaticResource CoverArtConverter}, ConverterParameter=invert}" />
                                    </Grid>
                                </Border>
                                <Label Text="{Binding Title}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimaryColor}"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />
                                <Label Text="{Binding ArtistName}"
                                       FontSize="10.5"
                                       TextColor="{DynamicResource TextHintColor}"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding SongCount, StringFormat='{0} 首'}"
                                       FontSize="10"
                                       TextColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- 列表视图 -->
            <CollectionView Grid.Column="0"
                            x:Name="ListCollectionView"
                            ItemsSource="{Binding FilteredAlbums}"
                            SelectionMode="None"
                            IsVisible="{Binding IsGridView, Converter={StaticResource InvertedBoolConverter}}"
                            Margin="0,4,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="9,6"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                BackgroundColor="Transparent"
                                Margin="0,0,0,2">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAlbumTapped" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12"
                                  VerticalOptions="Center">
                                <Border Grid.Column="0"
                                        WidthRequest="50" HeightRequest="50"
                                        StrokeShape="RoundRectangle 11"
                                        StrokeThickness="0"
                                        BackgroundColor="{Binding Id, Converter={StaticResource PlaceholderColorConverter}}">
                                    <Grid>
                                        <Image Source="{Binding CoverArtPath}"
                                               Aspect="AspectFill"
                                               IsVisible="{Binding CoverArtPath, Converter={StaticResource CoverArtConverter}}" />
                                        <Label Text="{Binding Title, Converter={StaticResource InitialConverter}}"
                                               FontSize="18"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="#DDFFFFFF"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               IsVisible="{Binding CoverArtPath, Converter={StaticResource CoverArtConverter}, ConverterParameter=invert}" />
                                    </Grid>
                                </Border>
                                <VerticalStackLayout Grid.Column="1"
                                                     VerticalOptions="Center"
                                                     Spacing="2">
                                    <Label Text="{Binding Title}"
                                           FontSize="13.5"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{DynamicResource TextPrimaryColor}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding ArtistName, StringFormat='{0} · '}"
                                           FontSize="11.5"
                                           TextColor="{DynamicResource TextHintColor}"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                                <HorizontalStackLayout Grid.Column="2"
                                                       VerticalOptions="Center"
                                                       Spacing="4">
                                    <Ellipse WidthRequest="7" HeightRequest="7"
                                             Fill="#55D6FF" />
                                    <Label Text="{Binding SongCount, StringFormat='{0} 首'}"
                                           FontSize="11"
                                           TextColor="{DynamicResource TextHintColor}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- 年代 rail -->
            <ScrollView Grid.Column="1"
                        IsVisible="{Binding IsGridView}"
                        Margin="0,4,0,0">
                <VerticalStackLayout Spacing="2" x:Name="EraRail"
                                     BindableLayout.ItemsSource="{Binding EraRailItems}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    BackgroundColor="{Binding BackgroundColor}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnEraTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Label}"
                                       FontSize="10.5"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{Binding TextColor}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- 加载指示器 -->
        <ActivityIndicator Grid.Row="4"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{DynamicResource PrimaryColor}"
                           HorizontalOptions="Center" VerticalOptions="Center" />
    </Grid>
</ContentPage>
