<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatClawMusic.Maui.Pages.SettingsPage"
             Title="设置"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid Background="{DynamicResource PageBackgroundBrush}">

        <Border WidthRequest="300" HeightRequest="300"
                StrokeThickness="0" StrokeShape="Ellipse"
                Background="{DynamicResource PrimaryGlowBrush}"
                HorizontalOptions="Start" VerticalOptions="Start"
                TranslationX="-130" TranslationY="-70" />

        <Border WidthRequest="240" HeightRequest="240"
                StrokeThickness="0" StrokeShape="Ellipse"
                Background="{DynamicResource AccentGlowBrush}"
                HorizontalOptions="End" VerticalOptions="Start"
                TranslationX="100" TranslationY="180" />

        <ScrollView>
            <VerticalStackLayout Padding="16,18,16,22" Spacing="12">

                <!-- Hero Header -->
                <Border Style="{StaticResource GlassCardStrongStyle}"
                        Background="{DynamicResource HeroBrush}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="设置"
                                   Style="{StaticResource PageTitleStyle}"
                                   TextColor="White" />
                            <Label Text="切换主题、管理音乐来源与插件，把猫爪音乐打磨成你喜欢的样子。"
                                   Style="{StaticResource PageSubtitleStyle}"
                                   TextColor="#F2F4FF" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                Style="{StaticResource GlassIconContainerStyle}"
                                BackgroundColor="#24FFFFFF"
                                Stroke="#40FFFFFF"
                                VerticalOptions="Start">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDarkModeToggleClicked" />
                            </Border.GestureRecognizers>
                            <Image Source="{Binding DarkModeIcon}"
                                   WidthRequest="40" HeightRequest="40"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Section: 内容与服务 -->
                <Label Text="内容与服务"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="4,8,0,2" />

                <!-- 外观与个性化 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="ic_edit" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="外观与个性化" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="主题颜色、启动页设置" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="ic_arrow_forward"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAppearanceSettingsClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 本地音乐 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="ic_folder" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="本地音乐" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding LocalMusicStatus}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="ic_arrow_forward"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLocalMusicClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 远程音乐服务 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="ic_search" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="远程音乐服务" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding RemoteMusicStatus}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="ic_arrow_forward"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRemoteMusicClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 插件管理 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="ic_equalizer" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="插件管理" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding PluginStatus}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="ic_arrow_forward"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPluginManagementClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 探索设置 (AI) -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="ic_play" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="探索设置" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding AiStatus}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="ic_arrow_forward"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAiSettingsClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Section: 系统与维护 -->
                <Label Text="系统与维护"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="4,12,0,2" />

                <!-- 权限管理 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="ic_lock_locked" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="权限管理" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding PermissionStatus}" FontSize="12"
                                   TextColor="{Binding PermissionStatusColor}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="ic_arrow_forward"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPermissionManagementClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 通用设置 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="ic_settings" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="通用设置" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="通用行为、播放偏好与系统选项" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="ic_arrow_forward"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGeneralSettingsClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 备份与恢复 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto, Auto" ColumnSpacing="16">
                        <Image Source="ic_folder" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="备份与恢复" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="备份、恢复、管理备份文件" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <BoxView Grid.Column="2"
                                 x:Name="UpdateRedDot"
                                 WidthRequest="10" HeightRequest="10"
                                 Color="{DynamicResource ErrorColor}"
                                 IsVisible="{Binding IsUpdateAvailable}"
                                 VerticalOptions="Center" />
                        <Image Grid.Column="3" Source="ic_arrow_forward"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackupRestoreClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 关于 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="16">
                        <Image Source="ic_check" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="关于" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="版本信息、开源协议、交流群" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <BoxView Grid.Column="2"
                                 x:Name="UpdateRedDot2"
                                 WidthRequest="10" HeightRequest="10"
                                 Color="{DynamicResource ErrorColor}"
                                 IsVisible="{Binding IsUpdateAvailable}"
                                 VerticalOptions="Center" />
                        <Image Grid.Column="3" Source="ic_arrow_forward"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAboutClicked" />
                    </Border.GestureRecognizers>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
