<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             x:Class="CatClawMusic.Maui.Pages.SettingsPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings]}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid Background="{DynamicResource PageBackgroundBrush}"
          RowDefinitions="*,Auto">
        <Grid.Behaviors>
            <controls:SafeAreaPaddingBehavior />
        </Grid.Behaviors>

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16,18,16,22" Spacing="12">

                <!-- Hero Header -->
                <Border Style="{StaticResource GlassCardStrongStyle}"
                        Background="{DynamicResource HeroBrush}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings]}"
                                   Style="{StaticResource PageTitleStyle}"
                                   TextColor="White" />
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[SettingsSubtitle]}"
                                   Style="{StaticResource PageSubtitleStyle}"
                                   TextColor="#F2F4FF" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                Style="{StaticResource GlassIconContainerStyle}"
                                BackgroundColor="#24FFFFFF"
                                Stroke="{DynamicResource GlassStrokeColor}"
                                VerticalOptions="Start">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDarkModeToggleClicked" />
                            </Border.GestureRecognizers>
                            <Image Source="{Binding DarkModeIcon}"
                                   WidthRequest="40" HeightRequest="40"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Section: 内容与服务 -->
                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ContentAndServices]}"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="4,8,0,2" />

                <!-- 外观与个性化 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_edit_light, Dark=ic_edit}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Appearance]}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AppearanceDesc]}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAppearanceSettingsClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 桌面歌词 -->
                <Border Style="{StaticResource GlassCardStyle}"
                        IsVisible="{OnPlatform Default=false, Android=true}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_lyrics_light, Dark=ic_lyrics}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitleDesktopLyric]}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DesktopLyricDesc]}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDesktopLyricClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 本地音乐 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_folder_light, Dark=ic_folder}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[LocalMusic]}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding LocalMusicStatus}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLocalMusicClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 远程音乐服务 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_search_light, Dark=ic_search}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[RemoteMusic]}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding RemoteMusicStatus}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRemoteMusicClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 插件管理 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_equalizer_light, Dark=ic_equalizer}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Plugins]}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding PluginStatus}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPluginManagementClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 探索设置 (AI) -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_play_light, Dark=ic_play}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ExploreSettings]}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding AiStatus}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAiSettingsClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Section: 系统与维护 -->
                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[SystemAndMaintenance]}"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="4,12,0,2" />

                <!-- 权限管理（仅 Android 需要运行时权限；Windows/PC 无意义，隐藏） -->
                <Border Style="{StaticResource GlassCardStyle}"
                        IsVisible="{OnPlatform Default=false, Android=true}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_lock_locked_light, Dark=ic_lock_locked}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Permissions]}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding PermissionStatus}" FontSize="12"
                                   TextColor="{Binding PermissionStatusColor}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPermissionManagementClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 通用设置 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_settings_light, Dark=ic_settings}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[GeneralSettings]}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[GeneralSettingsDesc]}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGeneralSettingsClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 备份与恢复 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto, Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_folder_light, Dark=ic_folder}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupRestore]}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[BackupRestoreDesc]}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <BoxView Grid.Column="2"
                                 x:Name="UpdateRedDot"
                                 WidthRequest="10" HeightRequest="10"
                                 Color="{DynamicResource ErrorColor}"
                                 IsVisible="{Binding IsUpdateAvailable}"
                                 VerticalOptions="Center" />
                        <Image Grid.Column="3" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackupRestoreClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 诊断日志 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_info_light, Dark=ic_info}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="诊断日志" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="查看、搜索并导出应用日志，协助排查问题" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDiagnosticLogClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 关于 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="16">
                        <Image Source="{AppThemeBinding Light=ic_check_light, Dark=ic_check}" WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" Opacity="0.8" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[About]}" FontSize="15" FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AboutDesc]}" Style="{StaticResource PageSubtitleStyle}" />
                        </VerticalStackLayout>
                        <BoxView Grid.Column="2"
                                 x:Name="UpdateRedDot2"
                                 WidthRequest="10" HeightRequest="10"
                                 Color="{DynamicResource ErrorColor}"
                                 IsVisible="{Binding IsUpdateAvailable}"
                                 VerticalOptions="Center" />
                        <Image Grid.Column="3" Source="{AppThemeBinding Light=ic_arrow_forward_light, Dark=ic_arrow_forward}"
                               WidthRequest="18" HeightRequest="18"
                               VerticalOptions="Center" Opacity="0.5" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAboutClicked" />
                    </Border.GestureRecognizers>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 底部毛玻璃底栏（纯视觉，与主 TabBar 同款）：覆盖 Android 系统导航条区域，保持底部磨砂一致性 -->
        <Grid Grid.Row="1" x:Name="BottomGlassBar"
              HeightRequest="52"
              BackgroundColor="{DynamicResource TabBarBackgroundColor}"
              IsVisible="{OnPlatform Default=false, Android=true}"
              InputTransparent="True">
            <controls:FrostedBackground
                Source="{DynamicResource ThemeBackgroundImage}"
                IsActive="{DynamicResource ThemeBackgroundEnabled}"
                IsVisible="{DynamicResource ThemeBackgroundEnabled}"
                TintColor="{DynamicResource TabBarGlassTint}"
                TintOpacity="0.28"
                DimAmount="0"
                Opacity="0.45"
                Aspect="AspectFill"
                UseNativeBlur="True"
                InputTransparent="True" />
            <BoxView HeightRequest="1"
                     VerticalOptions="Start"
                     BackgroundColor="{DynamicResource TabInactiveColor}"
                     Opacity="0.22"
                     InputTransparent="True" />
        </Grid>
    </Grid>
</ContentPage>
