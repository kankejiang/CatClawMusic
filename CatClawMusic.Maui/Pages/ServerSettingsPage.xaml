<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.ServerSettingsPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitleServerSettings]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">
    <Grid RowDefinitions="Auto,*" Background="{DynamicResource PageBackgroundBrush}">

        <!-- Frosted glass background: blurred theme image, semi-transparent -->
        <controls:FrostedBackground Grid.RowSpan="2"
            Source="{DynamicResource ThemeBackgroundImage}"
            IsActive="{DynamicResource ThemeBackgroundEnabled}"
            IsVisible="{DynamicResource ThemeBackgroundEnabled}"
            TintColor="{DynamicResource TabBarGlassTint}"
            TintOpacity="0.45"
            DimAmount="0.25"
            Opacity="0.8"
            Aspect="AspectFill"
            UseNativeBlur="True"
            InputTransparent="True" />
        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center" Padding="44,0,0,0">
                    <Label Text="服务器设置" Style="{StaticResource PageTitleStyle}" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FeatureInDev]}" Style="{StaticResource PageSubtitleStyle}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>
    </Grid>
</ContentPage>
