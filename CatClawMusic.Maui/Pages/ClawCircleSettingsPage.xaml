<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:converters="clr-namespace:CatClawMusic.Maui.Converters"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             xmlns:models="clr-namespace:CatClawMusic.Core.Models"
             x:Class="CatClawMusic.Maui.Pages.ClawCircleSettingsPage"
             Title="猫爪圈"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Padding="44,0,0,0" Spacing="6">
                    <Label Text="🐾 猫爪圈"
                           Style="{StaticResource PageTitleStyle}"
                           TextColor="White" />
                    <Label Text="在同一局域网内发现其他猫爪音乐用户，互看在听什么、直传歌曲。"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextColor="#F3F5FF" />
                    <Label Text="{Binding StatusText}"
                           FontSize="12"
                           TextColor="#B8C7FF" />
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,22" Spacing="14">

                <!-- 总开关 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleEnable]}"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleEnableDesc]}"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsEnabled}"
                                OnColor="{DynamicResource PrimaryColor}"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- 设备名 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleDeviceName]}"
                               FontSize="13"
                               TextColor="{DynamicResource TextSecondaryColor}" />
                        <Entry Text="{Binding DeviceName}"
                               Placeholder="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleDeviceNameHint]}"
                               BackgroundColor="#22FFFFFF"
                               TextColor="{DynamicResource TextPrimaryColor}"
                               PlaceholderColor="{DynamicResource TextHintColor}" />
                        <Label Text="{Binding LocalEndpoint, StringFormat='本机地址：{0}'}"
                               FontSize="12"
                               TextColor="{DynamicResource TextHintColor}"
                               IsVisible="{Binding IsRunning}" />
                    </VerticalStackLayout>
                </Border>

                <!-- 共享曲库 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleShare]}"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleShareDesc]}"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding ShareLibrary}"
                                OnColor="{DynamicResource PrimaryColor}"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- 自动启动 -->
                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleAutoStart]}"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleAutoStartDesc]}"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding AutoStart}"
                                OnColor="{DynamicResource PrimaryColor}"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- 跨网 P2P 服务端 -->
                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleTrackerSection]}"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="4,10,0,2" />
                <Border Style="{StaticResource GlassCardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleTrackerUrl]}"
                                   FontSize="13"
                                   TextColor="{DynamicResource TextSecondaryColor}" />
                            <Entry Text="{Binding TrackerUrl}"
                                   Placeholder="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleTrackerUrlHint]}"
                                   BackgroundColor="#22FFFFFF"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   PlaceholderColor="{DynamicResource TextHintColor}"
                                   Keyboard="Url" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleTrackerToken]}"
                                   FontSize="13"
                                   TextColor="{DynamicResource TextSecondaryColor}" />
                            <Entry Text="{Binding TrackerToken}"
                                   Placeholder="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleTrackerTokenHint]}"
                                   BackgroundColor="#22FFFFFF"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   PlaceholderColor="{DynamicResource TextHintColor}"
                                   IsPassword="True" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- 扫描按钮 -->
                <Button Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleScan]}"
                        Command="{Binding RefreshCommand}"
                        BackgroundColor="{DynamicResource PrimaryColor}"
                        TextColor="White"
                        CornerRadius="18"
                        HeightRequest="46"
                        FontSize="14" />

                <!-- 发现的设备 -->
                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleDevices]}"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="4,4,0,2" />

                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCircleNoDevices]}"
                       FontSize="12"
                       TextColor="{DynamicResource TextHintColor}"
                       IsVisible="{Binding HasPeers, Converter={StaticResource InvertedBoolConverter}}" />

                <CollectionView ItemsSource="{Binding Peers}"
                                SelectionMode="None"
                                IsVisible="{Binding HasPeers}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ClawCirclePeer">
                            <Border Style="{StaticResource GlassCardStyle}" Margin="0,0,0,8">
                                <Grid Padding="2" ColumnDefinitions="*,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding DeviceName}"
                                               FontSize="15"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{DynamicResource TextPrimaryColor}" />
                                        <Label Text="{Binding Ip}"
                                               FontSize="11"
                                               TextColor="{DynamicResource TextHintColor}" />
                                        <Label Text="{Binding Summary}"
                                               FontSize="11"
                                               TextColor="{DynamicResource TextHintColor}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                        <Label Text="在线"
                                               FontSize="11"
                                               TextColor="{DynamicResource PrimaryColor}"
                                               IsVisible="{Binding IsOnline}" />
                                        <Label Text="离线"
                                               FontSize="11"
                                               TextColor="{DynamicResource TextHintColor}"
                                               IsVisible="{Binding IsOnline, Converter={StaticResource InvertedBoolConverter}}" />
                                        <Button Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BrowseLabel}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BrowsePeerCommand}"
                                                CommandParameter="{Binding .}"
                                                FontSize="11"
                                                HeightRequest="30"
                                                CornerRadius="14"
                                                Padding="10,0"
                                                BackgroundColor="#33FFFFFF"
                                                TextColor="{DynamicResource TextSecondaryColor}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- 对端歌单 -->
                <StackLayout IsVisible="{Binding HasPeerSongs}"
                             Spacing="8">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ClawCirclePeerSongs]}"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="4,4,0,2" />

                    <ActivityIndicator IsRunning="{Binding IsLoadingPeerSongs}"
                                       IsVisible="{Binding IsLoadingPeerSongs}"
                                       Color="{DynamicResource PrimaryColor}" />

                    <CollectionView ItemsSource="{Binding PeerSongs}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ClawCircleSongInfo">
                                <Border Style="{StaticResource GlassCardStyle}" Margin="0,0,0,6">
                                    <Grid Padding="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="{DynamicResource TextPrimaryColor}" />
                                            <Label Text="{Binding Summary}"
                                                   FontSize="11"
                                                   TextColor="{DynamicResource TextHintColor}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1"
                                                Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PullLabel}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DownloadSongCommand}"
                                                CommandParameter="{Binding .}"
                                                FontSize="11"
                                                HeightRequest="32"
                                                CornerRadius="14"
                                                Padding="12,0"
                                                BackgroundColor="{DynamicResource PrimaryColor}"
                                                TextColor="White"
                                                VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>

                <!-- 下载提示 -->
                <Label Text="{Binding DownloadMessage}"
                       FontSize="12"
                       TextColor="{DynamicResource TextSecondaryColor}"
                       IsVisible="{Binding DownloadMessage, Converter={StaticResource StringToBoolConverter}}" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
