<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatClawMusic.Maui.Pages.MainPage"
             Title="猫爪音乐"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <Grid RowDefinitions="*,Auto,Auto"
          Background="{DynamicResource PageBackgroundBrush}">

        <!-- 自定义背景图片层（用户可选，覆盖在渐变背景之上、内容之下） -->
        <Image x:Name="CustomBackgroundImage"
               Aspect="AspectFill"
               Source="{DynamicResource CustomBackgroundImage}"
               IsVisible="{DynamicResource CustomBackgroundEnabled}"
               Opacity="{DynamicResource CustomBackgroundOpacity}"
               InputTransparent="True" />

        <!-- 背景遮罩层：在自定义背景图上加半透明暗色/亮色，确保文字可读 -->
        <BoxView x:Name="BackgroundMask"
                 Color="{DynamicResource CustomBackgroundMaskColor}"
                 IsVisible="{DynamicResource CustomBackgroundEnabled}"
                 InputTransparent="True" />

        <!-- ViewPager 区域：所有 tab 页面水平排列，滑动时同时移动 -->
        <Grid x:Name="ViewPagerGrid" Grid.Row="0"
              BackgroundColor="Transparent"
              IsClippedToBounds="True">
            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnPanUpdated" />
            </Grid.GestureRecognizers>
        </Grid>

        <!-- 迷你播放器：封面 + 歌曲信息 + 上一曲/播放暂停/下一曲 -->
        <Grid Grid.Row="1" x:Name="MiniPlayer"
              ColumnDefinitions="Auto,*,Auto,Auto,Auto"
              ColumnSpacing="10"
              Padding="10,6"
              HeightRequest="52"
              BackgroundColor="{DynamicResource CardBackgroundColor}"
              IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnMiniPlayerTapped" />
            </Grid.GestureRecognizers>

            <!-- 封面 -->
            <Border Grid.Column="0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    WidthRequest="40" HeightRequest="40"
                    BackgroundColor="{DynamicResource ChipInactiveColor}">
                <Image Source="{Binding CoverImage}"
                       Aspect="AspectFill" />
            </Border>

            <!-- 歌曲标题/艺术家 -->
            <VerticalStackLayout Grid.Column="1"
                                 Spacing="1"
                                 VerticalOptions="Center">
                <Label Text="{Binding Title}"
                       FontSize="13"
                       FontFamily="OpenSansSemibold"
                       TextColor="{DynamicResource TextPrimaryColor}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />
                <Label Text="{Binding Artist}"
                       FontSize="11"
                       TextColor="{DynamicResource TextSecondaryColor}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <!-- 上一曲 -->
            <Border Grid.Column="2"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    Background="{DynamicResource PrimaryGlowBrush}"
                    WidthRequest="28" HeightRequest="28"
                    VerticalOptions="Center">
                <ImageButton Source="ic_skip_previous"
                             WidthRequest="18" HeightRequest="18"
                             BackgroundColor="Transparent"
                             Command="{Binding PlayPreviousCommand}"
                             HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <!-- 播放/暂停：主题色圆形背景 + 白色图标 -->
            <Border Grid.Column="3"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18"
                    Background="{DynamicResource HeroBrush}"
                    WidthRequest="36" HeightRequest="36"
                    VerticalOptions="Center">
                <ImageButton Source="{Binding PlayPauseIconSource}"
                             WidthRequest="22" HeightRequest="22"
                             BackgroundColor="Transparent"
                             Command="{Binding TogglePlayPauseCommand}"
                             HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <!-- 下一曲 -->
            <Border Grid.Column="4"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    Background="{DynamicResource PrimaryGlowBrush}"
                    WidthRequest="28" HeightRequest="28"
                    VerticalOptions="Center">
                <ImageButton Source="ic_skip_next"
                             WidthRequest="18" HeightRequest="18"
                             BackgroundColor="Transparent"
                             Command="{Binding PlayNextCommand}"
                             HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- 自定义底部 TabBar -->
        <Grid Grid.Row="2" x:Name="TabBar"
              ColumnDefinitions="*,*,*,*,*"
              HeightRequest="64"
              BackgroundColor="{DynamicResource TabBarBackgroundColor}"
              Padding="0,4,0,8">

            <Grid Grid.Column="0" x:Name="TabItem0">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image WidthRequest="26" HeightRequest="26" HorizontalOptions="Center"
                           x:Name="TabIcon0">
                        <Image.Source>
                            <AppThemeBinding Light="ic_play_light" Dark="ic_play" />
                        </Image.Source>
                    </Image>
                    <Label Text="播放" FontSize="10" HorizontalTextAlignment="Center" x:Name="TabLabel0" />
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Column="1" x:Name="TabItem1">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image WidthRequest="26" HeightRequest="26" HorizontalOptions="Center"
                           x:Name="TabIcon1">
                        <Image.Source>
                            <AppThemeBinding Light="ic_home_light" Dark="ic_home" />
                        </Image.Source>
                    </Image>
                    <Label Text="发现" FontSize="10" HorizontalTextAlignment="Center" x:Name="TabLabel1" />
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Column="2" x:Name="TabItem2">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image WidthRequest="26" HeightRequest="26" HorizontalOptions="Center"
                           x:Name="TabIcon2">
                        <Image.Source>
                            <AppThemeBinding Light="ic_playlist_light" Dark="ic_playlist" />
                        </Image.Source>
                    </Image>
                    <Label Text="歌单" FontSize="10" HorizontalTextAlignment="Center" x:Name="TabLabel2" />
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Column="3" x:Name="TabItem3">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image WidthRequest="26" HeightRequest="26" HorizontalOptions="Center"
                           x:Name="TabIcon3">
                        <Image.Source>
                            <AppThemeBinding Light="ic_library_light" Dark="ic_library" />
                        </Image.Source>
                    </Image>
                    <Label Text="音乐库" FontSize="10" HorizontalTextAlignment="Center" x:Name="TabLabel3" />
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Column="4" x:Name="TabItem4">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image WidthRequest="26" HeightRequest="26" HorizontalOptions="Center"
                           x:Name="TabIcon4">
                        <Image.Source>
                            <AppThemeBinding Light="ic_settings_light" Dark="ic_settings" />
                        </Image.Source>
                    </Image>
                    <Label Text="设置" FontSize="10" HorizontalTextAlignment="Center" x:Name="TabLabel4" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- 启动加载页：统一风格的品牌 Splash Screen，与 MAUI 原生 Splash 视觉一致 -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="3"
              Background="{DynamicResource PageBackgroundBrush}"
              IsVisible="False"
              InputTransparent="False"
              ZIndex="999">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="24">
                <Border WidthRequest="120" HeightRequest="120"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 32"
                        Background="{DynamicResource HeroBrush}"
                        HorizontalOptions="Center">
                    <Image Source="splash_cat_dark.png"
                           WidthRequest="72" HeightRequest="72"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="猫爪音乐"
                       FontSize="28"
                       FontFamily="OpenSansSemibold"
                       TextColor="{DynamicResource TextPrimaryColor}"
                       HorizontalOptions="Center" />
                <Label Text="CatClaw Music"
                       FontSize="14"
                       TextColor="{DynamicResource TextSecondaryColor}"
                       HorizontalOptions="Center" />
                <ActivityIndicator IsRunning="True"
                                   Color="{DynamicResource PrimaryColor}"
                                   WidthRequest="36" HeightRequest="36"
                                   Margin="0,16,0,0" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
