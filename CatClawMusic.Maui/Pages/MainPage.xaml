<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             x:Class="CatClawMusic.Maui.Pages.MainPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AppName]}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource WindowBackgroundColor}"
             SafeAreaEdges="None">

    <Grid RowDefinitions="*,Auto,Auto"
          Background="{DynamicResource PageBackgroundBrush}"
          SafeAreaEdges="None">

        <!-- 主题内置背景图片层（星空/天空静态图，跟随主题色与深浅模式自动切换） -->
        <Image x:Name="ThemeBackgroundImage"
               Aspect="AspectFill"
               Source="{DynamicResource ThemeBackgroundImage}"
               IsVisible="{DynamicResource ThemeBackgroundEnabled}"
               Opacity="1.0"
               InputTransparent="True" />

        <!-- 背景遮罩层：在主题背景图上加半透明暗色/亮色，确保文字可读 -->
        <BoxView x:Name="BackgroundMask"
                 Color="{DynamicResource CustomBackgroundMaskColor}"
                 IsVisible="{DynamicResource ThemeBackgroundEnabled}"
                 InputTransparent="True" />

        <!-- ViewPager 区域：所有 tab 页面水平排列，滑动时同时移动 -->
        <Grid x:Name="ViewPagerGrid" Grid.Row="0"
              BackgroundColor="Transparent"
              IsClippedToBounds="True"
              SafeAreaEdges="None">
            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnPanUpdated" />
            </Grid.GestureRecognizers>
        </Grid>

        <!-- 迷你播放器：封面 + 歌曲信息 + 上一曲/播放暂停/下一曲 -->
        <Grid Grid.Row="1" x:Name="MiniPlayer"
              ColumnDefinitions="Auto,*,Auto,Auto,Auto"
              ColumnSpacing="10"
              Padding="10,6"
              HeightRequest="52"
              Background="{DynamicResource HeroBrush}"
              IsVisible="False"
              SafeAreaEdges="None">

            <!-- 封面 -->
            <Border Grid.Column="0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    WidthRequest="40" HeightRequest="40"
                    BackgroundColor="{DynamicResource ChipInactiveColor}">
                <Image Source="{Binding CoverImage}"
                       Aspect="AspectFill" />
            </Border>

            <!-- 歌曲标题/艺术家 -->
            <VerticalStackLayout Grid.Column="1"
                                 Spacing="1"
                                 VerticalOptions="Center">
                <Label Text="{Binding Title}"
                       FontSize="13"
                       FontFamily="OpenSansSemibold"
                       TextColor="White"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />
                <Label Text="{Binding Artist}"
                       FontSize="11"
                       TextColor="#CCFFFFFF"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <!-- 透明按钮覆盖封面+歌曲信息区域，避免 Grid 级 TapGestureRecognizer 在嵌套布局中失效 -->
            <Button Grid.Column="0" Grid.ColumnSpan="2"
                    BackgroundColor="Transparent"
                    Text=""
                    BorderWidth="0"
                    CornerRadius="0"
                    Padding="0"
                    Clicked="OnMiniPlayerTapped"
                    HorizontalOptions="Fill" VerticalOptions="Fill" />

            <!-- 上一曲 -->
            <Button Grid.Column="2"
                    WidthRequest="28" HeightRequest="28"
                    CornerRadius="14" Padding="0"
                    BackgroundColor="Transparent"
                    ImageSource="{Binding PlayPreviousIconSourceWhite}"
                    Command="{Binding PlayPreviousCommand}"
                    VerticalOptions="Center" HorizontalOptions="Center" />

            <!-- 播放/暂停：透明背景 + 白色图标 -->
            <Button Grid.Column="3"
                    WidthRequest="36" HeightRequest="36"
                    CornerRadius="18" Padding="0"
                    BackgroundColor="Transparent"
                    ImageSource="{Binding PlayPauseIconSourceWhite}"
                    Command="{Binding TogglePlayPauseCommand}"
                    VerticalOptions="Center" HorizontalOptions="Center" />

            <!-- 下一曲 -->
            <Button Grid.Column="4"
                    WidthRequest="28" HeightRequest="28"
                    CornerRadius="14" Padding="0"
                    BackgroundColor="Transparent"
                    ImageSource="{Binding PlayNextIconSourceWhite}"
                    Command="{Binding PlayNextCommand}"
                    VerticalOptions="Center" HorizontalOptions="Center" />
        </Grid>

        <!-- 自定义底部 TabBar（4个Tab：播放/发现/歌单/音乐库），透明 + 毛玻璃 -->
        <Grid Grid.Row="2" x:Name="TabBar"
              ColumnDefinitions="*,*,*,*"
              BackgroundColor="Transparent"
              Padding="0,4,0,4"
              SafeAreaEdges="None">

            <!-- 毛玻璃层：复用同一张主题背景图做模糊磨砂，跟随深浅模式压暗/提亮 -->
            <controls:FrostedBackground Grid.ColumnSpan="4"
                                        Source="{DynamicResource ThemeBackgroundImage}"
                                        IsActive="{DynamicResource ThemeBackgroundEnabled}"
                                        IsVisible="{DynamicResource ThemeBackgroundEnabled}"
                                        TintColor="{DynamicResource TabBarGlassTint}"
                                        TintOpacity="0.42"
                                        DimAmount="0"
                                        Aspect="AspectFill"
                                        InputTransparent="True" />

            <!-- 顶部分隔细线，增强与内容区的视觉区分 -->
            <BoxView Grid.ColumnSpan="4"
                     HeightRequest="1"
                     VerticalOptions="Start"
                     BackgroundColor="{DynamicResource TabInactiveColor}"
                     Opacity="0.22"
                     InputTransparent="True" />

            <Grid Grid.Column="0" x:Name="TabItem0"
                  HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout x:Name="TabContent0" Spacing="3" HorizontalOptions="Center" VerticalOptions="Center">
                    <ImageButton WidthRequest="24" HeightRequest="24" HorizontalOptions="Center"
                                 x:Name="TabIcon0"
                                 Source="ic_play"
                                 BackgroundColor="Transparent"
                                 BorderWidth="0"
                                 Padding="0"
                                 InputTransparent="True" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabPlaying]}" FontSize="10" HorizontalTextAlignment="Center" x:Name="TabLabel0" />
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Column="1" x:Name="TabItem1"
                  HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout x:Name="TabContent1" Spacing="3" HorizontalOptions="Center" VerticalOptions="Center">
                    <ImageButton WidthRequest="24" HeightRequest="24" HorizontalOptions="Center"
                                 x:Name="TabIcon1"
                                 Source="ic_home"
                                 BackgroundColor="Transparent"
                                 BorderWidth="0"
                                 Padding="0"
                                 InputTransparent="True" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabDiscover]}" FontSize="10" HorizontalTextAlignment="Center" x:Name="TabLabel1" />
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Column="2" x:Name="TabItem2"
                  HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout x:Name="TabContent2" Spacing="3" HorizontalOptions="Center" VerticalOptions="Center">
                    <ImageButton WidthRequest="24" HeightRequest="24" HorizontalOptions="Center"
                                 x:Name="TabIcon2"
                                 Source="ic_playlist"
                                 BackgroundColor="Transparent"
                                 BorderWidth="0"
                                 Padding="0"
                                 InputTransparent="True" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabPlaylists]}" FontSize="10" HorizontalTextAlignment="Center" x:Name="TabLabel2" />
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Column="3" x:Name="TabItem3"
                  HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout x:Name="TabContent3" Spacing="3" HorizontalOptions="Center" VerticalOptions="Center">
                    <ImageButton WidthRequest="24" HeightRequest="24" HorizontalOptions="Center"
                                 x:Name="TabIcon3"
                                 Source="ic_library"
                                 BackgroundColor="Transparent"
                                 BorderWidth="0"
                                 Padding="0"
                                 InputTransparent="True" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TabLibrary]}" FontSize="10" HorizontalTextAlignment="Center" x:Name="TabLabel3" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- 启动加载页：纯文字品牌 Splash Screen -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="3"
              Background="{DynamicResource PageBackgroundBrush}"
              IsVisible="False"
              InputTransparent="False"
              ZIndex="999">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AppName]}"
                       FontSize="42"
                       FontFamily="OpenSansSemibold"
                       TextColor="{DynamicResource TextPrimaryColor}"
                       HorizontalOptions="Center" />
                <Label Text="CatClaw Music"
                       FontSize="16"
                       TextColor="{DynamicResource TextSecondaryColor}"
                       HorizontalOptions="Center" />
                <ActivityIndicator IsRunning="True"
                                   Color="{DynamicResource PrimaryColor}"
                                   WidthRequest="36" HeightRequest="36"
                                   Margin="0,32,0,0" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
