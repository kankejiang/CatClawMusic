<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.ArtistMatchDetailPage"
             Title="艺术家匹配详情"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <controls:HeroCard>
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center" Padding="44,0,0,0">
                    <Label Text="艺术家匹配详情" Style="{StaticResource PageTitleStyle}" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FeatureInDev]}"
                           Style="{StaticResource PageSubtitleStyle}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>
</Grid>
</ContentPage>
