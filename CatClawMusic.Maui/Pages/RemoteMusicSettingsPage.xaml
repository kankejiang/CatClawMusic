<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:converters="clr-namespace:CatClawMusic.Maui.Converters"
             xmlns:vm="clr-namespace:CatClawMusic.Maui.ViewModels"
             xmlns:coreModels="clr-namespace:CatClawMusic.Core.Models;assembly=CatClawMusic.Core"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.RemoteMusicSettingsPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[RemoteMusic]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">

    <ContentPage.Resources>
        <converters:ProtocolToTextConverter x:Key="ProtocolToText" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource PageBackgroundBrush}">

        <!-- Frosted glass background: blurred theme image, semi-transparent -->
        <controls:FrostedBackground Grid.RowSpan="2"
            Source="{DynamicResource ThemeBackgroundImage}"
            IsActive="{DynamicResource ThemeBackgroundEnabled}"
            IsVisible="{DynamicResource ThemeBackgroundEnabled}"
            TintColor="{DynamicResource TabBarGlassTint}"
            TintOpacity="0.45"
            DimAmount="0.25"
            Opacity="0.8"
            Aspect="AspectFill"
            UseNativeBlur="True"
            InputTransparent="True" />

        <controls:HeroCard Grid.Row="0">
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Padding="44,0,0,0" Spacing="6">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[RemoteMusic]}"
                           Style="{StaticResource PageTitleStyle}"
                           TextColor="White" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[RemoteMusicSubtitle]}"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextColor="#F3F5FF" />
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,22" Spacing="14">

                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid Padding="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[CacheSongs]}"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}" />
                            <Label Text="{Binding CachedSongCount, StringFormat='已缓存 {0} 首网络歌曲'}"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[EmptyCache]}"
                                Command="{Binding ClearCacheCommand}"
                                BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                                TextColor="{DynamicResource TextPrimaryColor}"
                                CornerRadius="14"
                                HeightRequest="36"
                                FontSize="12"
                                VerticalOptions="Center"
                                IsEnabled="{Binding HasCachedSongs}" />
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ConfiguredConnections]}"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="4,4,0,2" />
                    <Button Grid.Column="1"
                            Text="+ 新建"
                            Command="{Binding StartCreateCommand}"
                            BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="34"
                            Padding="14,0"
                            FontSize="12" />
                </Grid>

                <!-- 同步进度面板 -->
                <Border Style="{StaticResource GlassCardStyle}"
                        IsVisible="{Binding IsSyncing}">
                    <VerticalStackLayout Spacing="8" Padding="4">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <ActivityIndicator IsRunning="True"
                                               Color="{DynamicResource PrimaryColor}"
                                               WidthRequest="20"
                                               HeightRequest="20"
                                               VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding SyncingProfileName, StringFormat='正在同步「{0}」'}"
                                   FontSize="13"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2"
                                   Text="{Binding SyncStatus}"
                                   FontSize="11"
                                   TextColor="{DynamicResource TextHintColor}"
                                   VerticalOptions="Center"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1" />
                        </Grid>
                        <ProgressBar Progress="{Binding SyncProgress}"
                                     ProgressColor="{DynamicResource PrimaryColor}"
                                     HeightRequest="4"
                                     IsVisible="{Binding HasSyncProgress}" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="10"
                                     BindableLayout.ItemsSource="{Binding Profiles}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="coreModels:ConnectionProfile">
                            <Border Style="{StaticResource GlassCardStyle}">
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                        <Label Text="🔗" FontSize="18" VerticalOptions="Center" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="{DynamicResource TextPrimaryColor}" />
                                            <Label Text="{Binding Host, StringFormat='{0}'}"
                                                   FontSize="11"
                                                   TextColor="{DynamicResource TextHintColor}" />
                                        </VerticalStackLayout>
                                        <Border Grid.Column="2"
                                                Padding="8,3"
                                                Stroke="{DynamicResource GlassStrokeColor}"
                                                StrokeShape="RoundRectangle 10"
                                                BackgroundColor="#1AFFFFFF"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Protocol, Converter={StaticResource ProtocolToText}}"
                                                   FontSize="10"
                                                   TextColor="#B8C7FF" />
                                        </Border>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*,*,Auto" ColumnSpacing="8">
                                        <Button Grid.Column="0"
                                                Text="测试"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TestProfileCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                                Opacity="0.75"
                                                TextColor="White"
                                                CornerRadius="12"
                                                HeightRequest="34"
                                                FontSize="11" />
                                        <Button Grid.Column="1"
                                                Text="同步"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SyncProfileCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                HeightRequest="34"
                                                FontSize="11" />
                                        <Button Grid.Column="2"
                                                Text="编辑"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StartEditCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                                                TextColor="{DynamicResource TextPrimaryColor}"
                                                CornerRadius="12"
                                                HeightRequest="34"
                                                FontSize="11" />
                                        <Button Grid.Column="3"
                                                Text="删除"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteProfileCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{DynamicResource ErrorColor}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                HeightRequest="34"
                                                WidthRequest="60"
                                                FontSize="11" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Border Style="{StaticResource GlassCardStyle}"
                        IsVisible="{Binding Profiles.Count, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="📡"
                               FontSize="34"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[NoConnections]}"
                               Style="{StaticResource PageSubtitleStyle}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[NoConnectionsHint]}"
                               FontSize="11"
                               TextColor="{DynamicResource TextHintColor}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource GlassCardStrongStyle}"
                        IsVisible="{Binding IsEditing}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding FormTitle}"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource TextPrimaryColor}" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="名称" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}" />
                            <Entry Text="{Binding FormName}"
                                   Placeholder="我的音乐库"
                                   BackgroundColor="#22FFFFFF"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   PlaceholderColor="{DynamicResource TextHintColor}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="协议" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}" />
                            <Picker ItemsSource="{Binding ProtocolOptions}"
                                    SelectedIndex="{Binding FormProtocolIndex}"
                                    BackgroundColor="#22FFFFFF"
                                    TextColor="{DynamicResource TextPrimaryColor}"
                                    TitleColor="{DynamicResource TextSecondaryColor}" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="主机地址" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}" />
                                <Entry Text="{Binding FormHost}"
                                       Placeholder="10.0.0.101 或 example.com"
                                       Keyboard="Url"
                                       BackgroundColor="#22FFFFFF"
                                       TextColor="{DynamicResource TextPrimaryColor}"
                                       PlaceholderColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4" WidthRequest="100">
                                <Label Text="端口" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}" />
                                <Entry Text="{Binding FormPort}"
                                       Keyboard="Numeric"
                                       BackgroundColor="#22FFFFFF"
                                       TextColor="{DynamicResource TextPrimaryColor}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="用户名" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}" />
                                <Entry Text="{Binding FormUserName}"
                                       BackgroundColor="#22FFFFFF"
                                       TextColor="{DynamicResource TextPrimaryColor}"
                                       PlaceholderColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="密码" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}" />
                                <Entry Text="{Binding FormPassword}"
                                       IsPassword="True"
                                       BackgroundColor="#22FFFFFF"
                                       TextColor="{DynamicResource TextPrimaryColor}"
                                       PlaceholderColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="4"
                                              IsVisible="{Binding IsNavidromeForm, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="基础路径" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Border BackgroundColor="#22FFFFFF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12,0"
                                        HeightRequest="40">
                                    <Label Text="{Binding FormBasePath}"
                                           FontSize="13"
                                           TextColor="{DynamicResource TextPrimaryColor}"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation" />
                                </Border>
                                <Button Grid.Column="1"
                                        Text="选择路径"
                                        Command="{Binding BrowsePathCommand}"
                                        BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                        TextColor="White"
                                        CornerRadius="8"
                                        HeightRequest="40"
                                        FontSize="12"
                                        WidthRequest="72" />
                            </Grid>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label Text="使用 HTTPS"
                                   FontSize="13"
                                   TextColor="{DynamicResource TextPrimaryColor}"
                                   VerticalOptions="Center" />
                            <Switch IsToggled="{Binding FormUseHttps}"
                                    OnColor="{DynamicResource PrimaryColor}"
                                    VerticalOptions="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10"
                              IsVisible="{Binding IsSmbForm}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="SMB 共享名" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}" />
                                <Entry Text="{Binding FormShareName}"
                                       BackgroundColor="#22FFFFFF"
                                       TextColor="{DynamicResource TextPrimaryColor}"
                                       PlaceholderColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="域名（可选）" FontSize="12" TextColor="{DynamicResource TextSecondaryColor}" />
                                <Entry Text="{Binding FormDomainName}"
                                       BackgroundColor="#22FFFFFF"
                                       TextColor="{DynamicResource TextPrimaryColor}"
                                       PlaceholderColor="{DynamicResource TextHintColor}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                            <Button Grid.Column="0"
                                    Text="取消"
                                    Command="{Binding CancelEditCommand}"
                                    BackgroundColor="{DynamicResource CardBackgroundStrongColor}"
                                    TextColor="{DynamicResource TextPrimaryColor}"
                                    CornerRadius="16"
                                    HeightRequest="42"
                                    FontSize="13" />
                            <Button Grid.Column="1"
                                    Text="保存"
                                    Command="{Binding SaveProfileCommand}"
                                    BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                    TextColor="White"
                                    CornerRadius="16"
                                    HeightRequest="42"
                                    FontSize="13" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.RowSpan="2"
              BackgroundColor="#80000000"
              IsVisible="{Binding IsBrowsing}"
              ZIndex="200">
            <Border Style="{StaticResource GlassCardStrongStyle}"
                    BackgroundColor="{DynamicResource CardBackgroundColor}"
                    WidthRequest="340"
                    MaximumHeightRequest="520"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Padding="0">
                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          Background="{DynamicResource HeroBrush}"
                          Padding="16,12">
                        <Label Text="选择远程目录"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="✕"
                                Command="{Binding CloseBrowseCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="16"
                                Padding="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center" />
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,Auto"
                          Padding="12,10"
                          BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
                        <Label Text="{Binding BrowseCurrentPath}"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondaryColor}"
                               VerticalOptions="Center"
                               LineBreakMode="TailTruncation" />
                        <Button Grid.Column="1"
                                Text="选择此目录"
                                Command="{Binding SelectCurrentDirCommand}"
                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="32"
                                FontSize="11"
                                Padding="10,0" />
                    </Grid>

                    <Grid Grid.Row="2" BackgroundColor="{DynamicResource CardBackgroundColor}">
                        <CollectionView ItemsSource="{Binding DirectoryItems}"
                                        SelectionMode="None"
                                        Margin="0">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:RemoteDirItem">
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10"
                                          Padding="16,12">
                                        <Image Source="ic_folder"
                                               WidthRequest="20"
                                               HeightRequest="20"
                                               VerticalOptions="Center"
                                               Opacity="0.8" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontSize="14"
                                               TextColor="{DynamicResource TextPrimaryColor}"
                                               VerticalOptions="Center"
                                               LineBreakMode="TailTruncation" />
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenDirCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <ActivityIndicator IsRunning="{Binding IsLoadingDirs}"
                                           IsVisible="{Binding IsLoadingDirs}"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           Color="{DynamicResource PrimaryColor}" />
                    </Grid>

                    <Grid Grid.Row="3"
                          ColumnDefinitions="*,*"
                          Padding="12,10"
                          BackgroundColor="{DynamicResource CardBackgroundStrongColor}">
                        <Button Text="返回上级"
                                Command="{Binding GoUpCommand}"
                                BackgroundColor="{DynamicResource CardBackgroundColor}"
                                TextColor="{DynamicResource TextSecondaryColor}"
                                CornerRadius="10"
                                HeightRequest="36"
                                FontSize="12" />
                        <Button Grid.Column="1"
                                Text="确定"
                                Command="{Binding SelectCurrentDirCommand}"
                                BackgroundColor="{DynamicResource PrimaryButtonBackgroundColor}"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="36"
                                FontSize="12" />
                    </Grid>

                </Grid>
            </Border>
        </Grid>

</Grid>
</ContentPage>
