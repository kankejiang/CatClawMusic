<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CatClawMusic.Maui.Controls"
             xmlns:services="clr-namespace:CatClawMusic.Maui.Services"
             x:Class="CatClawMusic.Maui.Pages.SongDetailPage"
             Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitleSongDetail]}"
             BackgroundColor="{DynamicResource WindowBackgroundColor}">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <controls:HeroCard>
            <controls:HeroCard.CardContent>
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center" Padding="44,0,0,0">
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PageTitleSongDetail]}" Style="{StaticResource PageTitleStyle}" />
                    <Label Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FeatureInDev]}"
                           Style="{StaticResource PageSubtitleStyle}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </controls:HeroCard.CardContent>
        </controls:HeroCard>
</Grid>
</ContentPage>
