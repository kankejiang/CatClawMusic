<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CatClawMusic.Mau.i.ViewModels"
             x:Class="CatClawMusic.Mau.i.Pages.PlaylistDetailPage"
             Title="{Binding Playlist.Name}">

    <ContentPage.BindingContext>
        <vm:PlaylistDetailViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Playlist Header -->
        <VerticalStackLayout Grid.Row="0" 
                       Padding="20,20,20,15"
                       BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">
            
            <Label Text="{Binding Playlist.Name}"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            
            <Label Text="{Binding StatusText}"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#B0B0B0}"
                   Margin="0,5,0,0" />
        </VerticalStackLayout>

        <!-- Song List -->
        <CollectionView Grid.Row="1"
                      ItemsSource="{Binding Songs}"
                      SelectionMode="Single"
                      SelectionChanged="OnSongSelected">
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{Binding Title}"
                                   FontSize="16"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Label Text="{Binding Artist}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#B0B0B0}" />
                        </VerticalStackLayout>

                        <Label Grid.Column="1"
                               Text="{Binding Duration, StringFormat='{0:mm\\:ss}'}"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#999999, Dark=#808080}"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="1"
                                   IsVisible="{Binding Songs.Count, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0, FallbackValue=false}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center">
            <Label Text="暂无歌曲"
                   FontSize="18"
                   TextColor="{AppThemeBinding Light=#999999, Dark=#808080}" />
            <Label Text="点击右上角添加歌曲"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#999999, Dark=#808080}"
                   Margin="0,10,0,0" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
